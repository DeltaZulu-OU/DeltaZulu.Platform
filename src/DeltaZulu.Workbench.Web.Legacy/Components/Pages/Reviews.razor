@namespace Workbench.Web.Components.Pages
@page "/reviews"
@using MudBlazor
@rendermode InteractiveServer
@using Workbench.Application.Services
@using Workbench.Domain.Changes
@using Workbench.Domain.Enums
@using Workbench.Domain.Reviews
@using Workbench.Web.Services
@inject ChangeService ChangeService
@inject NavigationManager Nav
@inject PocUserContext UserContext

<PageTitle>Reviews</PageTitle>

<DzPageHeader Title="Your reviews"
              Description="Changes awaiting your review decision and your review history." />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="6" md="4">
            <DzMetricTile Eyebrow="Awaiting your decision"
                          Value="@_awaitingCount.ToString()"
                          Label="Changes needing your review" />
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <DzMetricTile Eyebrow="Reviewed by you"
                          Value="@_reviewedByYouCount.ToString()"
                          Label="Changes you have reviewed" />
        </MudItem>
    </MudGrid>

    @if (!_showAuditView)
    {
        @if (_awaitingChanges.Count == 0 && _reviewedByYou.Count == 0)
        {
            <DzEmptyState Title="No review activity for your account yet."
                          Description="Changes awaiting your review and your review history will appear here."
                          Icon="@Icons.Material.Outlined.RateReview" />
        }

        @if (_awaitingChanges.Count > 0)
        {
            <MudText Typo="Typo.subtitle2" Class="dz-section-title">Awaiting your decision</MudText>
            <DzTableShell Class="mb-4">
                <MudTable Items="_awaitingChanges" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm"
                          OnRowClick="@(args => Nav.NavigateTo($"/changes/{args.Item!.Id}"))"
                          T="ChangeRequest" RowClass="cursor-pointer" Elevation="0">
                    <HeaderContent>
                        <MudTh>Key</MudTh>
                        <MudTh>Title</MudTh>
                        <MudTh>Profile</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Updated</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Key"><code>@context.Key</code></MudTd>
                        <MudTd DataLabel="Title">@context.Title</MudTd>
                        <MudTd DataLabel="Profile"><DzMetaChip Kind="workflow">@context.WorkflowProfileId</DzMetaChip></MudTd>
                        <MudTd DataLabel="Status"><StatusChip ChangeStatus="context.Status" /></MudTd>
                        <MudTd DataLabel="Updated"><MudText Typo="Typo.caption">@context.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</MudText></MudTd>
                    </RowTemplate>
                </MudTable>
            </DzTableShell>
        }

        @if (_reviewedByYou.Count > 0)
        {
            <MudText Typo="Typo.subtitle2" Class="dz-section-title">Your review history</MudText>
            <DzTableShell>
                <MudTable Items="_reviewedByYou" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" T="ReviewRow" Elevation="0">
                    <HeaderContent>
                        <MudTh>Change</MudTh>
                        <MudTh>Decision</MudTh>
                        <MudTh>State</MudTh>
                        <MudTh>Recorded</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Change">
                            <DzActionLink OnClick="@(() => Nav.NavigateTo($"/changes/{context.Change.Id}"))">
                                <code>@context.Change.Key</code>
                            </DzActionLink>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Change.Title</MudText>
                        </MudTd>
                        <MudTd DataLabel="Decision">
                            <DzReviewDecisionChip Decision="@context.Review.Decision" />
                        </MudTd>
                        <MudTd DataLabel="State">
                            @ReviewState(context.Review)
                        </MudTd>
                        <MudTd DataLabel="Recorded">
                            <MudText Typo="Typo.caption">@context.Review.CreatedAt.ToString("yyyy-MM-dd HH:mm")</MudText>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </DzTableShell>
        }
    }
    else
    {
        <DzTableShell>
            <MudTable Items="_allRows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" T="ReviewRow" Elevation="0">
                <HeaderContent>
                    <MudTh>Change</MudTh>
                    <MudTh>Decision</MudTh>
                    <MudTh>State</MudTh>
                    <MudTh>Comment</MudTh>
                    <MudTh>Recorded</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Change">
                        <DzActionLink OnClick="@(() => Nav.NavigateTo($"/changes/{context.Change.Id}"))">
                            <code>@context.Change.Key</code>
                        </DzActionLink>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Change.Title</MudText>
                    </MudTd>
                    <MudTd DataLabel="Decision">
                        <DzReviewDecisionChip Decision="@context.Review.Decision" />
                    </MudTd>
                    <MudTd DataLabel="State">
                        @ReviewState(context.Review)
                    </MudTd>
                    <MudTd DataLabel="Comment">
                        @if (string.IsNullOrWhiteSpace(context.Review.Comment))
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">—</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">@context.Review.Comment</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Recorded">
                        <MudText Typo="Typo.caption">@context.Review.CreatedAt.ToString("yyyy-MM-dd HH:mm")</MudText>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </DzTableShell>
    }

    <DzActionLink OnClick="@(() => _showAuditView = !_showAuditView)" Class="mt-3">
        @(_showAuditView ? "Show my reviews" : "Show all reviews (audit view)")
    </DzActionLink>
}

@code {
    private bool _loading = true;
    private bool _showAuditView;
    private List<ChangeRequest> _awaitingChanges = [];
    private List<ReviewRow> _reviewedByYou = [];
    private List<ReviewRow> _allRows = [];
    private int _awaitingCount;
    private int _reviewedByYouCount;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        var userId = UserContext.CurrentUser.Id;
        var changes = await ChangeService.ListAsync();

        _awaitingChanges = changes
            .Where(c => c.Status == ChangeStatus.ReviewRequired && c.AuthorId != userId)
            .ToList();
        _awaitingCount = _awaitingChanges.Count;

        _reviewedByYou = changes
            .SelectMany(c => c.Reviews.Where(r => r.ReviewerId == userId).Select(r => new ReviewRow(c, r)))
            .OrderByDescending(row => row.Review.CreatedAt)
            .ToList();
        _reviewedByYouCount = _reviewedByYou.Select(r => r.Change.Id).Distinct().Count();

        _allRows = changes
            .SelectMany(c => c.Reviews.Select(r => new ReviewRow(c, r)))
            .OrderByDescending(row => row.Review.CreatedAt)
            .ToList();

        _loading = false;
    }

    private static RenderFragment ReviewState(Review review) => builder =>
    {
        builder.OpenComponent<DzStatusChip>(0);
        builder.AddAttribute(1, "Label", review.IsSuperseded ? "Superseded" : "Effective");
        builder.AddAttribute(2, "Tone", review.IsSuperseded ? "muted" : "success");
        builder.CloseComponent();
    };

    private sealed record ReviewRow(ChangeRequest Change, Review Review);
}
