@namespace DeltaZulu.Workbench.Web.Components.Pages
@page "/changes/{Id}"
@using MudBlazor
@rendermode InteractiveServer
@using DeltaZulu.Workbench.Application.Services
@using DeltaZulu.Workbench.Domain.Changes
@using DeltaZulu.Workbench.Domain.Detections
@using DeltaZulu.Workbench.Domain.Issues
@using DeltaZulu.Workbench.Domain.Enums
@using DeltaZulu.Workbench.Domain.Identifiers
@using DeltaZulu.Workbench.Domain.Workflow
@using DeltaZulu.Workbench.Web.Services
@inject ChangeService ChangeService
@inject AcceptedContentReadService AcceptedContentReadService
@inject DetectionContentService DetectionService
@inject IssueService IssueService
@inject CheckPipelineRunner PipelineRunner
@inject MergeService MergeService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject PocUserContext UserContext

<PageTitle>Change — @(_change?.Key ?? "Loading")</PageTitle>

@if (_change is null)
{
    <MudProgressLinear Indeterminate="true" />
    return;
}

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-2" />

@* ── Header ── *@
<DzPageHeader Eyebrow="Change"
              Title="@($"{_change.Key} {_change.Title}")"
              Description="@ChangeReadinessSummary()">
    <Metadata>
        <StatusChip ChangeStatus="_change.Status" />
        <DzMetaChip Kind="workflow" Title="@ProfileDescription(_change.WorkflowProfileId)">
            @GovernanceLabel(_change.WorkflowProfileId)
        </DzMetaChip>
        <DzMetaChip Kind="actor">
            Acting as @UserContext.CurrentUser.DisplayName
        </DzMetaChip>
        @if (_change.IsStale)
        {
            <DzStatusChip Label="Stale" Tone="warning" />
        }
    </Metadata>
    <Actions>
        @if (!IsTerminal)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="RunChecks"
                       Disabled="_running" StartIcon="@Icons.Material.Outlined.PlaylistAddCheck">
                Run checks
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="RequestCloseChange"
                       Disabled="_running" StartIcon="@Icons.Material.Outlined.Close">
                Close
            </MudButton>
        }
    </Actions>
</DzPageHeader>

@if (_linkedIssue is not null)
{
    <div class="dz-linked-issue mb-4">
        <MudIcon Icon="@Icons.Material.Outlined.Link" Size="Size.Small" Class="dz-inline-icon" />
        <DzActionLink OnClick="@(() => Nav.NavigateTo($"/issues/{_linkedIssue.Id}"))">
            Issue: <code>@_linkedIssue.Key</code> @_linkedIssue.Title
        </DzActionLink>
    </div>
}

@* ── Stale base warning ── *@
@if (_change.IsStale && !IsTerminal)
{
    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-4">
        @(_change.StaleReason ?? "A newer version was accepted since this change was opened. Review the latest accepted content before proceeding.")
    </MudAlert>
}

@* ── Gate checklist ── *@
@if (!IsTerminal)
{
    <GateChecklist Readiness="_readiness" Change="_change"
                   OnRunChecks="RunChecks" OnRequestReview="ScrollToReview"
                   OnAccept="Accept" IsRunning="_running" />
}

<MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" @ref="_tabs">

    @* ── Content tab ── *@
    <MudTabPanel Text="Content" BadgeData="@_change.DraftFiles.Count" BadgeColor="Color.Secondary">
        <DzTabBody>
            @if (ChecksMayBeStale && !IsTerminal)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                    Content was modified after the last check run. Results may be outdated.
                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Warning"
                               OnClick="RunChecks" Disabled="_running" Class="ml-2">
                        Re-run checks
                    </MudButton>
                </MudAlert>
            }
            @if (!IsTerminal)
            {
                <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Outlined.NoteAdd"
                           OnClick="@(() => _showAddFile = !_showAddFile)" Class="mb-3">
                    Add or edit file
                </MudButton>
            }

            @if (_showAddFile)
            {
                <DzPanel Compact="true" Outlined="true" Elevation="0" Class="mb-3">
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="4">
                            <MudTextField Value="_newPath" ValueChanged="OnNewPathChanged" Label="Logical path" HelperText="e.g. detection.yaml, notes/investigation.md" T="string" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudSelect @bind-Value="_newContentType" Label="Content type" T="DraftContentType">
                                @foreach (var ct in Enum.GetValues<DraftContentType>())
                                {
                                    <MudSelectItem Value="ct">@ct</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_newContent" Label="Content" Lines="8" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary"
                                       OnClick="SaveDraftFile">Save file</MudButton>
                        </MudItem>
                    </MudGrid>
                </DzPanel>
            }

            @if (_change.DraftFiles.Count == 0)
            {
                <DzEmptyState Title="No draft files yet."
                              Description="Add content to begin the change."
                              Icon="@Icons.Material.Outlined.NoteAdd" />
            }
            else
            {
                @foreach (var group in _change.DraftFiles.GroupBy(f => f.ContentType).OrderBy(g => g.Key))
                {
                    <MudText Typo="Typo.subtitle2" Class="dz-file-group-title">@group.Key</MudText>
                    @foreach (var file in group)
                    {
                        <MudExpansionPanels Class="mb-2">
                            <MudExpansionPanel>
                                <TitleContent>
                                    <DzFileHeader Path="@file.Path.Value"
                                                  Kind="@file.ContentType.ToString()"
                                                  Metadata="@($"{file.SizeChars} chars")" />
                                </TitleContent>
                                <ChildContent>
                                    @if (file.ContentType == DraftContentType.InvestigationNote)
                                    {
                                        <MarkdownViewer Content="@file.Content" CurrentFilePath="@($"detections/{_detection?.Slug}/{file.Path.Value}")" />
                                    }
                                    else if (file.ContentType == DraftContentType.StaticAsset)
                                    {
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Binary asset — @file.SizeChars chars (base64)</MudText>
                                    }
                                    else
                                    {
                                        <DzCodeBlock Content="@file.Content" Light="true" Compact="true" MaxHeightPx="400" />
                                    }
                                    @if (!IsTerminal)
                                    {
                                        <div class="dz-file-actions">
                                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Secondary"
                                                       StartIcon="@Icons.Material.Outlined.Edit"
                                                       OnClick="@(() => BeginEditFile(file))">
                                                Edit
                                            </MudButton>
                                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Error"
                                                       StartIcon="@Icons.Material.Outlined.Delete"
                                                       OnClick="@(() => RequestDeleteFileAsync(file.Path.Value))">
                                                Delete
                                            </MudButton>
                                        </div>
                                    }
                                </ChildContent>
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                    }
                }
            }
        </DzTabBody>
    </MudTabPanel>

    @* ── Draft vs Accepted tab ── *@
    <MudTabPanel Text="Draft vs accepted" BadgeData="@_draftComparisons.Count(c => c.Status != DraftAcceptedComparisonStatus.Unchanged)" BadgeColor="Color.Warning">
        <DzTabBody>
            @if (_draftComparisons.Count == 0)
            {
                <DzEmptyState Title="No draft files to compare."
                              Description="Add or edit draft content before comparing it against accepted content."
                              Icon="@Icons.Material.Outlined.Difference" />
            }
            else
            {
                <MudText Typo="Typo.body2" Class="dz-comparison-description">
                    Compares each draft file against the current accepted content for this detection.
                </MudText>
                @foreach (var comp in _draftComparisons)
                {
                    <MudExpansionPanels Class="mb-2">
                        <MudExpansionPanel>
                            <TitleContent>
                                <div class="d-flex align-center gap-2 flex-wrap">
                                    <DzComparisonStatusChip Status="@comp.Status" />
                                    <code>@comp.LogicalPath</code>
                                </div>
                            </TitleContent>
                            <ChildContent>
                                @if (comp.Status == DraftAcceptedComparisonStatus.Unchanged)
                                {
                                    <MudAlert Severity="Severity.Info" Dense="true">Draft content is identical to the accepted version.</MudAlert>
                                }
                                else
                                {
                                    <DzDiffPair LeftTitle="Accepted"
                                                RightTitle="Draft"
                                                LeftContent="@comp.AcceptedContent"
                                                RightContent="@comp.DraftContent"
                                                MaxHeightPx="400" />
                                }
                            </ChildContent>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                }
            }
        </DzTabBody>
    </MudTabPanel>

    @* ── Validation tab ── *@
    <MudTabPanel Text="Validation" BadgeData="@_change.Checks.Count" BadgeColor="Color.Info">
        <DzTabBody>
            @if (ChecksMayBeStale && !IsTerminal)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                    Content was modified after the last check run. Results may be outdated.
                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Warning"
                               OnClick="RunChecks" Disabled="_running" Class="ml-2">
                        Re-run checks
                    </MudButton>
                </MudAlert>
            }
            @if (_change.Checks.Count > 0)
            {
                var passed = _change.Checks.Count(c => c.Status == CheckStatus.Passed);
                var total = _change.Checks.Count;
                var failed = _change.Checks.Count(c => c.Status == CheckStatus.Failed);
                <div class="dz-change-summary">
                    <MudText Typo="Typo.body2">
                        @passed of @total check(s) passed
                        @if (failed > 0)
                        {
                            <span class="dz-change-summary__failure"> — @failed failure(s)</span>
                        }
                    </MudText>
                    @if (!IsTerminal)
                    {
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Secondary"
                                   OnClick="RunChecks" Disabled="_running"
                                   StartIcon="@Icons.Material.Outlined.Refresh">
                            Re-run checks
                        </MudButton>
                    }
                </div>
            }

            @if (_change.Checks.Count == 0)
            {
                <DzEmptyState Title="No checks have been run yet."
                              Description="Run checks to validate the draft content before acceptance."
                              Icon="@Icons.Material.Outlined.PlaylistAddCheck">
                    <Actions>
                        @if (!IsTerminal)
                        {
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Secondary"
                                       OnClick="RunChecks" Disabled="_running"
                                       StartIcon="@Icons.Material.Outlined.PlaylistAddCheck">
                                Run checks
                            </MudButton>
                        }
                    </Actions>
                </DzEmptyState>
            }
            else
            {
                <DzTableShell>
                    <MudTable Items="_change.Checks.OrderByDescending(c => c.IsBlocking).ThenBy(c => c.Status)"
                              Dense="true" T="CheckRun" Elevation="0">
                        <HeaderContent>
                            <MudTh>Check</MudTh>
                            <MudTh>Blocking</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Summary</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="check">
                            <MudTd DataLabel="Check"><code>@check.Name</code></MudTd>
                            <MudTd DataLabel="Blocking">@(check.IsBlocking ? "Yes" : "No")</MudTd>
                            <MudTd DataLabel="Status"><StatusChip CheckStatus="check.Status" /></MudTd>
                            <MudTd DataLabel="Summary">
                                <MudText Typo="Typo.body2">@check.Summary</MudText>
                                @if (!string.IsNullOrWhiteSpace(check.LogsExcerpt))
                                {
                                    <MudExpansionPanels Class="mt-1">
                                        <MudExpansionPanel Text="Technical details" Dense="true">
                                            <DzCodeBlock Content="@check.LogsExcerpt" Light="true" Compact="true" MaxHeightPx="320" />
                                        </MudExpansionPanel>
                                    </MudExpansionPanels>
                                }
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </DzTableShell>
            }
        </DzTabBody>
    </MudTabPanel>

    @* ── Review tab ── *@
    <MudTabPanel Text="Review" BadgeData="@_change.Reviews.Count" BadgeColor="Color.Secondary">
        <DzTabBody>
            @if (!IsTerminal)
            {
                var profile = WorkflowProfile.For(_change.WorkflowProfileId);
                @if (profile.RequiresApproval)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                        @if (profile.RequiresNonAuthorApprover)
                        {
                            <span>This workflow requires approval from someone other than the author.</span>
                        }
                        else
                        {
                            <span>This workflow requires at least one approval.</span>
                        }
                    </MudAlert>
                }

                <DzPanel Title="Record review" Compact="true" Outlined="true" Elevation="0" Class="mb-3">
                    <MudExpansionPanels Class="mb-3">
                        <MudExpansionPanel Text="Switch user for testing" Dense="true">
                            <MudAlert Severity="@(IsCurrentUserAuthor ? Severity.Warning : Severity.Info)" Dense="true" Class="mb-2">
                                Acting as @UserContext.CurrentUser.DisplayName. Controlled review blocks approval by the change author.
                            </MudAlert>
                            <MudSelect Value="UserContext.CurrentPersona" ValueChanged="SwitchUser" Label="POC user" T="PocUserPersona">
                                @foreach (var user in UserContext.AvailableUsers)
                                {
                                    <MudSelectItem Value="user.Persona">@user.DisplayName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="4">
                            <MudSelect @bind-Value="_reviewDecision" Label="Decision" T="ReviewDecision">
                                @foreach (var d in Enum.GetValues<ReviewDecision>())
                                {
                                    <MudSelectItem Value="d">@d</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="8">
                            <MudTextField @bind-Value="_reviewComment" Label="Comment" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary"
                                       OnClick="RecordReview">Submit review</MudButton>
                        </MudItem>
                    </MudGrid>
                </DzPanel>
            }

            @if (_change.Reviews.Count == 0)
            {
                <DzEmptyState Title="No reviews recorded yet."
                              Description="Record a review once the draft is ready for approval."
                              Icon="@Icons.Material.Outlined.RateReview" />
            }
            else
            {
                <MudTimeline TimelinePosition="TimelinePosition.Start" Class="dz-review-timeline">
                    @foreach (var review in _change.Reviews.OrderByDescending(r => r.CreatedAt))
                    {
                        <MudTimelineItem Color="@ReviewDecisionColor(review.Decision)"
                                         Size="Size.Small">
                            <ItemContent>
                                <div class="dz-review-item">
                                    <div class="dz-review-item__header">
                                        <DzReviewDecisionChip Decision="@review.Decision" />
                                        @if (review.IsSuperseded)
                                        {
                                            <DzStatusChip Label="Superseded" Tone="muted" />
                                        }
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@review.CreatedAt.ToString("yyyy-MM-dd HH:mm")</MudText>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(review.Comment))
                                    {
                                        <MudText Typo="Typo.body2" Class="dz-review-item__comment">@review.Comment</MudText>
                                    }
                                </div>
                            </ItemContent>
                        </MudTimelineItem>
                    }
                </MudTimeline>
            }
        </DzTabBody>
    </MudTabPanel>
</MudTabs>

@code {
    [Parameter] public string Id { get; set; } = null!;

    private ChangeRequest? _change;
    private Detection? _detection;
    private Issue? _linkedIssue;
    private MergeReadiness? _readiness;
    private bool _running;
    private List<BreadcrumbItem> _breadcrumbs = [];
    private MudTabs? _tabs;

    // Draft vs accepted comparison
    private List<DraftAcceptedComparison> _draftComparisons = [];

    // Add file
    private bool _showAddFile;
    private string _newPath = "";
    private DraftContentType _newContentType = DraftContentType.DetectionMetadata;
    private string _newContent = "";

    // Edit file
    private string? _editingFile;

    // Delete file
    private string _deletingFilePath = "";

    // Close change
    private string _closeReason = "";

    // Review
    private ReviewDecision _reviewDecision = ReviewDecision.Approved;
    private string _reviewComment = "";

    private bool IsTerminal => _change?.Status is ChangeStatus.Merged or ChangeStatus.Closed;
    private bool IsCurrentUserAuthor => _change?.AuthorId == UserContext.CurrentUser.Id;
    private bool ChecksMayBeStale => _change is not null
        && _change.Checks.Count > 0
        && _change.Checks.Any(c => c.CompletedAt is not null)
        && _change.UpdatedAt > _change.Checks.Where(c => c.CompletedAt is not null).Max(c => c.CompletedAt!.Value);

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        if (!Guid.TryParse(Id, out var guid)) return;
        var changeId = new ChangeRequestId(guid);

        _change = await ChangeService.GetByIdAsync(changeId);
        if (_change is null) return;

        _detection = await DetectionService.GetByIdAsync(_change.DetectionId);
        _readiness = _change.EvaluateMergeReadiness();

        if (_change.LinkedIssueId is not null)
        {
            _linkedIssue = await IssueService.GetByIdAsync(_change.LinkedIssueId.Value);
        }

        _breadcrumbs =
        [
            new("Changes", "/changes"),
            new(_change.Key, null, disabled: true),
        ];

        await LoadDraftComparisonsAsync();
    }

    private async Task LoadDraftComparisonsAsync()
    {
        _draftComparisons = [];
        if (_change is null || _detection is null) return;

        _draftComparisons = (await AcceptedContentReadService.CompareDraftToAcceptedAsync(_change.Id)).ToList();
    }

    private async Task SaveDraftFile()
    {
        if (_change is null || string.IsNullOrWhiteSpace(_newPath)) return;
        _running = true;
        try
        {
            await ChangeService.UpsertDraftFileAsync(
                _change.Id, _newPath.Trim(), _newContentType, _newContent, UserContext.CurrentUser.Id);
            _showAddFile = false;
            _editingFile = null;
            _newPath = "";
            _newContent = "";
            Snackbar.Add("Draft file saved.", Severity.Success);
            await LoadAsync();
        }
        catch (Domain.Common.DomainException ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _running = false; }
    }

    private async Task RunChecks()
    {
        if (_change is null) return;
        _running = true;
        try
        {
            var results = await PipelineRunner.RunAsync(_change.Id);
            var passed = results.Count(r => r.Outcome.Status == CheckStatus.Passed);
            var failed = results.Count(r => r.Outcome.Status == CheckStatus.Failed);
            Snackbar.Add($"Pipeline complete: {passed} passed, {failed} failed.", failed > 0 ? Severity.Warning : Severity.Success);
            await LoadAsync();
        }
        catch (Domain.Common.DomainException ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _running = false; }
    }

    private void ScrollToReview()
    {
        if (_tabs is not null)
        {
            _tabs.ActivatePanelAsync(3);
        }
    }

    private void SwitchUser(PocUserPersona persona)
    {
        UserContext.SwitchTo(persona);
    }

    private async Task RecordReview()
    {
        if (_change is null) return;
        _running = true;
        try
        {
            await ChangeService.RecordReviewAsync(_change.Id, UserContext.CurrentUser.Id, _reviewDecision, _reviewComment);
            _reviewComment = "";
            Snackbar.Add("Review recorded.", Severity.Success);
            await LoadAsync();
        }
        catch (Domain.Common.DomainException ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _running = false; }
    }

    private async Task Accept()
    {
        if (_change is null) return;
        _running = true;
        try
        {
            var version = await MergeService.MergeAsync(_change.Id, UserContext.CurrentUser.DisplayName, UserContext.CurrentUser.Email);
            Snackbar.Add($"Accepted. Version {version.DisplayVersion} created.", Severity.Success);
            await LoadAsync();
        }
        catch (Domain.Common.DomainException ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _running = false; }
    }

    // ── Inline file editing ──

    private void BeginEditFile(ChangeDraftFile file)
    {
        _editingFile = file.Path.Value;
        _newPath = file.Path.Value;
        _newContentType = file.ContentType;
        _newContent = file.Content;
        _showAddFile = true;
    }

    // ── Delete file ──

    private async Task RequestDeleteFileAsync(string path)
    {
        _deletingFilePath = path;

        var parameters = new DialogParameters<DeltaZulu.Blazor.Components.DzConfirmDialog>
        {
            { x => x.Title, "Delete file?" },
            { x => x.Message, $"Are you sure you want to delete {path}?" },
            { x => x.ConfirmText, "Delete" },
            { x => x.ConfirmColor, Color.Error },
            { x => x.Tone, "error" },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<DeltaZulu.Blazor.Components.DzConfirmDialog>("Delete file", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await ConfirmDeleteFile();
        }
    }

    private async Task ConfirmDeleteFile()
    {
        if (_change is null || string.IsNullOrWhiteSpace(_deletingFilePath)) return;
        _running = true;
        try
        {
            await ChangeService.RemoveDraftFileAsync(_change.Id, _deletingFilePath);
            Snackbar.Add("File deleted.", Severity.Success);
            await LoadAsync();
        }
        catch (Domain.Common.DomainException ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally
        {
            _running = false;
            _deletingFilePath = "";
        }
    }

    // ── Close change ──

    private async Task RequestCloseChange()
    {
        var parameters = new DialogParameters<DeltaZulu.Blazor.Components.DzConfirmDialog>
        {
            { x => x.Title, "Close change?" },
            { x => x.Message, "This will close the change without accepting. Please provide a reason." },
            { x => x.ConfirmText, "Confirm close" },
            { x => x.ConfirmColor, Color.Error },
            { x => x.Tone, "error" },
            { x => x.RequireReason, true },
            { x => x.ReasonLabel, "Reason" },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<DeltaZulu.Blazor.Components.DzConfirmDialog>("Close change", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            _closeReason = result.Data as string ?? "";
            await CloseChange();
        }
    }

    private async Task CloseChange()
    {
        if (_change is null) return;
        _running = true;
        try
        {
            await ChangeService.CloseAsync(_change.Id, _closeReason);
            _closeReason = "";
            Snackbar.Add("Change closed.", Severity.Success);
            await LoadAsync();
        }
        catch (Domain.Common.DomainException ex) { Snackbar.Add(ex.Message, Severity.Error); }
        finally { _running = false; }
    }

    // ── Content type auto-inference ──

    private void OnNewPathChanged(string path)
    {
        _newPath = path;
        _newContentType = InferContentType(path);
    }

    private string ChangeReadinessSummary()
    {
        if (IsTerminal)
        {
            return "This change is completed and retained for review.";
        }

        if (_readiness is null)
        {
            return "Readiness has not been evaluated yet.";
        }

        return _readiness.IsReady
            ? "Ready to accept."
            : _readiness.UnmetGates.FirstOrDefault()?.Message ?? "Acceptance gates are not yet satisfied.";
    }

    private static string ProfileDescription(WorkflowProfileId id) => id switch
    {
        WorkflowProfileId.QuickLab => "No approval required. Checks are optional.",
        WorkflowProfileId.ControlledReview => "Requires passing checks and non-author approval.",
        _ => "",
    };

    private static string GovernanceLabel(WorkflowProfileId id) => id switch
    {
        WorkflowProfileId.QuickLab => "No approval required",
        WorkflowProfileId.ControlledReview => "Requires approval",
        _ => id.ToString(),
    };

    private static DraftContentType InferContentType(string path)
    {
        var lower = path.Trim().ToLowerInvariant().Replace('\\', '/');

        if (lower.Contains("detection.yaml") || lower.Contains("detection.yml"))
            return DraftContentType.DetectionMetadata;

        if (lower.EndsWith(".kql") || lower.EndsWith(".kusto"))
            return DraftContentType.HuntingQuery;

        if (lower.StartsWith("tests/") && (lower.EndsWith(".yaml") || lower.EndsWith(".yml")))
            return DraftContentType.TestDefinition;

        if (lower.EndsWith(".json") || lower.EndsWith(".ndjson"))
            return DraftContentType.Fixture;

        if (lower.StartsWith("notes/") && lower.EndsWith(".md"))
            return DraftContentType.InvestigationNote;

        if (lower.StartsWith("notes/") && !lower.EndsWith(".md"))
            return DraftContentType.StaticAsset;

        return DraftContentType.DetectionMetadata;
    }

    private static Color ReviewDecisionColor(ReviewDecision decision) => decision switch
    {
        ReviewDecision.Approved => Color.Success,
        ReviewDecision.ChangesRequested => Color.Error,
        _ => Color.Default,
    };
}
