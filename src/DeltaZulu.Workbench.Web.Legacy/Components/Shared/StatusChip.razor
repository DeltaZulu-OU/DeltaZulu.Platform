@namespace DeltaZulu.Workbench.Web.Components.Shared
@using DeltaZulu.Workbench.Domain.Enums

@if (_text is not null)
{
    <DzStatusChip Label="@_text" Tone="@_tone" />
}

@code {
    [Parameter] public ChangeStatus? ChangeStatus { get; set; }
    [Parameter] public IssueStatus? IssueStatus { get; set; }
    [Parameter] public DetectionLifecycle? Lifecycle { get; set; }
    [Parameter] public CheckStatus? CheckStatus { get; set; }

    private string? _text;
    private string _tone = "neutral";

    protected override void OnParametersSet()
    {
        if (ChangeStatus is not null)
        {
            _text = ChangeStatus.Value.ToString();
            _tone = ChangeStatus.Value switch
            {
                ChangeStatus.Draft => "neutral",
                ChangeStatus.ChecksRunning => "info",
                ChangeStatus.ReviewRequired => "warning",
                ChangeStatus.ChangesRequested => "error",
                ChangeStatus.ReadyToAccept => "success",
                ChangeStatus.Merged => "dark",
                ChangeStatus.Published => "success",
                ChangeStatus.Closed => "muted",
                _ => "neutral",
            };
        }
        else if (IssueStatus is not null)
        {
            _text = IssueStatus.Value.ToString();
            _tone = IssueStatus.Value switch
            {
                IssueStatus.New => "neutral",
                IssueStatus.NeedsInfo => "warning",
                IssueStatus.Triaged => "info",
                IssueStatus.SanitizationRequired => "error",
                IssueStatus.Rejected => "muted",
                IssueStatus.Backlog => "neutral",
                IssueStatus.Ready => "info",
                IssueStatus.Blocked => "error",
                IssueStatus.InProgress => "warning",
                IssueStatus.InReview => "warning",
                IssueStatus.Merged => "success",
                IssueStatus.Published => "dark",
                IssueStatus.Closed => "muted",
                _ => "neutral",
            };
        }
        else if (Lifecycle is not null)
        {
            _text = Lifecycle.Value switch
            {
                DetectionLifecycle.Draft => "Draft",
                DetectionLifecycle.Accepted => "Accepted",
                DetectionLifecycle.Deprecated => "Deprecated",
                _ => Lifecycle.Value.ToString(),
            };
            _tone = Lifecycle.Value switch
            {
                DetectionLifecycle.Draft => "neutral",
                DetectionLifecycle.Accepted => "success",
                DetectionLifecycle.Deprecated => "muted",
                _ => "neutral",
            };
        }
        else if (CheckStatus is not null)
        {
            _text = CheckStatus.Value.ToString();
            _tone = CheckStatus.Value switch
            {
                CheckStatus.Passed => "success",
                CheckStatus.Failed => "error",
                CheckStatus.Running => "info",
                CheckStatus.Queued => "neutral",
                CheckStatus.Skipped => "muted",
                CheckStatus.Cancelled => "muted",
                _ => "neutral",
            };
        }
        else
        {
            _text = null;
            _tone = "neutral";
        }
    }
}
