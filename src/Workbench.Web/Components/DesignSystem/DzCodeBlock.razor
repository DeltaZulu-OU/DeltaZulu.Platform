<pre class="@BlockClass" @attributes="AdditionalAttributes"><code>@Content</code></pre>

@code {
    [Parameter] public string? Content { get; set; }
    [Parameter] public bool Wrap { get; set; } = true;
    [Parameter] public bool Light { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string BlockClass => string.Join(" ", new[]
    {
        "dz-code-block",
        Wrap ? "dz-code-block--wrap" : null,
        Light ? "dz-code-block--light" : null,
        Class
    }.Where(static value => !string.IsNullOrWhiteSpace(value)));
}
