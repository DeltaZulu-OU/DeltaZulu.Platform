<DzPanel Class="@PanelClass" Elevation="@Elevation" Outlined="@Outlined" @attributes="AdditionalAttributes">
    <div class="dz-empty-state__content">
        @if (!string.IsNullOrWhiteSpace(Icon))
        {
            <MudIcon Icon="@Icon" Size="Size.Large" Class="dz-empty-state__icon" />
        }

        <MudText Typo="Typo.h6" Class="dz-empty-state__title">@Title</MudText>

        @if (!string.IsNullOrWhiteSpace(Description))
        {
            <MudText Typo="Typo.body2" Class="dz-empty-state__description">@Description</MudText>
        }

        @if (Actions is not null)
        {
            <div class="dz-empty-state__actions">
                @Actions
            </div>
        }
    </div>
</DzPanel>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public int Elevation { get; set; } = 1;
    [Parameter] public bool Outlined { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string PanelClass => string.Join(" ", new[]
    {
        "dz-empty-state",
        Class
    }.Where(static value => !string.IsNullOrWhiteSpace(value)));
}
