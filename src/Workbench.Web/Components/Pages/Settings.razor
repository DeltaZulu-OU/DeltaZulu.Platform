@page "/settings"
@rendermode InteractiveServer
@using Microsoft.Extensions.Configuration
@using Workbench.Application.Abstractions
@using Workbench.Application.Services
@using Workbench.Domain.Common
@using Workbench.Domain.Enums
@using Workbench.Domain.Identifiers
@using Workbench.Web.Services
@inject IConfiguration Configuration
@inject PocUserContext UserContext
@inject MergeReconciliationService MergeReconciliation
@inject DetectionContentService DetectionService
@inject ChangeService ChangeService
@inject VersionService VersionService
@inject ISnackbar Snackbar

<PageTitle>Settings</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">Settings</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--color-text-secondary); max-width: 720px;">
    Current POC runtime configuration. Workflow engine and accepted content storage stay behind application abstractions.
</MudText>

<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="6" md="3">
        <MudPaper Class="pa-4 text-center" Elevation="1">
            <MudIcon Icon="@Icons.Material.Outlined.Shield" Size="Size.Large" Style="color: var(--brand-slate);" />
            <MudText Typo="Typo.h4" Class="mt-2" Style="font-weight: 700;">@_totalDetections</MudText>
            <MudText Typo="Typo.caption" Style="color: var(--color-text-secondary);">Detections</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" md="3">
        <MudPaper Class="pa-4 text-center" Elevation="1">
            <MudIcon Icon="@Icons.Material.Outlined.EditNote" Size="Size.Large" Style="color: var(--color-info);" />
            <MudText Typo="Typo.h4" Class="mt-2" Style="font-weight: 700;">@_openChanges</MudText>
            <MudText Typo="Typo.caption" Style="color: var(--color-text-secondary);">Open changes</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" md="3">
        <MudPaper Class="pa-4 text-center" Elevation="1">
            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Large" Style="color: var(--color-success);" />
            <MudText Typo="Typo.h4" Class="mt-2" Style="font-weight: 700;">@_acceptedVersions</MudText>
            <MudText Typo="Typo.caption" Style="color: var(--color-text-secondary);">Accepted versions</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" md="3">
        <MudPaper Class="pa-4 text-center" Elevation="1">
            <MudIcon Icon="@Icons.Material.Outlined.Error" Size="Size.Large" Style="color: var(--color-error);" />
            <MudText Typo="Typo.h4" Class="mt-2" Style="font-weight: 700;">@_failedCheckChanges</MudText>
            <MudText Typo="Typo.caption" Style="color: var(--color-text-secondary);">Changes with failed checks</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudGrid Spacing="3">
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="1" Style="height: 100%;">
            <span class="eyebrow">POC user</span>
            <MudText Typo="Typo.h6" Class="mt-2 mb-2">Current actor</MudText>
            <MudSelect Value="UserContext.CurrentPersona" ValueChanged="SwitchUser" Label="Acting as" T="PocUserPersona" Class="mb-2">
                @foreach (var user in UserContext.AvailableUsers)
                {
                    <MudSelectItem Value="user.Persona">@user.DisplayName</MudSelectItem>
                }
            </MudSelect>
            <MudText Typo="Typo.caption" Style="color: var(--color-text-secondary); word-break: break-word;">
                User ID: @UserContext.CurrentUser.Id
            </MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="1" Style="height: 100%;">
            <span class="eyebrow">Workflow</span>
            <MudText Typo="Typo.h6" Class="mt-2 mb-2">Orchestration mode</MudText>
            <MudText Typo="Typo.body2" Style="color: var(--color-text-secondary);">
                @(_useElsa ? "Elsa adapter enabled" : "Domain-driven POC orchestrator enabled")
            </MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="1" Style="height: 100%;">
            <span class="eyebrow">Accepted content</span>
            <MudText Typo="Typo.h6" Class="mt-2 mb-2">Canonical store path</MudText>
            <MudText Typo="Typo.body2" Style="color: var(--color-text-secondary); word-break: break-word;">
                @_repositoryPath
            </MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="1">
            <div class="d-flex align-center justify-space-between gap-2 flex-wrap mb-3">
                <div>
                    <span class="eyebrow">Operations</span>
                    <MudText Typo="Typo.h6" Class="mt-2">Merge reconciliation</MudText>
                    <MudText Typo="Typo.body2" Style="color: var(--color-text-secondary); max-width: 760px;">
                        Unresolved merge intents are database-owned recovery markers for accepted-content writes that have not completed their version projection.
                        Accepted writes can be repaired here without exposing storage internals to normal users.
                    </MudText>
                </div>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Disabled="_loadingIntents" OnClick="LoadMergeIntentsAsync" StartIcon="@Icons.Material.Outlined.Refresh">
                    Refresh
                </MudButton>
            </div>

            @if (_loadingIntents)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_mergeIntents.Count == 0)
            {
                <MudAlert Severity="Severity.Success" Dense="true">No unresolved merge intents were found.</MudAlert>
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace(_lastRepairMessage))
                {
                    <MudAlert Severity="@_lastRepairSeverity" Dense="true" Class="mb-3">@_lastRepairMessage</MudAlert>
                }
                <MudTable Items="_mergeIntents" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" T="MergeIntent">
                    <HeaderContent>
                        <MudTh>Change</MudTh>
                        <MudTh>Detection</MudTh>
                        <MudTh>Recovery state</MudTh>
                        <MudTh>Requested</MudTh>
                        <MudTh>Accepted snapshot</MudTh>
                        <MudTh>Operator guidance</MudTh>
                        <MudTh>Action</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        @{ var guidance = GuidanceFor(context); }
                        <MudTd DataLabel="Change"><code>@context.ChangeId.Value</code></MudTd>
                        <MudTd DataLabel="Detection">
                            <MudText Typo="Typo.body2">@context.DetectionSlug</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary"><code>@context.DetectionId.Value</code></MudText>
                        </MudTd>
                        <MudTd DataLabel="Recovery state">
                            <MudChip T="string" Size="Size.Small" Color="@IntentStateColor(context.State)" Variant="Variant.Filled">@IntentStateLabel(context.State)</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Requested">
                            <MudText Typo="Typo.caption">@context.RequestedAt.ToString("yyyy-MM-dd HH:mm")</MudText>
                        </MudTd>
                        <MudTd DataLabel="Accepted snapshot">
                            @if (string.IsNullOrWhiteSpace(context.CommitSha))
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">No accepted snapshot recorded.</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption"><code>@ShortSha(context.CommitSha)</code></MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@(context.CommittedAt?.ToString("yyyy-MM-dd HH:mm") ?? "Accepted time unavailable")</MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="Operator guidance">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@guidance.Message</MudText>
                            <MudText Typo="Typo.caption"><strong>Recommended:</strong> @guidance.RecommendedAction</MudText>
                        </MudTd>
                        <MudTd DataLabel="Action">
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                                       Disabled="@(!guidance.CanRepair || _repairingChangeId == context.ChangeId)"
                                       OnClick="@(() => RepairIntentAsync(context.ChangeId))"
                                       StartIcon="@Icons.Material.Outlined.Healing">
                                Repair projection
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </MudItem>
    <MudItem xs="12">
        <MudAlert Severity="Severity.Info">
            Predefined workflow profiles are selected on changes. User-authored workflow definitions and low-level accepted-content storage operations are intentionally outside the POC UI.
        </MudAlert>
    </MudItem>
</MudGrid>

@code {
    private bool _useElsa;
    private string _repositoryPath = "accepted-content";
    private readonly List<MergeIntent> _mergeIntents = [];
    private bool _loadingIntents = true;
    private ChangeRequestId? _repairingChangeId;
    private string? _lastRepairMessage;
    private Severity _lastRepairSeverity = Severity.Info;

    private int _totalDetections;
    private int _openChanges;
    private int _acceptedVersions;
    private int _failedCheckChanges;

    private void SwitchUser(PocUserPersona persona)
    {
        UserContext.SwitchTo(persona);
    }

    protected override async Task OnInitializedAsync()
    {
        _useElsa = Configuration.GetValue<bool>("Workflow:UseElsa");
        _repositoryPath = Configuration.GetValue<string>("AcceptedContent:RepositoryPath") ?? "accepted-content";

        var detections = await DetectionService.ListAsync();
        _totalDetections = detections.Count;

        var allChanges = await ChangeService.ListAsync();
        _openChanges = allChanges.Count(c => c.Status is not ChangeStatus.Merged and not ChangeStatus.Closed);

        var recentVersions = await VersionService.ListRecentAsync(int.MaxValue);
        _acceptedVersions = recentVersions.Count;

        var failedChanges = await ChangeService.ListWithFailedChecksAsync();
        _failedCheckChanges = failedChanges.Count;

        await LoadMergeIntentsAsync();
    }

    private async Task LoadMergeIntentsAsync()
    {
        _loadingIntents = true;
        try
        {
            _mergeIntents.Clear();
            _mergeIntents.AddRange(await MergeReconciliation.ListUnresolvedAsync());
            if (_mergeIntents.Count == 0)
            {
                _lastRepairMessage = null;
            }
        }
        finally
        {
            _loadingIntents = false;
        }
    }

    private async Task RepairIntentAsync(ChangeRequestId changeId)
    {
        _repairingChangeId = changeId;
        try
        {
            var result = await MergeReconciliation.RepairCommittedAsync(changeId);
            _lastRepairSeverity = result.IsSuccess ? Severity.Success : Severity.Warning;
            _lastRepairMessage = result.Message;
            Snackbar.Add(result.Message, _lastRepairSeverity);
            await LoadMergeIntentsAsync();
        }
        catch (DomainException ex)
        {
            _lastRepairSeverity = Severity.Error;
            _lastRepairMessage = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _repairingChangeId = null;
        }
    }

    private static MergeIntentRecoveryGuidance GuidanceFor(MergeIntent intent)
        => MergeReconciliationService.BuildRecoveryGuidance(intent);

    private static string ShortSha(string commitSha)
        => commitSha.Length <= 12 ? commitSha : commitSha[..12];

    private static string IntentStateLabel(MergeIntentState state) => state switch
    {
        MergeIntentState.Committed => "Accepted write recorded",
        MergeIntentState.Pending => "Waiting for accepted write",
        _ => state.ToString(),
    };

    private static Color IntentStateColor(MergeIntentState state) => state switch
    {
        MergeIntentState.Committed => Color.Warning,
        MergeIntentState.Pending => Color.Info,
        _ => Color.Default,
    };
}
