@page "/checks"
@rendermode InteractiveServer
@using Workbench.Application.Services
@using Workbench.Domain.Changes
@using Workbench.Domain.Enums
@inject ChangeService ChangeService
@inject NavigationManager Nav

<PageTitle>Checks</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">Checks</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--color-text-secondary); max-width: 720px;">
    Validation outcomes across open and accepted changes. Checks remain attached to database-owned changes.
</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_rows.Count == 0)
{
    <MudAlert Severity="Severity.Info">No checks have been run yet. Open a change and run the validation pipeline.</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="1" Style="height: 100%;">
                <span class="eyebrow">Total checks</span>
                <MudText Typo="Typo.h4" Class="mt-1">@_rows.Count</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Across @_changeCount change(s)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="1" Style="height: 100%;">
                <span class="eyebrow">Blocking attention</span>
                <MudText Typo="Typo.h4" Class="mt-1">@BlockingAttentionCount</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Blocking checks not currently passed</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="1" Style="height: 100%;">
                <span class="eyebrow">Failed checks</span>
                <MudText Typo="Typo.h4" Class="mt-1">@FailedCount</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Latest failures stay linked to changes</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="1" Style="height: 100%;">
                <span class="eyebrow">Waiting/running</span>
                <MudText Typo="Typo.h4" Class="mt-1">@InFlightCount</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Queued or running validations</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudChipSet T="string" SelectionMode="SelectionMode.SingleSelection" SelectedValue="_checkFilter"
                SelectedValueChanged="OnCheckFilterChanged" Class="mb-3">
        <MudChip T="string" Value="@("all")" Variant="Variant.Outlined" SelectedColor="Color.Primary">All</MudChip>
        <MudChip T="string" Value="@("failed")" Variant="Variant.Outlined" SelectedColor="Color.Error">Failed</MudChip>
        <MudChip T="string" Value="@("passed")" Variant="Variant.Outlined" SelectedColor="Color.Success">Passed</MudChip>
        <MudChip T="string" Value="@("running")" Variant="Variant.Outlined" SelectedColor="Color.Info">Running / Queued</MudChip>
        <MudChip T="string" Value="@("blocking")" Variant="Variant.Outlined" SelectedColor="Color.Warning">Blocking attention</MudChip>
    </MudChipSet>

    @if (_filteredRows.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No checks match the current filter.</MudAlert>
    }
    else
    {
        <MudTable Items="_filteredRows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" T="CheckRow">
            <HeaderContent>
                <MudTh>Change</MudTh>
                <MudTh>Check</MudTh>
                <MudTh>Blocking</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Summary</MudTh>
                <MudTh>Completed</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Change">
                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Secondary"
                               OnClick="@(() => Nav.NavigateTo($"/changes/{context.Change.Id}"))"
                               Class="px-0" Style="font-weight: 600; text-transform: none;">
                        <code>@context.Change.Key</code>
                    </MudButton>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Change.Title</MudText>
                </MudTd>
                <MudTd DataLabel="Check"><code>@context.Check.Name</code></MudTd>
                <MudTd DataLabel="Blocking">@(context.Check.IsBlocking ? "Yes" : "No")</MudTd>
                <MudTd DataLabel="Status"><StatusChip CheckStatus="context.Check.Status" /></MudTd>
                <MudTd DataLabel="Summary">
                    <MudText Typo="Typo.body2">@context.Check.Summary</MudText>
                    @if (!string.IsNullOrWhiteSpace(context.Check.LogsExcerpt))
                    {
                        <MudExpansionPanels Class="mt-1">
                            <MudExpansionPanel Text="Logs" Dense="true" IsInitiallyExpanded="false">
                                <pre style="white-space: pre-wrap; font-size: 0.8rem;">@context.Check.LogsExcerpt</pre>
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                    }
                </MudTd>
                <MudTd DataLabel="Completed">
                    <MudText Typo="Typo.caption">@(context.Check.CompletedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</MudText>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

@code {
    private readonly List<CheckRow> _rows = [];
    private List<CheckRow> _filteredRows = [];
    private string _checkFilter = "all";
    private bool _loading = true;
    private int _changeCount;

    private int BlockingAttentionCount => _rows.Count(row => row.Check.IsBlocking && row.Check.Status is not CheckStatus.Passed);

    private int FailedCount => _rows.Count(row => row.Check.Status is CheckStatus.Failed);

    private int InFlightCount => _rows.Count(row => row.Check.Status is CheckStatus.Queued or CheckStatus.Running);

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        var changes = await ChangeService.ListAsync();
        _changeCount = changes.Count;
        _rows.AddRange(changes.SelectMany(change => change.Checks.Select(check => new CheckRow(change, check))));
        _rows.Sort((left, right) => Nullable.Compare(right.Check.CompletedAt, left.Check.CompletedAt));
        ApplyCheckFilter();
        _loading = false;
    }

    private void OnCheckFilterChanged(string filter)
    {
        _checkFilter = filter ?? "all";
        ApplyCheckFilter();
    }

    private void ApplyCheckFilter()
    {
        _filteredRows = _checkFilter switch
        {
            "failed" => _rows.Where(r => r.Check.Status is CheckStatus.Failed).ToList(),
            "passed" => _rows.Where(r => r.Check.Status is CheckStatus.Passed).ToList(),
            "running" => _rows.Where(r => r.Check.Status is CheckStatus.Queued or CheckStatus.Running).ToList(),
            "blocking" => _rows.Where(r => r.Check.IsBlocking && r.Check.Status is not CheckStatus.Passed).ToList(),
            _ => _rows.ToList(),
        };
    }

    private sealed record CheckRow(ChangeRequest Change, CheckRun Check);
}