@page "/checks"
@rendermode InteractiveServer
@using Workbench.Application.Services
@using Workbench.Domain.Changes
@using Workbench.Domain.Enums
@inject ChangeService ChangeService
@inject NavigationManager Nav

<PageTitle>Checks</PageTitle>

<DzPageHeader Title="Checks"
              Description="Validation outcomes across open and accepted changes. Checks remain attached to database-owned changes." />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_rows.Count == 0)
{
    <DzEmptyState Title="No checks have been run yet."
                  Description="Open a change and run the validation pipeline."
                  Icon="@Icons.Material.Outlined.PlaylistAddCheck" />
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <DzPanel Class="dz-metric-tile">
                <span class="eyebrow">Total checks</span>
                <MudText Typo="Typo.h4" Class="dz-metric-tile__value">@_rows.Count</MudText>
                <MudText Typo="Typo.caption" Class="dz-metric-tile__label">Across @_changeCount change(s)</MudText>
            </DzPanel>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <DzPanel Class="dz-metric-tile">
                <span class="eyebrow">Blocking attention</span>
                <MudText Typo="Typo.h4" Class="dz-metric-tile__value">@BlockingAttentionCount</MudText>
                <MudText Typo="Typo.caption" Class="dz-metric-tile__label">Blocking checks not currently passed</MudText>
            </DzPanel>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <DzPanel Class="dz-metric-tile">
                <span class="eyebrow">Failed checks</span>
                <MudText Typo="Typo.h4" Class="dz-metric-tile__value">@FailedCount</MudText>
                <MudText Typo="Typo.caption" Class="dz-metric-tile__label">Latest failures stay linked to changes</MudText>
            </DzPanel>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <DzPanel Class="dz-metric-tile">
                <span class="eyebrow">Waiting/running</span>
                <MudText Typo="Typo.h4" Class="dz-metric-tile__value">@InFlightCount</MudText>
                <MudText Typo="Typo.caption" Class="dz-metric-tile__label">Queued or running validations</MudText>
            </DzPanel>
        </MudItem>
    </MudGrid>

    <DzToolbar>
        <div class="dz-filter-row">
            <DzFilterChip Value="all" Selected="@(_checkFilter == "all")" OnClick="@(() => OnCheckFilterChanged("all"))">
                All
            </DzFilterChip>
            <DzFilterChip Value="failed" Selected="@(_checkFilter == "failed")" OnClick="@(() => OnCheckFilterChanged("failed"))">
                Failed
            </DzFilterChip>
            <DzFilterChip Value="passed" Selected="@(_checkFilter == "passed")" OnClick="@(() => OnCheckFilterChanged("passed"))">
                Passed
            </DzFilterChip>
            <DzFilterChip Value="running" Selected="@(_checkFilter == "running")" OnClick="@(() => OnCheckFilterChanged("running"))">
                Running / Queued
            </DzFilterChip>
            <DzFilterChip Value="blocking" Selected="@(_checkFilter == "blocking")" OnClick="@(() => OnCheckFilterChanged("blocking"))">
                Blocking attention
            </DzFilterChip>
        </div>
    </DzToolbar>

    @if (_filteredRows.Count == 0)
    {
        <DzEmptyState Title="No checks match the current filter."
                      Description="Adjust the filter to review other validation outcomes."
                      Icon="@Icons.Material.Outlined.FilterAltOff" />
    }
    else
    {
        <div class="dz-table-shell">
            <MudTable Items="_filteredRows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" T="CheckRow" Elevation="0">
                <HeaderContent>
                    <MudTh>Change</MudTh>
                    <MudTh>Check</MudTh>
                    <MudTh>Blocking</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Summary</MudTh>
                    <MudTh>Completed</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Change">
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Secondary"
                                   OnClick="@(() => Nav.NavigateTo($"/changes/{context.Change.Id}"))"
                                   Class="dz-link-button">
                            <code>@context.Change.Key</code>
                        </MudButton>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Change.Title</MudText>
                    </MudTd>
                    <MudTd DataLabel="Check"><code>@context.Check.Name</code></MudTd>
                    <MudTd DataLabel="Blocking">@(context.Check.IsBlocking ? "Yes" : "No")</MudTd>
                    <MudTd DataLabel="Status"><StatusChip CheckStatus="context.Check.Status" /></MudTd>
                    <MudTd DataLabel="Summary">
                        <MudText Typo="Typo.body2">@context.Check.Summary</MudText>
                        @if (!string.IsNullOrWhiteSpace(context.Check.LogsExcerpt))
                        {
                            <MudExpansionPanels Class="mt-1">
                                <MudExpansionPanel Text="Logs" Dense="true" IsInitiallyExpanded="false">
                                    <DzCodeBlock Content="@context.Check.LogsExcerpt" Light="true" Compact="true" MaxHeightPx="320" />
                                </MudExpansionPanel>
                            </MudExpansionPanels>
                        }
                    </MudTd>
                    <MudTd DataLabel="Completed">
                        <MudText Typo="Typo.caption">@(context.Check.CompletedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</MudText>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </div>
    }
}

@code {
    private readonly List<CheckRow> _rows = [];
    private List<CheckRow> _filteredRows = [];
    private string _checkFilter = "all";
    private bool _loading = true;
    private int _changeCount;

    private int BlockingAttentionCount => _rows.Count(row => row.Check.IsBlocking && row.Check.Status is not CheckStatus.Passed);

    private int FailedCount => _rows.Count(row => row.Check.Status is CheckStatus.Failed);

    private int InFlightCount => _rows.Count(row => row.Check.Status is CheckStatus.Queued or CheckStatus.Running);

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        var changes = await ChangeService.ListAsync();
        _changeCount = changes.Count;
        _rows.AddRange(changes.SelectMany(change => change.Checks.Select(check => new CheckRow(change, check))));
        _rows.Sort((left, right) => Nullable.Compare(right.Check.CompletedAt, left.Check.CompletedAt));
        ApplyCheckFilter();
        _loading = false;
    }

    private void OnCheckFilterChanged(string filter)
    {
        _checkFilter = filter ?? "all";
        ApplyCheckFilter();
    }

    private void ApplyCheckFilter()
    {
        _filteredRows = _checkFilter switch
        {
            "failed" => _rows.Where(r => r.Check.Status is CheckStatus.Failed).ToList(),
            "passed" => _rows.Where(r => r.Check.Status is CheckStatus.Passed).ToList(),
            "running" => _rows.Where(r => r.Check.Status is CheckStatus.Queued or CheckStatus.Running).ToList(),
            "blocking" => _rows.Where(r => r.Check.IsBlocking && r.Check.Status is not CheckStatus.Passed).ToList(),
            _ => _rows.ToList(),
        };
    }

    private sealed record CheckRow(ChangeRequest Change, CheckRun Check);
}
