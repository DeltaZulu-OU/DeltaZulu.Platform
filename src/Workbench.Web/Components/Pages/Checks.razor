@page "/checks"
@rendermode InteractiveServer
@using Workbench.Application.Services
@using Workbench.Domain.Changes
@inject ChangeService ChangeService
@inject NavigationManager Nav

<PageTitle>Checks</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">Checks</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--color-text-secondary); max-width: 720px;">
    Validation outcomes across open and accepted changes. Checks remain attached to database-owned changes.
</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_rows.Count == 0)
{
    <MudAlert Severity="Severity.Info">No checks have been run yet. Open a change and run the validation pipeline.</MudAlert>
}
else
{
    <MudTable Items="_rows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" T="CheckRow">
        <HeaderContent>
            <MudTh>Change</MudTh>
            <MudTh>Check</MudTh>
            <MudTh>Blocking</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Summary</MudTh>
            <MudTh>Completed</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Change">
                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Secondary"
                           OnClick="@(() => Nav.NavigateTo($"/changes/{context.Change.Id}"))"
                           Class="px-0" Style="font-weight: 600; text-transform: none;">
                    <code>@context.Change.Key</code>
                </MudButton>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Change.Title</MudText>
            </MudTd>
            <MudTd DataLabel="Check"><code>@context.Check.Name</code></MudTd>
            <MudTd DataLabel="Blocking">@(context.Check.IsBlocking ? "Yes" : "No")</MudTd>
            <MudTd DataLabel="Status"><StatusChip CheckStatus="context.Check.Status" /></MudTd>
            <MudTd DataLabel="Summary">
                <MudText Typo="Typo.body2">@context.Check.Summary</MudText>
                @if (!string.IsNullOrWhiteSpace(context.Check.LogsExcerpt))
                {
                    <MudExpansionPanels Class="mt-1">
                        <MudExpansionPanel Text="Logs" Dense="true" IsInitiallyExpanded="false">
                            <pre style="white-space: pre-wrap; font-size: 0.8rem;">@context.Check.LogsExcerpt</pre>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                }
            </MudTd>
            <MudTd DataLabel="Completed">
                <MudText Typo="Typo.caption">@(context.Check.CompletedAt?.ToString("yyyy-MM-dd HH:mm") ?? "—")</MudText>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private readonly List<CheckRow> _rows = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        var changes = await ChangeService.ListAsync();
        _rows.AddRange(changes.SelectMany(change => change.Checks.Select(check => new CheckRow(change, check))));
        _rows.Sort((left, right) => Nullable.Compare(right.Check.CompletedAt, left.Check.CompletedAt));
        _loading = false;
    }

    private sealed record CheckRow(ChangeRequest Change, CheckRun Check);
}
