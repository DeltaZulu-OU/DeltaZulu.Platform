@page "/detections/{Id}"
@rendermode InteractiveServer
@using Workbench.Application.Services
@using Workbench.Application.Abstractions
@using Workbench.Domain.Detections
@using Workbench.Domain.Changes
@using Workbench.Domain.Identifiers
@using Workbench.Domain.Issues
@using Workbench.Domain.Common
@using Workbench.Domain.Enums
@inject DetectionContentService DetectionService
@inject IssueService IssueService
@inject ChangeService ChangeService
@inject VersionService VersionService
@inject IAcceptedContentStore ContentStore
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject PocUserContext UserContext

<PageTitle>Detection — @(_detection?.Title ?? "Loading")</PageTitle>

@if (_detection is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2" />

    <MudGrid Spacing="3">
        <MudItem xs="12" md="8">
            <span class="eyebrow">Detection</span>
            <MudText Typo="Typo.h5" Class="mt-1" Style="font-weight: 700;">@_detection.Title</MudText>
            <MudText Typo="Typo.body2" Style="color: var(--color-text-muted);" Class="mb-3">
                <code>@_detection.Slug</code>
            </MudText>
            <MudText Typo="Typo.body2" Style="color: var(--color-text-secondary);" Class="mb-4">@_detection.Summary</MudText>
            <div class="d-flex gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Outlined.Add" OnClick="OpenChangeDialog">
                    Open change
                </MudButton>
                @if (_detection.Lifecycle == DetectionLifecycle.Accepted)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                               StartIcon="@Icons.Material.Outlined.Archive" OnClick="DeprecateDetection">
                        Deprecate
                    </MudButton>
                }
            </div>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="1">
                <span class="eyebrow" style="font-size: 0.625rem;">Details</span>
                <div class="mt-3">
                    <MudText Typo="Typo.caption" Style="color: var(--color-text-muted);">Lifecycle</MudText>
                    <div class="mt-1"><StatusChip Lifecycle="_detection.Lifecycle" /></div>
                </div>
                <MudDivider Class="my-3" Style="border-color: rgba(19,31,42,0.06);" />
                <div>
                    <MudText Typo="Typo.caption" Style="color: var(--color-text-muted);">Latest version</MudText>
                    @if (_latestVersion is not null)
                    {
                        <div class="d-flex align-center gap-2 mt-1">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success">@_latestVersion.DisplayVersion</MudChip>
                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Secondary"
                                       OnClick="@(() => Nav.NavigateTo($"/versions/{_latestVersion.Id}"))"
                                       Class="px-0" Style="font-weight: 600; text-transform: none;">
                                Compare
                            </MudButton>
                        </div>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="mt-1" Style="color: var(--color-text-secondary);">None</MudText>
                    }
                </div>
                    <MudDivider Class="my-3" Style="border-color: var(--color-divider);" />
                <div>
                    <MudText Typo="Typo.caption" Style="color: var(--color-text-muted);">Active changes</MudText>
                    <MudText Typo="Typo.body2" Class="mt-1">@_activeChangeCount</MudText>
                </div>
                    <MudDivider Class="my-3" Style="border-color: var(--color-divider);" />
                <div>
                    <MudText Typo="Typo.caption" Style="color: var(--color-text-muted);">Updated</MudText>
                    <MudText Typo="Typo.body2" Class="mt-1" Style="font-family: var(--font-family-mono); font-size: 0.8125rem;">
                        @_detection.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss")
                    </MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" Class="mt-4">
        <MudTabPanel Text="Versions" BadgeData="@_versions.Count" BadgeColor="Color.Secondary">
            @if (_versions.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="ma-4">No accepted versions yet. Accept a change to create the first.</MudAlert>
            }
            else
            {
                <MudTable Items="_versions" Dense="true" Class="ma-3" T="DetectionVersion">
                    <HeaderContent>
                        <MudTh>Version</MudTh>
                        <MudTh>Summary</MudTh>
                        <MudTh>Profile</MudTh>
                        <MudTh>Accepted</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Version"><MudText Typo="Typo.body2"><strong>@context.DisplayVersion</strong></MudText></MudTd>
                        <MudTd DataLabel="Summary">@context.ChangeSummary</MudTd>
                        <MudTd DataLabel="Profile"><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.WorkflowProfile</MudChip></MudTd>
                        <MudTd DataLabel="Accepted"><MudText Typo="Typo.caption">@context.AcceptedAt.ToString("yyyy-MM-dd HH:mm")</MudText></MudTd>
                        <MudTd DataLabel="Actions">
                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Secondary"
                            OnClick="@(() => Nav.NavigateTo($"/versions/{context.Id}"))">
                                Compare / restore
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="Work history" BadgeData="@_changes.Count" BadgeColor="Color.Secondary">
            @if (_changes.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Class="ma-3">No changes linked to this detection.</MudAlert>
            }
            else
            {
                <MudTable Items="_changes" Dense="true" Hover="true" Class="ma-3"
                          OnRowClick="@(args => Nav.NavigateTo($"/changes/{args.Item.Id}"))"
                          T="ChangeRequest" RowClass="cursor-pointer">
                    <HeaderContent>
                        <MudTh>Key</MudTh>
                        <MudTh>Title</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Updated</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Key"><code>@context.Key</code></MudTd>
                        <MudTd DataLabel="Title">@context.Title</MudTd>
                        <MudTd DataLabel="Status"><StatusChip ChangeStatus="context.Status" /></MudTd>
                        <MudTd DataLabel="Updated"><MudText Typo="Typo.caption">@context.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</MudText></MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="Related issues" BadgeData="@_relatedIssues.Count" BadgeColor="Color.Info">
            @if (_relatedIssues.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Class="ma-3">No issues linked to this detection.</MudAlert>
            }
            else
            {
                <MudTable Items="_relatedIssues" Dense="true" Hover="true" Class="ma-3"
                          OnRowClick="@(args => Nav.NavigateTo($"/issues/{args.Item.Id}"))"
                          T="Issue" RowClass="cursor-pointer">
                    <HeaderContent>
                        <MudTh>Key</MudTh>
                        <MudTh>Title</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Updated</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Key"><code>@context.Key</code></MudTd>
                        <MudTd DataLabel="Title">@context.Title</MudTd>
                        <MudTd DataLabel="Type"><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.Type</MudChip></MudTd>
                        <MudTd DataLabel="Status"><StatusChip IssueStatus="context.Status" /></MudTd>
                        <MudTd DataLabel="Updated"><MudText Typo="Typo.caption">@context.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</MudText></MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="Files">
            @if (_acceptedFiles.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Class="ma-3">No accepted content yet.</MudAlert>
            }
            else
            {
                <MudList T="string" Dense="true" Class="ma-3">
                    @foreach (var file in _acceptedFiles)
                    {
                        <MudListItem T="string" Icon="@Icons.Material.Filled.InsertDriveFile">
                            <code>@file.RepositoryPath</code>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudTabPanel>
    </MudTabs>
}

@code {
    [Parameter] public string Id { get; set; } = null!;

    private Detection? _detection;
    private DetectionVersion? _latestVersion;
    private int _activeChangeCount;
    private List<DetectionVersion> _versions = [];
    private List<ChangeRequest> _changes = [];
    private List<ContentFile> _acceptedFiles = [];
    private List<Issue> _relatedIssues = [];
    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnParametersSetAsync()
    {
        if (!Guid.TryParse(Id, out var guid)) return;
        var detId = new DetectionId(guid);

        _detection = await DetectionService.GetByIdAsync(detId);
        if (_detection is null) return;

        _breadcrumbs =
        [
            new("Detections", "/detections"),
            new(_detection.Slug, null, disabled: true),
        ];

        _versions = (await VersionService.ListByDetectionAsync(detId)).ToList();
        _latestVersion = _versions.FirstOrDefault();
        _changes = (await ChangeService.ListByDetectionAsync(detId)).ToList();
        _activeChangeCount = _changes.Count(c => c.Status is not Domain.Enums.ChangeStatus.Merged and not Domain.Enums.ChangeStatus.Closed);

        var prefix = Application.ContentPipeline.CanonicalPathResolver.DetectionPrefix(_detection.Slug);
        _acceptedFiles = (await ContentStore.ListFilesAsync(prefix)).ToList();

        var allIssues = await IssueService.ListAsync();
        _relatedIssues = allIssues.Where(i => i.LinkedDetectionId == detId).ToList();
    }

    private async Task DeprecateDetection()
    {
        if (_detection is null) return;
        try
        {
            await DetectionService.DeprecateAsync(_detection.Id);
            Snackbar.Add("Detection deprecated.", Severity.Success);
            _detection = await DetectionService.GetByIdAsync(_detection.Id);
        }
        catch (DomainException ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task OpenChangeDialog()
    {
        if (_detection is null) return;
        var parameters = new DialogParameters<OpenChangeDialog>
        {
            { x => x.DetectionId, _detection.Id },
            { x => x.AuthorId, UserContext.CurrentUser.Id },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<OpenChangeDialog>("Open Change", parameters, options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is ChangeRequestId changeId)
        {
            Nav.NavigateTo($"/changes/{changeId}");
        }
    }
}