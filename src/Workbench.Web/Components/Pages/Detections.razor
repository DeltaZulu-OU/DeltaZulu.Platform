@page "/detections"
@rendermode InteractiveServer
@using Workbench.Application.Services
@using Workbench.Domain.Detections
@using Workbench.Domain.Enums
@inject DetectionContentService DetectionService
@inject IDialogService DialogService
@inject NavigationManager Nav

<PageTitle>Detections</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <div>
        <MudText Typo="Typo.h5" Style="font-weight: 700;">Detections</MudText>
        <MudText Typo="Typo.body2" Style="color: var(--color-text-secondary);">
            Detection content packages versioned in Git.
        </MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Outlined.Add"
               OnClick="OpenConceiveDialog">
        Conceive detection
    </MudButton>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Secondary" />
}
else if (_detections.Count == 0)
{
    <MudPaper Class="pa-6" Elevation="1" Style="text-align: center;">
        <MudText Typo="Typo.body1" Style="color: var(--color-text-muted);">No detections yet.</MudText>
        <MudText Typo="Typo.body2" Style="color: var(--color-text-muted);" Class="mt-1">
            Conceive one to begin building detection content.
        </MudText>
    </MudPaper>
}
else
{
    <MudTable Items="_detections" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="1"
              OnRowClick="@(args => Nav.NavigateTo($"/detections/{args.Item.Id}"))"
              T="Detection" RowClass="cursor-pointer">
        <HeaderContent>
            <MudTh>Slug</MudTh>
            <MudTh>Title</MudTh>
            <MudTh>Lifecycle</MudTh>
            <MudTh>Updated</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Slug"><code>@context.Slug</code></MudTd>
            <MudTd DataLabel="Title">@context.Title</MudTd>
            <MudTd DataLabel="Lifecycle"><StatusChip Lifecycle="context.Lifecycle" /></MudTd>
            <MudTd DataLabel="Updated">
                <MudText Typo="Typo.caption" Style="color: var(--color-text-muted);">@context.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</MudText>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<Detection> _detections = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _detections = (await DetectionService.ListAsync()).ToList();
        _loading = false;
    }

    private async Task OpenConceiveDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ConceiveDetectionDialog>("Conceive detection", options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled) await LoadAsync();
    }
}
