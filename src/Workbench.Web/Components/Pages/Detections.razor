@page "/detections"
@rendermode InteractiveServer
@using Workbench.Application.Services
@using Workbench.Domain.Detections
@using Workbench.Domain.Enums
@using Workbench.Domain.Identifiers
@inject DetectionContentService DetectionService
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject PocUserContext UserContext

<PageTitle>Detections</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <div>
        <MudText Typo="Typo.h5" Style="font-weight: 700;">Detections</MudText>
        <MudText Typo="Typo.body2" Style="color: var(--color-text-secondary);">
            Detection content packages versioned in Git.
        </MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Outlined.Add"
               OnClick="OpenConceiveDialog">
        Conceive detection
    </MudButton>
</div>

<div class="d-flex align-center gap-3 mb-3 flex-wrap">
    <MudTextField Value="_searchText" ValueChanged="OnSearchChanged" Placeholder="Search by slug or title"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Outlined.Search"
                  Immediate="true" DebounceInterval="200" Class="flex-grow-1" Style="max-width: 360px;"
                  T="string" />
    <MudChipSet T="string" SelectionMode="SelectionMode.SingleSelection" SelectedValue="_lifecycleFilter"
                SelectedValueChanged="OnLifecycleFilterChanged">
        <MudChip T="string" Value="@("all")" Variant="Variant.Outlined" SelectedColor="Color.Primary">All (@_detections.Count)</MudChip>
        <MudChip T="string" Value="@("Conceived")" Variant="Variant.Outlined" SelectedColor="Color.Primary">Conceived (@_detections.Count(d => d.Lifecycle == DetectionLifecycle.Conceived))</MudChip>
        <MudChip T="string" Value="@("Accepted")" Variant="Variant.Outlined" SelectedColor="Color.Primary">Accepted (@_detections.Count(d => d.Lifecycle == DetectionLifecycle.Accepted))</MudChip>
        <MudChip T="string" Value="@("Deprecated")" Variant="Variant.Outlined" SelectedColor="Color.Primary">Deprecated (@_detections.Count(d => d.Lifecycle == DetectionLifecycle.Deprecated))</MudChip>
    </MudChipSet>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Secondary" />
}
else if (_filteredDetections.Count == 0)
{
    <MudPaper Class="pa-6" Elevation="1" Style="text-align: center;">
        <MudText Typo="Typo.body1" Style="color: var(--color-text-muted);">No detections match the current filter.</MudText>
        <MudText Typo="Typo.body2" Style="color: var(--color-text-muted);" Class="mt-1">
            Conceive one to begin building detection content.
        </MudText>
    </MudPaper>
}
else
{
    <MudTable Items="_filteredDetections" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="1"
              OnRowClick="@(args => Nav.NavigateTo($"/detections/{args.Item.Id}"))"
              T="Detection" RowClass="cursor-pointer">
        <HeaderContent>
            <MudTh>Slug</MudTh>
            <MudTh>Title</MudTh>
            <MudTh>Lifecycle</MudTh>
            <MudTh>Updated</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Slug"><code>@context.Slug</code></MudTd>
            <MudTd DataLabel="Title">@context.Title</MudTd>
            <MudTd DataLabel="Lifecycle"><StatusChip Lifecycle="context.Lifecycle" /></MudTd>
            <MudTd DataLabel="Updated">
                <MudText Typo="Typo.caption" Style="color: var(--color-text-muted);">@context.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</MudText>
            </MudTd>
            <MudTd DataLabel="Actions" @onclick:stopPropagation="true">
                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Outlined.Add"
                           OnClick="@(() => OpenChangeForDetection(context.Id))">
                    Open change
                </MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<Detection> _detections = [];
    private List<Detection> _filteredDetections = [];
    private string _searchText = "";
    private string _lifecycleFilter = "all";
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _detections = (await DetectionService.ListAsync()).ToList();
        ApplyFilter();
        _loading = false;
    }

    private void OnSearchChanged(string text)
    {
        _searchText = text ?? "";
        ApplyFilter();
    }

    private void OnLifecycleFilterChanged(string filter)
    {
        _lifecycleFilter = filter ?? "all";
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        var query = _searchText?.Trim() ?? "";
        _filteredDetections = _detections
            .Where(d => _lifecycleFilter == "all" || d.Lifecycle.ToString() == _lifecycleFilter)
            .Where(d => string.IsNullOrEmpty(query)
                || d.Slug.Contains(query, StringComparison.OrdinalIgnoreCase)
                || d.Title.Contains(query, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private async Task OpenConceiveDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ConceiveDetectionDialog>("Conceive detection", options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled) await LoadAsync();
    }

    private async Task OpenChangeForDetection(DetectionId detectionId)
    {
        var parameters = new DialogParameters<OpenChangeDialog>
        {
            { x => x.DetectionId, detectionId },
            { x => x.AuthorId, UserContext.CurrentUser.Id },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<OpenChangeDialog>("Open Change", parameters, options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is ChangeRequestId changeId)
        {
            Nav.NavigateTo($"/changes/{changeId}");
        }
    }
}