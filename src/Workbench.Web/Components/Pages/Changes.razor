@page "/changes"
@rendermode InteractiveServer
@using Workbench.Application.Services
@using Workbench.Domain.Changes
@inject ChangeService ChangeService
@inject NavigationManager Nav

<PageTitle>Changes</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Changes</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_changes.Count == 0)
{
    <MudAlert Severity="Severity.Info">No changes yet. Open one from a detection detail page.</MudAlert>
}
else
{
    <MudTable Items="_changes" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm"
              OnRowClick="@(args => Nav.NavigateTo($"/changes/{args.Item.Id}"))"
              T="ChangeRequest" RowClass="cursor-pointer">
        <HeaderContent>
            <MudTh>Key</MudTh>
            <MudTh>Title</MudTh>
            <MudTh>Profile</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Files</MudTh>
            <MudTh>Checks</MudTh>
            <MudTh>Stale</MudTh>
            <MudTh>Updated</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Key"><code>@context.Key</code></MudTd>
            <MudTd DataLabel="Title">@context.Title</MudTd>
            <MudTd DataLabel="Profile"><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.WorkflowProfileId</MudChip></MudTd>
            <MudTd DataLabel="Status"><StatusChip ChangeStatus="context.Status" /></MudTd>
            <MudTd DataLabel="Files">@context.DraftFiles.Count</MudTd>
            <MudTd DataLabel="Checks">@context.Checks.Count</MudTd>
            <MudTd DataLabel="Stale">
                @if (context.IsStale)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" />
                }
            </MudTd>
            <MudTd DataLabel="Updated"><MudText Typo="Typo.caption">@context.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</MudText></MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<ChangeRequest> _changes = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _changes = (await ChangeService.ListAsync()).ToList();
        _loading = false;
    }
}
