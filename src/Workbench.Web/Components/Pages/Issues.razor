@page "/issues"
@rendermode InteractiveServer
@using Workbench.Application.Services
@using Workbench.Domain.Issues
@using Workbench.Domain.Enums
@inject IssueService IssueService
@inject IDialogService DialogService

<PageTitle>Issues &amp; Cases</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Issues &amp; Cases</MudText>

<MudButtonGroup Variant="Variant.Filled" Class="mb-4">
    <MudButton Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="@(() => OpenCreateDialog(false))">New issue</MudButton>
    <MudButton Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Cases"
               OnClick="@(() => OpenCreateDialog(true))">From external case</MudButton>
</MudButtonGroup>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_issues.Count == 0)
{
    <MudAlert Severity="Severity.Info">No issues yet. Create one to begin tracking detection work.</MudAlert>
}
else
{
    <MudTable Items="_issues" Dense="true" Hover="true" T="Issue">
        <HeaderContent>
            <MudTh>Key</MudTh>
            <MudTh>Title</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Priority</MudTh>
            <MudTh>External Case</MudTh>
            <MudTh>Updated</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Key"><code>@context.Key</code></MudTd>
            <MudTd DataLabel="Title">@context.Title</MudTd>
            <MudTd DataLabel="Type"><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.Type</MudChip></MudTd>
            <MudTd DataLabel="Status"><StatusChip IssueStatus="context.Status" /></MudTd>
            <MudTd DataLabel="Priority">@context.Priority</MudTd>
            <MudTd DataLabel="External Case">
                @if (context.ExternalCase is not null)
                {
                    @if (context.ExternalCase.Url is not null)
                    {
                        <MudLink Href="@context.ExternalCase.Url" Target="_blank">
                            @context.ExternalCase.System: @context.ExternalCase.ExternalId
                        </MudLink>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">@context.ExternalCase.System: @context.ExternalCase.ExternalId</MudText>
                    }
                }
                else
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">—</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Updated"><MudText Typo="Typo.caption">@context.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</MudText></MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<Issue> _issues = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _issues = (await IssueService.ListAsync()).ToList();
        _loading = false;
    }

    private async Task OpenCreateDialog(bool withExternalCase)
    {
        var parameters = new DialogParameters<CreateIssueDialog> { { x => x.WithExternalCase, withExternalCase } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateIssueDialog>(
            withExternalCase ? "From external case" : "New issue", parameters, options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled) await LoadAsync();
    }
}
