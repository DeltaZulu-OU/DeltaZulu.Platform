@page "/"
@rendermode InteractiveServer
@using Workbench.Application.Services
@using Workbench.Domain.Changes
@using Workbench.Domain.Detections
@using Workbench.Domain.Enums
@using Workbench.Web.Services
@inject ChangeService ChangeService
@inject DetectionContentService DetectionService
@inject VersionService VersionService
@inject PocUserContext UserContext
@inject NavigationManager Nav

<PageTitle>Detection Content Workbench</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1" Style="font-weight: 700;">Detection Content Workbench</MudText>
<MudText Typo="Typo.body1" Style="color: var(--color-text-secondary); max-width: 640px;" Class="mb-6">
    Edit detection content, prove it is safe, accept it into history.
</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
    return;
}

<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="6" md="3">
        <MudPaper Class="pa-4 text-center" Elevation="1">
            <MudIcon Icon="@Icons.Material.Outlined.Shield" Size="Size.Large" Style="color: var(--brand-slate);" />
            <MudText Typo="Typo.h4" Class="mt-2" Style="font-weight: 700;">@_totalDetections</MudText>
            <MudText Typo="Typo.caption" Style="color: var(--color-text-secondary);">Detections</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" md="3">
        <MudPaper Class="pa-4 text-center" Elevation="1">
            <MudIcon Icon="@Icons.Material.Outlined.EditNote" Size="Size.Large" Style="color: var(--color-info);" />
            <MudText Typo="Typo.h4" Class="mt-2" Style="font-weight: 700;">@_openChanges</MudText>
            <MudText Typo="Typo.caption" Style="color: var(--color-text-secondary);">Open changes</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" md="3">
        <MudPaper Class="pa-4 text-center" Elevation="1">
            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Large" Style="color: var(--color-success);" />
            <MudText Typo="Typo.h4" Class="mt-2" Style="font-weight: 700;">@_acceptedVersions</MudText>
            <MudText Typo="Typo.caption" Style="color: var(--color-text-secondary);">Accepted versions</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" md="3">
        <MudPaper Class="pa-4 text-center" Elevation="1">
            <MudIcon Icon="@Icons.Material.Outlined.Error" Size="Size.Large" Style="color: var(--color-error);" />
            <MudText Typo="Typo.h4" Class="mt-2" Style="font-weight: 700;">@_failedCheckChanges</MudText>
            <MudText Typo="Typo.caption" Style="color: var(--color-text-secondary);">Changes with failed checks</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>


<MudGrid Spacing="3">
    @* ── Needs my action ── *@
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-5" Elevation="1" Style="height: 100%;">
            <span class="eyebrow">Needs my action</span>
            @if (_myChanges.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mt-3" Style="color: var(--color-text-secondary);">
                    No changes need your attention.
                </MudText>
            }
            else
            {
                <MudList T="ChangeRequest" Dense="true" Class="mt-2">
                    @foreach (var change in _myChanges)
                    {
                        <MudListItem T="ChangeRequest" OnClick="@(() => Nav.NavigateTo($"/changes/{change.Id}"))">
                            <div class="d-flex align-center gap-2 flex-wrap">
                                <code style="font-size: 0.85em;">@change.Key</code>
                                <MudText Typo="Typo.body2">@change.Title</MudText>
                                <StatusChip ChangeStatus="change.Status" />
                                @if (change.IsStale)
                                {
                                    <MudChip T="string" Size="Size.Small" Style="background: var(--color-warning-bg); color: var(--color-warning);">Stale</MudChip>
                                }
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudPaper>
    </MudItem>

    @* ── Pending review ── *@
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-5" Elevation="1" Style="height: 100%;">
            <span class="eyebrow">Pending review</span>
            @if (_awaitingReview.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mt-3" Style="color: var(--color-text-secondary);">
                    No reviews waiting for your decision.
                </MudText>
            }
            else
            {
                <MudList T="ChangeRequest" Dense="true" Class="mt-2">
                    @foreach (var change in _awaitingReview)
                    {
                        <MudListItem T="ChangeRequest" OnClick="@(() => Nav.NavigateTo($"/changes/{change.Id}"))">
                            <div class="d-flex align-center gap-2 flex-wrap">
                                <code style="font-size: 0.85em;">@change.Key</code>
                                <MudText Typo="Typo.body2">@change.Title</MudText>
                                <StatusChip ChangeStatus="change.Status" />
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudPaper>
    </MudItem>

    @* ── Failed checks ── *@
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-5" Elevation="1" Style="height: 100%;">
            <span class="eyebrow">Failed checks</span>
            @if (_failedChecks.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mt-3" Style="color: var(--color-text-secondary);">
                    No check failures across open changes.
                </MudText>
            }
            else
            {
                <MudList T="ChangeRequest" Dense="true" Class="mt-2">
                    @foreach (var change in _failedChecks)
                    {
                        var failCount = change.Checks.Count(c => c.IsBlocking && c.Status == CheckStatus.Failed);
                        <MudListItem T="ChangeRequest" OnClick="@(() => Nav.NavigateTo($"/changes/{change.Id}"))">
                            <div class="d-flex align-center gap-2 flex-wrap">
                                <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Size="Size.Small"
                                         Style="color: var(--color-error);" />
                                <code style="font-size: 0.85em;">@change.Key</code>
                                <MudText Typo="Typo.body2">@change.Title</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
                                    @failCount failure(s)
                                </MudChip>
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudPaper>
    </MudItem>

    @* ── Recently accepted ── *@
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-5" Elevation="1" Style="height: 100%;">
            <span class="eyebrow">Recently accepted</span>
            @if (_recentVersions.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mt-3" Style="color: var(--color-text-secondary);">
                    No versions accepted yet.
                </MudText>
            }
            else
            {
                <MudList T="DetectionVersion" Dense="true" Class="mt-2">
                    @foreach (var version in _recentVersions)
                    {
                        <MudListItem T="DetectionVersion" OnClick="@(() => Nav.NavigateTo($"/history/{version.Id}"))">
                            <div class="d-flex align-center gap-2 flex-wrap">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success">
                                    @version.DisplayVersion
                                </MudChip>
                                <MudText Typo="Typo.body2">@version.Title</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @version.AcceptedAt.ToString("yyyy-MM-dd HH:mm")
                                </MudText>
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private IReadOnlyList<ChangeRequest> _myChanges = [];
    private IReadOnlyList<ChangeRequest> _awaitingReview = [];
    private IReadOnlyList<ChangeRequest> _failedChecks = [];
    private IReadOnlyList<DetectionVersion> _recentVersions = [];
    private int _totalDetections;
    private int _openChanges;
    private int _acceptedVersions;
    private int _failedCheckChanges;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        var userId = UserContext.CurrentUser.Id;

        var myChangesTask = ChangeService.ListMyActiveChangesAsync(userId);
        var awaitingReviewTask = ChangeService.ListAwaitingMyReviewAsync(userId);
        var failedChecksTask = ChangeService.ListWithFailedChecksAsync();
        var recentVersionsTask = VersionService.ListRecentAsync(5);
        var detectionsTask = DetectionService.ListAsync();
        var allChangesTask = ChangeService.ListAsync();
        var allVersionsTask = VersionService.ListRecentAsync(int.MaxValue);

        await Task.WhenAll(myChangesTask, awaitingReviewTask, failedChecksTask, recentVersionsTask,
                   detectionsTask, allChangesTask, allVersionsTask);

        _myChanges = myChangesTask.Result;
        _awaitingReview = awaitingReviewTask.Result;
        _failedChecks = failedChecksTask.Result;
        _recentVersions = recentVersionsTask.Result;

        _totalDetections = detectionsTask.Result.Count;
        _openChanges = allChangesTask.Result.Count(c => c.Status is not ChangeStatus.Merged and not ChangeStatus.Closed);
        _acceptedVersions = allVersionsTask.Result.Count;
        _failedCheckChanges = _failedChecks.Count;

        _loading = false;
    }
}
