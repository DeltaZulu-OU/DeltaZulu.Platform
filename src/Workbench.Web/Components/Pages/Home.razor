@page "/"
@rendermode InteractiveServer
@using Workbench.Application.Services
@using Workbench.Domain.Changes
@using Workbench.Domain.Detections
@using Workbench.Domain.Enums
@using Workbench.Web.Services
@inject ChangeService ChangeService
@inject DetectionContentService DetectionService
@inject VersionService VersionService
@inject PocUserContext UserContext
@inject NavigationManager Nav

<PageTitle>Detection Content Workbench</PageTitle>

<DzPageHeader Title="Detection Content Workbench"
              TitleTypo="Typo.h4"
              Description="Edit detection content, prove it is safe, accept it into history." />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
    return;
}

<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="6" md="3">
        <DzPanel Class="dz-metric-tile">
            <MudIcon Icon="@Icons.Material.Outlined.Shield" Size="Size.Large" Class="dz-metric-tile__icon" />
            <MudText Typo="Typo.h4" Class="dz-metric-tile__value">@_totalDetections</MudText>
            <MudText Typo="Typo.caption" Class="dz-metric-tile__label">Detections</MudText>
        </DzPanel>
    </MudItem>
    <MudItem xs="6" md="3">
        <DzPanel Class="dz-metric-tile">
            <MudIcon Icon="@Icons.Material.Outlined.EditNote" Size="Size.Large" Class="dz-metric-tile__icon" />
            <MudText Typo="Typo.h4" Class="dz-metric-tile__value">@_openChanges</MudText>
            <MudText Typo="Typo.caption" Class="dz-metric-tile__label">Open changes</MudText>
        </DzPanel>
    </MudItem>
    <MudItem xs="6" md="3">
        <DzPanel Class="dz-metric-tile">
            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Large" Class="dz-metric-tile__icon dz-metric-tile__icon--success" />
            <MudText Typo="Typo.h4" Class="dz-metric-tile__value">@_acceptedVersions</MudText>
            <MudText Typo="Typo.caption" Class="dz-metric-tile__label">Accepted versions</MudText>
        </DzPanel>
    </MudItem>
    <MudItem xs="6" md="3">
        <DzPanel Class="dz-metric-tile">
            <MudIcon Icon="@Icons.Material.Outlined.Error" Size="Size.Large" Class="dz-metric-tile__icon dz-metric-tile__icon--error" />
            <MudText Typo="Typo.h4" Class="dz-metric-tile__value">@_failedCheckChanges</MudText>
            <MudText Typo="Typo.caption" Class="dz-metric-tile__label">Changes with failed checks</MudText>
        </DzPanel>
    </MudItem>
</MudGrid>

<MudGrid Spacing="3">
    <MudItem xs="12" md="6">
        <DzPanel Eyebrow="Needs my action" Class="dz-panel--full-height">
            @if (_myChanges.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="text-secondary">
                    No changes need your attention.
                </MudText>
            }
            else
            {
                <MudList T="ChangeRequest" Dense="true" Class="dz-card-list">
                    @foreach (var change in _myChanges)
                    {
                        <MudListItem T="ChangeRequest" OnClick="@(() => Nav.NavigateTo($"/changes/{change.Id}"))">
                            <div class="dz-card-list__row">
                                <code>@change.Key</code>
                                <MudText Typo="Typo.body2">@change.Title</MudText>
                                <StatusChip ChangeStatus="change.Status" />
                                @if (change.IsStale)
                                {
                                    <DzStatusChip Label="Stale" Tone="warning" />
                                }
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </DzPanel>
    </MudItem>

    <MudItem xs="12" md="6">
        <DzPanel Eyebrow="Pending review" Class="dz-panel--full-height">
            @if (_awaitingReview.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="text-secondary">
                    No reviews waiting for your decision.
                </MudText>
            }
            else
            {
                <MudList T="ChangeRequest" Dense="true" Class="dz-card-list">
                    @foreach (var change in _awaitingReview)
                    {
                        <MudListItem T="ChangeRequest" OnClick="@(() => Nav.NavigateTo($"/changes/{change.Id}"))">
                            <div class="dz-card-list__row">
                                <code>@change.Key</code>
                                <MudText Typo="Typo.body2">@change.Title</MudText>
                                <StatusChip ChangeStatus="change.Status" />
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </DzPanel>
    </MudItem>

    <MudItem xs="12" md="6">
        <DzPanel Eyebrow="Failed checks" Class="dz-panel--full-height">
            @if (_failedChecks.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="text-secondary">
                    No check failures across open changes.
                </MudText>
            }
            else
            {
                <MudList T="ChangeRequest" Dense="true" Class="dz-card-list">
                    @foreach (var change in _failedChecks)
                    {
                        var failCount = change.Checks.Count(c => c.IsBlocking && c.Status == CheckStatus.Failed);
                        <MudListItem T="ChangeRequest" OnClick="@(() => Nav.NavigateTo($"/changes/{change.Id}"))">
                            <div class="dz-card-list__row">
                                <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" Size="Size.Small" Class="dz-inline-icon dz-inline-icon--error" />
                                <code>@change.Key</code>
                                <MudText Typo="Typo.body2">@change.Title</MudText>
                                <DzStatusChip Label="@($"{failCount} failure(s)")" Tone="error" />
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </DzPanel>
    </MudItem>

    <MudItem xs="12" md="6">
        <DzPanel Eyebrow="Recently accepted" Class="dz-panel--full-height">
            @if (_recentVersions.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="text-secondary">
                    No versions accepted yet.
                </MudText>
            }
            else
            {
                <MudList T="DetectionVersion" Dense="true" Class="dz-card-list">
                    @foreach (var version in _recentVersions)
                    {
                        <MudListItem T="DetectionVersion" OnClick="@(() => Nav.NavigateTo($"/history/{version.Id}"))">
                            <div class="dz-card-list__row">
                                <DzMetaChip Kind="version">@version.DisplayVersion</DzMetaChip>
                                <MudText Typo="Typo.body2">@version.Title</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @version.AcceptedAt.ToString("yyyy-MM-dd HH:mm")
                                </MudText>
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </DzPanel>
    </MudItem>
</MudGrid>

@code {
    private IReadOnlyList<ChangeRequest> _myChanges = [];
    private IReadOnlyList<ChangeRequest> _awaitingReview = [];
    private IReadOnlyList<ChangeRequest> _failedChecks = [];
    private IReadOnlyList<DetectionVersion> _recentVersions = [];
    private int _totalDetections;
    private int _openChanges;
    private int _acceptedVersions;
    private int _failedCheckChanges;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        var userId = UserContext.CurrentUser.Id;

        var myChangesTask = ChangeService.ListMyActiveChangesAsync(userId);
        var awaitingReviewTask = ChangeService.ListAwaitingMyReviewAsync(userId);
        var failedChecksTask = ChangeService.ListWithFailedChecksAsync();
        var recentVersionsTask = VersionService.ListRecentAsync(5);
        var detectionsTask = DetectionService.ListAsync();
        var allChangesTask = ChangeService.ListAsync();
        var allVersionsTask = VersionService.ListRecentAsync(int.MaxValue);

        await Task.WhenAll(myChangesTask, awaitingReviewTask, failedChecksTask, recentVersionsTask,
                   detectionsTask, allChangesTask, allVersionsTask);

        _myChanges = myChangesTask.Result;
        _awaitingReview = awaitingReviewTask.Result;
        _failedChecks = failedChecksTask.Result;
        _recentVersions = recentVersionsTask.Result;

        _totalDetections = detectionsTask.Result.Count;
        _openChanges = allChangesTask.Result.Count(c => c.Status is not ChangeStatus.Merged and not ChangeStatus.Closed);
        _acceptedVersions = allVersionsTask.Result.Count;
        _failedCheckChanges = _failedChecks.Count;

        _loading = false;
    }
}
