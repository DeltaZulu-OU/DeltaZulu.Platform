@using Markdig
@using Markdig.Syntax
@using Markdig.Syntax.Inlines

<div class="markdown-viewer">
    @((MarkupString)_renderedHtml)
</div>

@code {
    /// <summary>Raw markdown content to render.</summary>
    [Parameter, EditorRequired]
    public string Content { get; set; } = string.Empty;

    /// <summary>
    /// Repository-relative path of the current file, used to resolve relative links.
    /// E.g. <c>detections/anomalous-sign-in/notes/investigation.md</c>.
    /// </summary>
    [Parameter]
    public string? CurrentFilePath { get; set; }

    private string _renderedHtml = string.Empty;

    private static readonly MarkdownPipeline Pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .UseYamlFrontMatter()
        .Build();

    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(Content))
        {
            _renderedHtml = string.Empty;
            return;
        }

        var doc = Markdown.Parse(Content, Pipeline);

        // Rewrite internal relative links to Blazor routes.
        RewriteLinks(doc);

        using var writer = new StringWriter();
        var renderer = new Markdig.Renderers.HtmlRenderer(writer);
        Pipeline.Setup(renderer);
        renderer.Render(doc);
        writer.Flush();
        _renderedHtml = writer.ToString();
    }

    private void RewriteLinks(MarkdownDocument doc)
    {
        foreach (var link in doc.Descendants<LinkInline>())
        {
            if (link.Url is null) continue;

            // Skip external URLs and anchors.
            if (link.Url.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
                || link.Url.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
                || link.Url.StartsWith("mailto:", StringComparison.OrdinalIgnoreCase)
                || link.Url.StartsWith('#'))
            {
                continue;
            }

            // Resolve relative path against current file's directory.
            var resolved = ResolveRelativePath(link.Url);
            if (resolved is null) continue;

            // Map to Blazor route.
            link.Url = MapToRoute(resolved);
        }
    }

    private string? ResolveRelativePath(string relativePath)
    {
        if (CurrentFilePath is null) return relativePath;

        var currentDir = CurrentFilePath.Contains('/')
            ? CurrentFilePath[..CurrentFilePath.LastIndexOf('/')]
            : string.Empty;

        // Split and resolve . and ..
        var parts = $"{currentDir}/{relativePath}".Split('/', StringSplitOptions.RemoveEmptyEntries);
        var resolved = new Stack<string>();

        foreach (var part in parts)
        {
            if (part == ".") continue;
            if (part == ".." && resolved.Count > 0) { resolved.Pop(); continue; }
            if (part == "..") continue;
            resolved.Push(part);
        }

        return string.Join('/', resolved.Reverse());
    }

    private static string MapToRoute(string repoPath)
    {
        // detections/<slug>/... → /detections/<slug>/file/<rest>
        if (repoPath.StartsWith("detections/", StringComparison.Ordinal))
        {
            var afterDetections = repoPath["detections/".Length..];
            var slashIdx = afterDetections.IndexOf('/');
            if (slashIdx > 0)
            {
                var slug = afterDetections[..slashIdx];
                var rest = afterDetections[(slashIdx + 1)..];
                return $"/detections/{slug}/file/{rest}";
            }
        }

        // investigations/<slug>/... → /investigations/<slug>/file/<rest>
        if (repoPath.StartsWith("investigations/", StringComparison.Ordinal))
        {
            var afterInv = repoPath["investigations/".Length..];
            var slashIdx = afterInv.IndexOf('/');
            if (slashIdx > 0)
            {
                var slug = afterInv[..slashIdx];
                var rest = afterInv[(slashIdx + 1)..];
                return $"/investigations/{slug}/file/{rest}";
            }
        }

        // Fallback: link as-is.
        return repoPath;
    }
}
