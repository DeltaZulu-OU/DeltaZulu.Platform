@using Workbench.Domain.Enums

@if (_text is not null)
{
    <MudChip T="string" Size="Size.Small" Style="@_style" Variant="Variant.Filled">@_text</MudChip>
}

@code {
    [Parameter] public ChangeStatus? ChangeStatus { get; set; }
    [Parameter] public IssueStatus? IssueStatus { get; set; }
    [Parameter] public DetectionLifecycle? Lifecycle { get; set; }
    [Parameter] public CheckStatus? CheckStatus { get; set; }

    private string? _text;
    private string _style = "";

    // DZ design system: use semantic/viz tokens for status colours.
    // Orange is CTA-only — never on status chips.
    private const string ChipSuccess = "background: var(--color-success-bg); color: var(--color-success);";
    private const string ChipWarning = "background: var(--color-warning-bg); color: var(--color-warning);";
    private const string ChipError = "background: var(--color-error-bg); color: var(--color-error);";
    private const string ChipInfo = "background: var(--color-surface-muted); color: var(--brand-slate);";
    private const string ChipNeutral = "background: var(--color-divider); color: var(--color-text-secondary);";
    private const string ChipDark = "background: var(--brand-ink); color: var(--color-text-inverse);";
    private const string ChipMuted = "background: var(--color-divider); color: var(--color-text-muted);";

    protected override void OnParametersSet()
    {
        if (ChangeStatus is not null)
        {
            _text = ChangeStatus.Value.ToString();
            _style = ChangeStatus.Value switch
            {
                Domain.Enums.ChangeStatus.Draft => ChipNeutral,
                Domain.Enums.ChangeStatus.ChecksRunning => ChipInfo,
                Domain.Enums.ChangeStatus.ReviewRequired => ChipWarning,
                Domain.Enums.ChangeStatus.ChangesRequested => ChipError,
                Domain.Enums.ChangeStatus.ReadyToAccept => ChipSuccess,
                Domain.Enums.ChangeStatus.Merged => ChipDark,
                Domain.Enums.ChangeStatus.Closed => ChipMuted,
                _ => ChipNeutral,
            };
        }
        else if (IssueStatus is not null)
        {
            _text = IssueStatus.Value.ToString();
            _style = IssueStatus.Value switch
            {
                Domain.Enums.IssueStatus.Open => ChipInfo,
                Domain.Enums.IssueStatus.InProgress => ChipWarning,
                Domain.Enums.IssueStatus.Blocked => ChipError,
                Domain.Enums.IssueStatus.Resolved => ChipSuccess,
                Domain.Enums.IssueStatus.Closed => ChipMuted,
                _ => ChipNeutral,
            };
        }
        else if (Lifecycle is not null)
        {
            _text = Lifecycle.Value.ToString();
            _style = Lifecycle.Value switch
            {
                DetectionLifecycle.Conceived => ChipNeutral,
                DetectionLifecycle.Accepted => ChipSuccess,
                DetectionLifecycle.Deprecated => ChipMuted,
                _ => ChipNeutral,
            };
        }
        else if (CheckStatus is not null)
        {
            _text = CheckStatus.Value.ToString();
            _style = CheckStatus.Value switch
            {
                Domain.Enums.CheckStatus.Passed => ChipSuccess,
                Domain.Enums.CheckStatus.Failed => ChipError,
                Domain.Enums.CheckStatus.Running => ChipInfo,
                Domain.Enums.CheckStatus.Queued => ChipNeutral,
                Domain.Enums.CheckStatus.Skipped => ChipMuted,
                Domain.Enums.CheckStatus.Cancelled => ChipMuted,
                _ => ChipNeutral,
            };
        }
    }
}
