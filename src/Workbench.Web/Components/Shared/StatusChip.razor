@using Workbench.Domain.Enums

@if (_text is not null)
{
    <DzStatusChip Label="@_text" Tone="@_tone" />
}

@code {
    [Parameter] public ChangeStatus? ChangeStatus { get; set; }
    [Parameter] public IssueStatus? IssueStatus { get; set; }
    [Parameter] public DetectionLifecycle? Lifecycle { get; set; }
    [Parameter] public CheckStatus? CheckStatus { get; set; }

    private string? _text;
    private string _tone = "neutral";

    protected override void OnParametersSet()
    {
        if (ChangeStatus is not null)
        {
            _text = ChangeStatus.Value.ToString();
            _tone = ChangeStatus.Value switch
            {
                Domain.Enums.ChangeStatus.Draft => "neutral",
                Domain.Enums.ChangeStatus.ChecksRunning => "info",
                Domain.Enums.ChangeStatus.ReviewRequired => "warning",
                Domain.Enums.ChangeStatus.ChangesRequested => "error",
                Domain.Enums.ChangeStatus.ReadyToAccept => "success",
                Domain.Enums.ChangeStatus.Merged => "dark",
                Domain.Enums.ChangeStatus.Closed => "muted",
                _ => "neutral",
            };
        }
        else if (IssueStatus is not null)
        {
            _text = IssueStatus.Value.ToString();
            _tone = IssueStatus.Value switch
            {
                Domain.Enums.IssueStatus.Open => "info",
                Domain.Enums.IssueStatus.InProgress => "warning",
                Domain.Enums.IssueStatus.Blocked => "error",
                Domain.Enums.IssueStatus.Resolved => "success",
                Domain.Enums.IssueStatus.Closed => "muted",
                _ => "neutral",
            };
        }
        else if (Lifecycle is not null)
        {
            _text = Lifecycle.Value.ToString();
            _tone = Lifecycle.Value switch
            {
                DetectionLifecycle.Conceived => "neutral",
                DetectionLifecycle.Accepted => "success",
                DetectionLifecycle.Deprecated => "muted",
                _ => "neutral",
            };
        }
        else if (CheckStatus is not null)
        {
            _text = CheckStatus.Value.ToString();
            _tone = CheckStatus.Value switch
            {
                Domain.Enums.CheckStatus.Passed => "success",
                Domain.Enums.CheckStatus.Failed => "error",
                Domain.Enums.CheckStatus.Running => "info",
                Domain.Enums.CheckStatus.Queued => "neutral",
                Domain.Enums.CheckStatus.Skipped => "muted",
                Domain.Enums.CheckStatus.Cancelled => "muted",
                _ => "neutral",
            };
        }
        else
        {
            _text = null;
            _tone = "neutral";
        }
    }
}
