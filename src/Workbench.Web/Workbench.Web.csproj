<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <RootNamespace>Workbench.Web</RootNamespace>
    <AssemblyName>Workbench.Web</AssemblyName>
    <UserSecretsId>dac-workbench-web</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Workbench.Application\Workbench.Application.csproj" />
    <ProjectReference Include="..\Workbench.Domain\Workbench.Domain.csproj" />
    <ProjectReference Include="..\Workbench.Persistence\Workbench.Persistence.csproj" />
    <ProjectReference Include="..\Workbench.Infrastructure\Workbench.Infrastructure.csproj" />
    <ProjectReference Include="..\Workbench.Workflow\Workbench.Workflow.csproj" />
    <ProjectReference Include="..\Workbench.Validation\Workbench.Validation.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!--
      MudBlazor 9.x is requested per user constraint. The 9.* range is intentional for first
      restore; pin to a concrete patch (e.g. 9.0.0) once the CI baseline is locked. MudBlazor
      9 currently targets net9.0 and forward-compatible runtime; verify on first restore that
      net10.0 transitive resolution does not require a prerelease feed.
    -->
    <PackageReference Include="MudBlazor" Version="9.*" />
    <PackageReference Include="Markdig" Version="1.2.0" />
  </ItemGroup>

</Project>
