@inherits LayoutComponentBase
@namespace Hunting.Web.Shared

<div class="hunt-shell">
    <aside class="hunt-sidebar">
        <div class="hunt-logo">
            <span class="hunt-logo-text">🔍 Hunting Workbench</span>
        </div>

        <nav class="hunt-nav">
            <NavLink href="/" Match="NavLinkMatch.All" class="hunt-nav-link">Hunt</NavLink>
            <NavLink href="/settings" class="hunt-nav-link">Settings</NavLink>
        </nav>

        <SchemaBrowser />
    </aside>

    <main class="hunt-main">
        @Body
    </main>
</div>

<MudSnackbarProvider />
