@page "/"
@namespace Hunting.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>KQL Hunting Workbench</title>
    <base href="~/" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="_content/MudBlazor/MudBlazor.min.css" />
</head>
<body>
    <component type="typeof(Hunting.Web.App)" render-mode="Server" />
    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>
    <script src="~/js/monaco.js" asp-append-version="true"></script>
    <script src="~/js/charts.js" asp-append-version="true"></script>
    <script src="~/js/splitter.js" asp-append-version="true"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="_framework/blazor.server.js" autostart="false"></script>
    <!-- Load Vizor bundle which includes echarts -->
    <script src="_content/Vizor.ECharts/js/vizor-echarts-bundle-min.js"></script>
    <script>
        Blazor.start();
    </script>
</body>
</html>
