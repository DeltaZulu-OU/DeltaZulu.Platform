@page "/library"
@namespace Hunting.Web.Pages
@using Hunting.Web.Library
@using Hunting.Web.Services
@inject LibraryPageController Controller

<div class="dashboard-list-page">
    <header class="dashboard-page-header dashboard-list-header">
        <div>
            <p class="dashboard-eyebrow">Library</p>
            <h1>Library</h1>
            <p class="dashboard-page-subtitle">Manage saved searches, reusable visualizations, and dashboards from one place.</p>
        </div>
        <div class="dashboard-list-toolbar">
            <label class="dashboard-search" aria-label="Search library">
                <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
                <input placeholder="Search library"
                       value="@State.SearchText"
                       @oninput="OnSearchChanged" />
            </label>

            <div class="dashboard-list-actions-primary">
                <button class="hunt-btn dashboard-primary-action" @onclick="Controller.CreateSavedSearch">New saved search</button>
                <button class="hunt-btn" @onclick="Controller.CreateVisualization">New visualization</button>
                <button class="hunt-btn" @onclick="Controller.CreateDashboard">New dashboard</button>
            </div>
        </div>
    </header>

    @if (State.HasError)
    {
        <div class="dashboard-error">@State.Error</div>
    }

    @if (State.HasMessage)
    {
        <div class="hunt-query-library-message">@State.Message</div>
    }

    <section class="dashboard-list-panel" aria-label="Library panel">
        <div class="dashboard-list-panel-header">
            <div>
                <h2>@State.FilterTitle</h2>
                <p>@State.RangeText</p>
            </div>

            <div class="dashboard-list-actions-primary">
                <button class="@Controller.FilterButtonClass(null)" @onclick="() => Controller.SetFilter(null)">All</button>
                <button class="@Controller.FilterButtonClass(LibraryItemKind.SavedSearch)" @onclick="() => Controller.SetFilter(LibraryItemKind.SavedSearch)">Saved searches</button>
                <button class="@Controller.FilterButtonClass(LibraryItemKind.Visualization)" @onclick="() => Controller.SetFilter(LibraryItemKind.Visualization)">Visualizations</button>
                <button class="@Controller.FilterButtonClass(LibraryItemKind.Dashboard)" @onclick="() => Controller.SetFilter(LibraryItemKind.Dashboard)">Dashboards</button>
            </div>
        </div>

        @if (State.HasPagination)
        {
            <nav class="dashboard-pagination" aria-label="Library pages">
                <button class="hunt-btn dashboard-page-button"
                        disabled="@(State.Page <= 1)"
                        @onclick="Controller.PreviousPage">
                    Previous
                </button>
                <span>Page @State.Page of @State.TotalPages</span>
                <button class="hunt-btn dashboard-page-button"
                        disabled="@(State.Page >= State.TotalPages)"
                        @onclick="Controller.NextPage">
                    Next
                </button>
            </nav>
        }

        @if (State.Loading)
        {
            <section class="dashboard-empty-state">
                <h2>Loading library…</h2>
                <p>Reading saved searches, visualizations, and dashboards from local application persistence.</p>
            </section>
        }
        else if (State.HasNoMatches)
        {
            <section class="dashboard-empty-state dashboard-list-empty">
                <h2>No matching library items</h2>
                <p>Create a new item or adjust the search/filter.</p>
                <div class="dashboard-empty-actions">
                    <button class="hunt-btn" @onclick="Controller.ClearSearch">Clear search</button>
                    <button class="hunt-btn dashboard-primary-action" @onclick="Controller.CreateSavedSearch">Create saved search</button>
                </div>
            </section>
        }
        else
        {
            <div class="dashboard-list" aria-label="Library items">
                @foreach (var item in State.PagedItems)
                {
                    <article class="dashboard-list-card">
                        <div class="dashboard-card-main">
                            <div class="dashboard-card-title-row">
                                <h2>@item.Name</h2>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <p>@item.Description</p>
                            }
                            else
                            {
                                <p class="dashboard-muted">No description.</p>
                            }
                        </div>

                        <dl class="dashboard-list-meta">
                            <div>
                                <dt>Type</dt>
                                <dd>@LibraryLabels.KindLabel(item.Kind)</dd>
                            </div>
                            <div>
                                <dt>Source</dt>
                                <dd>@item.DependencyLabel</dd>
                            </div>
                            <div>
                                <dt>Status</dt>
                                <dd>@LibraryLabels.StatusLabel(item.Status)</dd>
                            </div>
                            <div>
                                <dt>Updated</dt>
                                <dd>@item.UpdatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                            </div>
                        </dl>

                        <div class="dashboard-card-actions">
                            <button class="hunt-btn dashboard-primary-action" @onclick="() => Controller.OpenItemAsync(item)">Open</button>
                            <button class="@Controller.DeleteButtonClass(item)"
                                    disabled="@State.Deleting"
                                    title="@Controller.DeleteButtonTitle(item)"
                                    @onclick="() => Controller.DeleteItemAsync(item)">
                                @Controller.DeleteButtonText(item)
                            </button>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>

@code {
    private LibraryPageState State => Controller.State;

    protected override async Task OnInitializedAsync()
    {
        await Controller.LoadAsync();
    }

    private void OnSearchChanged(ChangeEventArgs args)
    {
        Controller.SetSearchText(args.Value?.ToString());
    }
}
