@page "/library"
@namespace Hunting.Web.Pages
@using Hunting.Web.Library
@using Hunting.Web.Services
@inject LibraryPageController Controller

<div class="dashboard-list-page">
    <header class="dashboard-page-header dashboard-list-header">
        <div>
            <p class="dashboard-eyebrow">Library</p>
            <h1>Library</h1>
            <p class="dashboard-page-subtitle">Manage saved queries, reusable visualizations, and dashboards from one place.</p>
        </div>
        <div class="dashboard-list-toolbar">
            <div class="dashboard-list-actions-primary">
                <MudButton Variant="Variant.Filled"
                           Size="Size.Small"
                           Color="Color.Primary"
                           OnClick="@(() => Controller.CreateSavedQuery())">
                    New saved query
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           OnClick="@(() => Controller.CreateVisualization())">
                    New visualization
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Size="Size.Small"
                           OnClick="@(() => Controller.CreateDashboard())">
                    New dashboard
                </MudButton>
            </div>
        </div>
    </header>

    @if (State.HasError)
    {
        <div class="dashboard-error">@State.Error</div>
    }

    @if (State.HasMessage)
    {
        <div class="hunt-query-library-message">@State.Message</div>
    }

    <section class="dashboard-list-panel" aria-label="Library panel">
        <MudTable T="LibraryItem"
                  Items="@State.Items"
                  Dense="true"
                  Hover="true"
                  Elevation="0"
                  Loading="@State.Loading"
                  Filter="State.FilterItem"
                  RowsPerPage="@LibraryPageState.DefaultRowsPerPage"
                  Class="library-object-table">
            <ToolBarContent>
                <div class="dashboard-list-panel-header library-table-toolbar">
                    <div>
                        <h2>@State.FilterTitle</h2>
                        <p>@State.RangeText</p>
                    </div>

                    <MudSpacer />

                    <MudTextField T="string"
                                  Value="@State.SearchText"
                                  ValueChanged="Controller.SetSearchText"
                                  Placeholder="Search library"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true"
                                  Margin="Margin.Dense"
                                  Variant="Variant.Outlined"
                                  Class="library-table-search" />

                    <div class="dashboard-list-actions-primary library-filter-buttons">
                        <button class="@Controller.FilterButtonClass(null)" @onclick="() => Controller.SetFilter(null)">All</button>
                        <button class="@Controller.FilterButtonClass(LibraryItemKind.SavedQuery)" @onclick="() => Controller.SetFilter(LibraryItemKind.SavedQuery)">Saved queries</button>
                        <button class="@Controller.FilterButtonClass(LibraryItemKind.Visualization)" @onclick="() => Controller.SetFilter(LibraryItemKind.Visualization)">Visualizations</button>
                        <button class="@Controller.FilterButtonClass(LibraryItemKind.Dashboard)" @onclick="() => Controller.SetFilter(LibraryItemKind.Dashboard)">Dashboards</button>
                    </div>
                </div>
            </ToolBarContent>

            <HeaderContent>
                <MudTh Style="width: 48px;"></MudTh>
                <MudTh>
                    <MudTableSortLabel T="LibraryItem" SortBy="item => LibraryLabels.KindLabel(item.Kind)">
                        Type
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel T="LibraryItem" InitialDirection="SortDirection.Ascending" SortBy="item => item.Name">
                        Title
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel T="LibraryItem" SortBy="item => item.DependencyLabel">
                        Source
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel T="LibraryItem" SortBy="item => LibraryLabels.StatusLabel(item.Status)">
                        Status
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel T="LibraryItem" SortBy="item => item.UpdatedAtUtc">
                        Updated
                    </MudTableSortLabel>
                </MudTh>
                <MudTh Style="text-align: right;">Actions</MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd DataLabel="">
                    <MudIcon Icon="@GetKindIcon(context.Kind)" Size="Size.Small" />
                </MudTd>
                <MudTd DataLabel="Type">@LibraryLabels.KindLabel(context.Kind)</MudTd>
                <MudTd DataLabel="Title">
                    <MudButton Variant="Variant.Text"
                               Size="Size.Small"
                               Class="library-object-title"
                               OnClick="@(() => Controller.OpenItemAsync(context))">
                        @context.Name
                    </MudButton>
                    @if (!string.IsNullOrWhiteSpace(context.Description))
                    {
                        <div class="dashboard-muted">@context.Description</div>
                    }
                </MudTd>
                <MudTd DataLabel="Source">@context.DependencyLabel</MudTd>
                <MudTd DataLabel="Status">
                    @if (context.Status == LibraryItemStatus.MissingDependency)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Missing dependency</MudChip>
                    }
                    else
                    {
                        <span class="dashboard-muted">OK</span>
                    }
                </MudTd>
                <MudTd DataLabel="Updated">@LibraryLabels.UpdatedLabel(context.UpdatedAtUtc)</MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudButton Variant="Variant.Outlined"
                               Size="Size.Small"
                               OnClick="@(() => Controller.OpenItemAsync(context))">
                        Open
                    </MudButton>
                    <MudButton Variant="Variant.Text"
                               Size="Size.Small"
                               Disabled="@State.Deleting"
                               Title="@Controller.DeleteButtonTitle(context)"
                               Class="@Controller.DeleteButtonClass(context)"
                               OnClick="@(() => Controller.DeleteItemAsync(context))">
                        @Controller.DeleteButtonText(context)
                    </MudButton>
                </MudTd>
            </RowTemplate>

            <NoRecordsContent>
                @if (State.Items.Count == 0)
                {
                    <section class="dashboard-empty-state dashboard-list-empty">
                        <h2>No library items</h2>
                        <p>Create a saved query, visualization, or dashboard to populate the library.</p>
                        <div class="dashboard-empty-actions">
                            <button class="hunt-btn dashboard-primary-action" @onclick="Controller.CreateSavedQuery">Create saved query</button>
                        </div>
                    </section>
                }
                else
                {
                    <section class="dashboard-empty-state dashboard-list-empty">
                        <h2>No matching library items</h2>
                        <p>Clear the search text or use a different filter.</p>
                        <div class="dashboard-empty-actions">
                            <button class="hunt-btn" @onclick="Controller.ClearSearch">Clear search</button>
                        </div>
                    </section>
                }
            </NoRecordsContent>

            <PagerContent>
                <MudTablePager PageSizeOptions="@LibraryPageState.PageSizeOptions" />
            </PagerContent>
        </MudTable>
    </section>
</div>

@code {
    private LibraryPageState State => Controller.State;

    protected override async Task OnInitializedAsync()
    {
        await Controller.LoadAsync();
    }

    private static string GetKindIcon(LibraryItemKind kind)
        => kind switch
        {
            LibraryItemKind.SavedQuery => Icons.Material.Filled.Search,
            LibraryItemKind.Visualization => Icons.Material.Filled.InsertChart,
            LibraryItemKind.Dashboard => Icons.Material.Filled.Dashboard,
            _ => Icons.Material.Filled.Description
        };
}
