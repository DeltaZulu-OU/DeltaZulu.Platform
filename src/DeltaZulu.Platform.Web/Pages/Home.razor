@page "/"
@using MudBlazor

<PageTitle>DeltaZulu Platform — Overview</PageTitle>

<DzPageHeader Eyebrow="Full-cycle security analytics"
              Title="Overview"
              Description="Start investigations, reuse analytical content, manage detections, and review operational work from one place.">
    <Actions>
        <MudButton Href="/analytics" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Outlined.Search">
            Open Analytics Workbench
        </MudButton>
        <MudButton Href="/governance/detections" Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" Class="ml-2" StartIcon="@Icons.Material.Outlined.Radar">
            Manage Detections
        </MudButton>
    </Actions>
</DzPageHeader>

<MudGrid Spacing="3">
    <MudItem xs="12" md="4">
        <DzPanel Eyebrow="Analytics" Title="Analytics Workbench" Elevation="0" Outlined="true" Class="dz-panel--full-height">
            <MudText Typo="Typo.body2" Class="text-secondary">
                Run KQL queries against approved Golden schema views, inspect results, and save reusable queries.
            </MudText>
            <MudButton Href="/analytics"
                       Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Size="Size.Small"
                       Class="mt-3"
                       StartIcon="@Icons.Material.Outlined.Search">
                Open workbench
            </MudButton>
        </DzPanel>
    </MudItem>

    <MudItem xs="12" md="4">
        <DzPanel Eyebrow="Analytics" Title="Library" Elevation="0" Outlined="true" Class="dz-panel--full-height">
            <MudText Typo="Typo.body2" Class="text-secondary">
                Browse saved queries, visualizations, and reusable analytical artifacts.
            </MudText>
            <MudButton Href="/analytics/library"
                       Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Size="Size.Small"
                       Class="mt-3"
                       StartIcon="@Icons.Material.Outlined.LibraryBooks">
                Open library
            </MudButton>
        </DzPanel>
    </MudItem>

    <MudItem xs="12" md="4">
        <DzPanel Eyebrow="Analytics" Title="Dashboards" Elevation="0" Outlined="true" Class="dz-panel--full-height">
            <MudText Typo="Typo.body2" Class="text-secondary">
                Compose persisted table and chart widgets on top of the same query runtime.
            </MudText>
            <MudButton Href="/analytics/dashboards"
                       Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Size="Size.Small"
                       Class="mt-3"
                       StartIcon="@Icons.Material.Outlined.Dashboard">
                View dashboards
            </MudButton>
        </DzPanel>
    </MudItem>

    <MudItem xs="12" md="4">
        <DzPanel Eyebrow="Content" Title="Detections" Elevation="0" Outlined="true" Class="dz-panel--full-height">
            <MudText Typo="Typo.body2" Class="text-secondary">
                Manage detection content packages and open proposals.
            </MudText>
            <MudButton Href="/governance/detections"
                       Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Size="Size.Small"
                       Class="mt-3"
                       StartIcon="@Icons.Material.Outlined.Radar">
                Open detections
            </MudButton>
        </DzPanel>
    </MudItem>

    <MudItem xs="12" md="4">
        <DzPanel Eyebrow="Workflow" Title="Proposals" Elevation="0" Outlined="true" Class="dz-panel--full-height">
            <MudText Typo="Typo.body2" Class="text-secondary">
                Review draft content, validation checks, approvals, and acceptance gates.
            </MudText>
            <MudButton Href="/governance/proposals"
                       Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Size="Size.Small"
                       Class="mt-3"
                       StartIcon="@Icons.Material.Outlined.Assignment">
                Open proposals
            </MudButton>
        </DzPanel>
    </MudItem>

    <MudItem xs="12" md="4">
        <DzPanel Eyebrow="History" Title="Accepted versions" Elevation="0" Outlined="true" Class="dz-panel--full-height">
            <MudText Typo="Typo.body2" Class="text-secondary">
                Compare accepted versions and restore previous content safely.
            </MudText>
            <MudButton Href="/governance/history"
                       Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Size="Size.Small"
                       Class="mt-3"
                       StartIcon="@Icons.Material.Outlined.History">
                Open history
            </MudButton>
        </DzPanel>
    </MudItem>

    <MudItem xs="12" md="4">
        <DzPanel Eyebrow="Platform" Title="Settings" Elevation="0" Outlined="true" Class="dz-panel--full-height">
            <MudText Typo="Typo.body2" Class="text-secondary">
                Configure query defaults and platform operational options.
            </MudText>
            <MudButton Href="/settings"
                       Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Size="Size.Small"
                       Class="mt-3"
                       StartIcon="@Icons.Material.Outlined.Settings">
                Open settings
            </MudButton>
        </DzPanel>
    </MudItem>
</MudGrid>
