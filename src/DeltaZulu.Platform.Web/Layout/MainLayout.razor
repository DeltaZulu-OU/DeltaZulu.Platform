@inherits LayoutComponentBase
@using DeltaZulu.Platform.Web.Components
@using DeltaZulu.Platform.Web.Platform
@inject IEnumerable<IPlatformModule> Modules
@inject NavigationManager Navigation
@implements IDisposable

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <DzAppBar ProductName="DeltaZulu Platform"
              LogoSrc="img/logo-dark.png"
              OnMenuClick="@ToggleDrawer" />

    <DzSideNav @bind-Open="_drawerOpen" Items="_navItems" Heading="Platform">
        <Footer>
            <MudDivider Class="my-3 mx-4 dz-nav-divider" />
            <MudNavMenu Class="dz-side-nav__menu dz-side-nav__menu--footer">
                <MudNavLink Href="@_settingsItem.Href"
                            Match="@_settingsItem.Match"
                            Icon="@_settingsItem.Icon">
                    @_settingsItem.Label
                </MudNavLink>
            </MudNavMenu>
        </Footer>
    </DzSideNav>

    <DzMainContent Class="@ShellMainClass" MainContentClass="@MainContentClass">
        @Body
    </DzMainContent>
</MudLayout>

@code {
    private static readonly MudTheme _theme = DeltaZuluTheme.Create();
    private static readonly DzNavItem _overviewItem = new("Overview", "/", Icons.Material.Outlined.Home, NavLinkMatch.All, IsPlatformRoute: true);
    private static readonly DzNavItem _settingsItem = new("Settings", "/settings", Icons.Material.Outlined.Settings, IsPlatformRoute: true);
    private bool _drawerOpen = true;
    private IReadOnlyList<IPlatformModule> _orderedModules = [];
    private IReadOnlyList<DzNavItem> _navItems = [];

    protected override void OnInitialized()
    {
        _orderedModules = Modules.OrderBy(m => m.Descriptor.Order).ToList();
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            _overviewItem.Href,
            _settingsItem.Href,
        };

        _navItems = new[] { _overviewItem }
            .Concat(_orderedModules.SelectMany(m => m.NavigationItems)
                .Where(item => !item.IsPlatformRoute && seen.Add(item.Href)))
            .ToList();

        Navigation.LocationChanged += OnLocationChanged;
    }

    private bool IsFullBleedWorkbenchRoute
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/');
            return string.Equals(relativePath, "analytics", StringComparison.OrdinalIgnoreCase)
                   || string.Equals(relativePath, "governance/detections/new", StringComparison.OrdinalIgnoreCase);
        }
    }

    private string? ShellMainClass => IsFullBleedWorkbenchRoute ? "dz-shell-main--full-bleed" : null;

    private string? MainContentClass => IsFullBleedWorkbenchRoute ? "dz-main-content--full-height" : null;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;
}
