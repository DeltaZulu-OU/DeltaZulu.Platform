@inherits LayoutComponentBase
@using DeltaZulu.Platform.Web.Components
@using DeltaZulu.Platform.Web.Platform
@inject IEnumerable<IPlatformModule> Modules
@inject NavigationManager Navigation
@implements IDisposable

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <DzAppBar ProductName="DeltaZulu Platform"
              LogoSrc="img/logo-dark.png"
              OnMenuClick="@ToggleDrawer" />

    <DzSideNav @bind-Open="_drawerOpen" Items="_navItems" Heading="Platform" />

    <DzMainContent Class="@ShellMainClass" MainContentClass="@MainContentClass">
        @Body
    </DzMainContent>
</MudLayout>

@code {
    private static readonly MudTheme _theme = DeltaZuluTheme.Create();
    private bool _drawerOpen = true;
    private IReadOnlyList<IPlatformModule> _orderedModules = [];
    private IReadOnlyList<DzNavItem> _navItems = [];

    protected override void OnInitialized()
    {
        _orderedModules = Modules.OrderBy(m => m.Descriptor.Order).ToList();
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        _navItems = _orderedModules
            .SelectMany(m => m.NavigationItems)
            .Where(item => !item.IsPlatformRoute || seen.Add(item.Href))
            .ToList();

        Navigation.LocationChanged += OnLocationChanged;
    }

    private bool IsThreatAnalyticsRoute
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/');
            return string.Equals(relativePath, "analytics/threat-hunting", StringComparison.OrdinalIgnoreCase);
        }
    }

    private string? ShellMainClass => IsThreatAnalyticsRoute ? "dz-shell-main--full-bleed" : null;

    private string? MainContentClass => IsThreatAnalyticsRoute ? "dz-main-content--full-height" : null;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;
}
