@namespace DeltaZulu.Platform.Web.Analytics.Components
@using DeltaZulu.Platform.Domain.Analytics.Rendering
@using DeltaZulu.Platform.Domain.Analytics.Schema
@using DeltaZulu.Platform.Web.Analytics.Rendering
@inject DeltaZulu.Platform.Domain.Analytics.Catalog.ApprovedViewCatalog Catalog
@inject RenderedQueryRunner RenderedQueryRunner
@inject EChartsRenderOptionsBuilder EChartsOptionsBuilder
@implements IDisposable

<button class="hunt-btn hunt-btn-helper" @onclick="OpenAsync" aria-haspopup="dialog" aria-expanded="@_open">Visualization wizard</button>

@if (_open)
{
    <button class="hunt-drawer-backdrop" @onclick="Close" aria-label="Close visualization wizard"></button>
    <aside class="hunt-drawer hunt-helper-drawer" role="dialog" aria-modal="true" aria-label="Visualization wizard">
        <div class="hunt-drawer-header">
            <div>
                <div class="hunt-drawer-title">Visualization wizard</div>
                <div class="hunt-drawer-subtitle">Pick chart settings; the render clause is appended only when you apply it.</div>
            </div>
            <button class="hunt-drawer-close" @onclick="Close" aria-label="Close visualization wizard">×</button>
        </div>

        <div class="hunt-drawer-body hunt-drawer-body-padded hunt-helper-body">
            <section class="hunt-helper-section" aria-labelledby="viz-kind-heading">
                <h3 id="viz-kind-heading" class="hunt-helper-section-title">Chart type</h3>
                <div class="hunt-helper-grid">
                    <label class="hunt-helper-field">
                        <span>Kind</span>
                        <select class="hunt-helper-input" @bind="_kind" @bind:after="OnKindChanged">
                            @foreach (var kind in RenderKinds)
                            {
                                <option value="@kind">@GetKindLabel(kind)</option>
                            }
                        </select>
                    </label>
                    <label class="hunt-helper-field">
                        <span>Table schema</span>
                        <select class="hunt-helper-input" value="@_table" @onchange="OnTableChanged">
                            @foreach (var table in Tables)
                            {
                                <option value="@table.Name">@table.Name</option>
                            }
                        </select>
                    </label>
                    <label class="hunt-helper-field hunt-helper-field-wide">
                        <span>Title</span>
                        <input class="hunt-helper-input" @bind="_title" @bind:event="oninput" @bind:after="RefreshPreviewAsync" placeholder="Optional chart title" />
                    </label>
                </div>
            </section>

            <section class="hunt-helper-section" aria-labelledby="viz-attrs-heading">
                <h3 id="viz-attrs-heading" class="hunt-helper-section-title">Attributes</h3>
                <div class="hunt-helper-grid">
                    @if (UsesXColumn)
                    {
                        <label class="hunt-helper-field">
                            <span>@XColumnLabel</span>
                            <select class="hunt-helper-input" @bind="_xColumn" @bind:after="RefreshPreviewAsync">
                                <option value="">Infer from result</option>
                                @foreach (var column in XColumnChoices)
                                {
                                    <option value="@column.Name">@column.Name (@column.Type)</option>
                                }
                            </select>
                        </label>
                    }

                    @if (UsesYColumns)
                    {
                        <div class="hunt-helper-field hunt-helper-field-wide">
                            <span>Y/value columns</span>
                            <div class="hunt-helper-filters" style="max-height: 12rem; overflow: auto;">
                                @foreach (var column in YColumnChoices)
                                {
                                    <label class="hunt-helper-checkbox-row">
                                        <input type="checkbox" checked="@IsYColumnSelected(column.Name)" @onchange="args => ToggleYColumn(column.Name, args)" />
                                        <span>@column.Name (@column.Type)</span>
                                    </label>
                                }
                            </div>
                        </div>
                    }

                    @if (UsesSeriesColumn)
                    {
                        <label class="hunt-helper-field">
                            <span>Series column</span>
                            <select class="hunt-helper-input" @bind="_seriesColumn" @bind:after="RefreshPreviewAsync">
                                <option value="">None</option>
                                @foreach (var column in CurrentColumns)
                                {
                                    <option value="@column.Name">@column.Name (@column.Type)</option>
                                }
                            </select>
                        </label>
                    }

                    <label class="hunt-helper-field">
                        <span>Legend</span>
                        <select class="hunt-helper-input" @bind="_legend" @bind:after="RefreshPreviewAsync">
                            <option value="">Auto</option>
                            <option value="visible">Visible</option>
                            <option value="hidden">Hidden</option>
                        </select>
                    </label>

                    @if (UsesStacking)
                    {
                        <label class="hunt-helper-checkbox-row hunt-helper-field-wide">
                            <input type="checkbox" @bind="_isStacked" @bind:after="RefreshPreviewAsync" />
                            <span>Stack series</span>
                        </label>
                    }
                </div>
            </section>

            <section class="hunt-helper-section" aria-labelledby="viz-test-heading">
                <div class="hunt-helper-section-header">
                    <h3 id="viz-test-heading" class="hunt-helper-section-title">Preview card</h3>
                    <button class="hunt-btn hunt-btn-helper-secondary" @onclick="RefreshPreviewCardAsync" disabled="@_previewRunning">@(_previewRunning ? "Rendering…" : "Refresh")</button>
                </div>
                <div class="hunt-render-panel">
                    @if (!string.IsNullOrWhiteSpace(_previewMessage))
                    {
                        <div class="hunt-render-fallback">@_previewMessage</div>
                    }
                    else if (_previewChartOptions is not null)
                    {
                        <div class="hunt-chart-wrapper">
                            <div class="hunt-echart">
                                <Vizor.ECharts.EChart @key="_previewChartRenderKey" Width="100%" Height="260px" Options="@_previewChartOptions" />
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_previewWarning))
                        {
                            <p class="hunt-render-note">@_previewWarning</p>
                        }
                    }
                    else
                    {
                        <p class="hunt-helper-note">The graph preview updates automatically as the editor query or render settings change.</p>
                    }
                </div>
            </section>
        </div>

        <div class="hunt-helper-actions">
            <button class="hunt-btn hunt-btn-run" @onclick="ApplyAsync">Apply to editor</button>
            <button class="hunt-btn" @onclick="ApplyAndRunAsync">Apply &amp; refresh</button>
            <button class="hunt-btn hunt-btn-clear" @onclick="Close">Cancel</button>
        </div>
    </aside>
}

@code {
    [Parameter] public EventCallback<string> ApplyRequested { get; set; }
    [Parameter] public EventCallback<string> RefreshRequested { get; set; }
    [Parameter] public Func<Task<string>>? CurrentQueryTextProvider { get; set; }

    private IReadOnlyList<EditorTableMetadata> _tables = [];
    private bool _open;
    private RenderKind _kind = RenderKind.Barchart;
    private string _table = string.Empty;
    private string _title = string.Empty;
    private string _xColumn = string.Empty;
    private readonly List<string> _yColumns = [];
    private string _seriesColumn = string.Empty;
    private string _legend = string.Empty;
    private bool _isStacked;
    private bool _previewRunning;
    private string? _previewMessage;
    private string? _previewWarning;
    private Vizor.ECharts.ChartOptions? _previewChartOptions;
    private int _previewChartRenderKey;
    private CancellationTokenSource? _previewWatcherCts;
    private CancellationTokenSource? _previewRenderCts;
    private long _previewRequestId;
    private string? _lastPreviewSignature;

    private static readonly TimeSpan PreviewDebounceDelay = TimeSpan.FromMilliseconds(450);
    private static readonly TimeSpan PreviewEditorPollInterval = TimeSpan.FromMilliseconds(750);

    private static readonly RenderKind[] RenderKinds = [RenderKind.Timechart, RenderKind.Linechart, RenderKind.Barchart, RenderKind.Columnchart, RenderKind.Piechart, RenderKind.Areachart, RenderKind.Scatterchart, RenderKind.Card, RenderKind.Table];
    private IReadOnlyList<EditorTableMetadata> Tables => _tables;
    private EditorTableMetadata? SelectedTable => Tables.FirstOrDefault(table => string.Equals(table.Name, _table, StringComparison.OrdinalIgnoreCase));
    private IReadOnlyList<EditorColumnMetadata> CurrentColumns => SelectedTable?.Columns ?? [];
    private IEnumerable<EditorColumnMetadata> NumericColumns => CurrentColumns.Where(c => c.Type is "int" or "long" or "real" or "decimal" or "double");
    private IEnumerable<EditorColumnMetadata> XColumnChoices => _kind == RenderKind.Timechart ? CurrentColumns.Where(c => string.Equals(c.Type, "datetime", StringComparison.OrdinalIgnoreCase)) : CurrentColumns;
    private IEnumerable<EditorColumnMetadata> YColumnChoices => _kind == RenderKind.Piechart ? NumericColumns.Take(8) : NumericColumns;
    private bool UsesXColumn => _kind != RenderKind.Card && _kind != RenderKind.Table;
    private bool UsesYColumns => _kind != RenderKind.Card && _kind != RenderKind.Table;
    private bool UsesSeriesColumn => _kind is RenderKind.Timechart or RenderKind.Linechart or RenderKind.Barchart or RenderKind.Columnchart or RenderKind.Areachart or RenderKind.Scatterchart;
    private bool UsesStacking => _kind is RenderKind.Barchart or RenderKind.Columnchart or RenderKind.Areachart;
    private string XColumnLabel => _kind == RenderKind.Piechart ? "Category column" : "X-axis column";
    private string RenderClause => BuildRenderClause();

    protected override void OnInitialized()
    {
        _tables = Catalog.BuildEditorSchemaMetadata().Tables.OrderBy(static table => table.Name, StringComparer.OrdinalIgnoreCase).ToArray();
        _table = Tables.FirstOrDefault()?.Name ?? string.Empty;
        ResetColumnDefaults();
    }

    private async Task OpenAsync()
    {
        _open = true;
        _lastPreviewSignature = null;
        await InitializeFromHostQueryAsync();
        StartPreviewWatcher();
        SchedulePreviewCardRefresh();
    }

    private Task Close()
    {
        _open = false;
        StopPreviewWatcher();
        CancelPreviewRender();
        return Task.CompletedTask;
    }

    private async Task OnKindChanged()
    {
        ResetColumnDefaults();
        await RefreshPreviewAsync();
    }

    private async Task OnTableChanged(ChangeEventArgs args)
    {
        _table = args.Value?.ToString() ?? string.Empty;
        ResetColumnDefaults();
        await RefreshPreviewAsync();
    }


    private async Task InitializeFromHostQueryAsync()
    {
        if (CurrentQueryTextProvider is null)
        {
            return;
        }

        try
        {
            var currentText = await CurrentQueryTextProvider.Invoke();
            if (TryInferTableName(currentText, out var tableName)
                && !string.Equals(_table, tableName, StringComparison.OrdinalIgnoreCase))
            {
                _table = tableName;
                ResetColumnDefaults();
            }
        }
        catch (Exception ex)
        {
            SetPreviewWarning($"Could not read the current query from the editor: {ex.Message}");
        }
    }

    private void ResetColumnDefaults()
    {
        _xColumn = XColumnChoices.FirstOrDefault()?.Name ?? CurrentColumns.FirstOrDefault()?.Name ?? string.Empty;
        _yColumns.Clear();
        _yColumns.AddRange(YColumnChoices.Take(_kind == RenderKind.Piechart ? 1 : 2).Select(c => c.Name));
        _seriesColumn = string.Empty;
        if (!UsesStacking) _isStacked = false;
    }

    private bool IsYColumnSelected(string column) => _yColumns.Contains(column, StringComparer.OrdinalIgnoreCase);

    private async Task ToggleYColumn(string column, ChangeEventArgs args)
    {
        var isChecked = args.Value is bool value && value;
        if (isChecked && !IsYColumnSelected(column)) _yColumns.Add(column);
        if (!isChecked) _yColumns.RemoveAll(value => string.Equals(value, column, StringComparison.OrdinalIgnoreCase));
        await RefreshPreviewAsync();
    }

    private Task RefreshPreviewAsync()
    {
        SchedulePreviewCardRefresh();
        return Task.CompletedTask;
    }

    private async Task RefreshPreviewCardAsync()
    {
        _lastPreviewSignature = null;
        await InitializeFromHostQueryAsync();
        SchedulePreviewCardRefresh();
    }

    private void SchedulePreviewCardRefresh()
    {
        if (!_open)
        {
            return;
        }

        var requestId = Interlocked.Increment(ref _previewRequestId);
        _ = DebouncedPreviewCardRefreshAsync(requestId);
    }

    private async Task DebouncedPreviewCardRefreshAsync(long requestId)
    {
        try
        {
            await Task.Delay(PreviewDebounceDelay);
            if (!_open || requestId != Interlocked.Read(ref _previewRequestId))
            {
                return;
            }

            await InvokeAsync(async () =>
            {
                await RunPreviewCardAsync();
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException)
        {
            // Component disposal can race with the debounce timer.
        }
    }

    private async Task RunPreviewCardAsync()
    {
        if (CurrentQueryTextProvider is null)
        {
            SetPreviewWarning("Preview is unavailable because the current query cannot be read from this host.");
            return;
        }

        CancellationToken cancellationToken = default;

        try
        {
            var currentText = await CurrentQueryTextProvider.Invoke();
            var signature = $"{currentText}\n-- render --\n{RenderClause}";
            if (string.Equals(signature, _lastPreviewSignature, StringComparison.Ordinal))
            {
                return;
            }

            _lastPreviewSignature = signature;
            if (!RenderClauseQueryValidator.TryAppendOrReplaceTerminalRender(currentText, RenderClause, out var previewQuery, out var error))
            {
                SetPreviewWarning(error);
                return;
            }

            CancelPreviewRender();
            _previewRenderCts = new CancellationTokenSource();
            cancellationToken = _previewRenderCts.Token;
            _previewRunning = true;
            ClearPreviewCard();
            StateHasChanged();

            var rendered = await RenderedQueryRunner.RunAsync(previewQuery, cancellationToken);
            if (cancellationToken.IsCancellationRequested)
            {
                return;
            }

            if (!rendered.QueryResult.Success)
            {
                SetPreviewWarning(BuildDiagnosticPreviewMessage(rendered));
                return;
            }

            if (!rendered.Chart.CanRender)
            {
                SetPreviewWarning(rendered.Chart.Message ?? "The current query did not produce renderable chart data.");
                return;
            }

            _previewWarning = rendered.Chart.Warning;
            _previewChartOptions = EChartsOptionsBuilder.Build(rendered.Chart);
            _previewChartRenderKey++;
        }
        catch (OperationCanceledException)
        {
            // A newer query/render setting superseded this preview.
        }
        catch (Exception ex)
        {
            SetPreviewWarning($"Could not render preview: {ex.Message}");
        }
        finally
        {
            if (!cancellationToken.IsCancellationRequested)
            {
                _previewRunning = false;
            }
        }
    }

    private void SetPreviewWarning(string message)
    {
        ClearPreviewCard();
        _previewMessage = message;
        _previewRunning = false;
    }

    private static string BuildDiagnosticPreviewMessage(RenderedQueryResult rendered)
    {
        var diagnostics = rendered.QueryResult.Diagnostics.All;
        if (diagnostics.Count == 0)
        {
            return "The current query could not be rendered.";
        }

        return string.Join(" ", diagnostics.Take(3).Select(d => d.Message));
    }

    private void StartPreviewWatcher()
    {
        StopPreviewWatcher();
        _previewWatcherCts = new CancellationTokenSource();
        _ = WatchEditorQueryForPreviewChangesAsync(_previewWatcherCts.Token);
    }

    private async Task WatchEditorQueryForPreviewChangesAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(PreviewEditorPollInterval);
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (!_open || CurrentQueryTextProvider is null)
                {
                    continue;
                }

                try
                {
                    var currentText = await CurrentQueryTextProvider.Invoke();
                    var signature = $"{currentText}\n-- render --\n{RenderClause}";
                    if (!string.Equals(signature, _lastPreviewSignature, StringComparison.Ordinal))
                    {
                        SchedulePreviewCardRefresh();
                    }
                }
                catch (Exception) when (!cancellationToken.IsCancellationRequested)
                {
                    await InvokeAsync(() =>
                    {
                        SetPreviewWarning("Could not read the current query for preview.");
                        StateHasChanged();
                    });
                }
            }
        }
        catch (OperationCanceledException)
        {
            // Drawer closed or component disposed.
        }
    }

    private void StopPreviewWatcher()
    {
        _previewWatcherCts?.Cancel();
        _previewWatcherCts?.Dispose();
        _previewWatcherCts = null;
    }

    private void CancelPreviewRender()
    {
        _previewRenderCts?.Cancel();
        _previewRenderCts?.Dispose();
        _previewRenderCts = null;
    }

    private void ClearPreviewCard()
    {
        _previewMessage = null;
        _previewWarning = null;
        _previewChartOptions = null;
    }

    private async Task ApplyAsync()
    {
        await ApplyRequested.InvokeAsync(RenderClause);
        await Close();
    }

    private async Task ApplyAndRunAsync()
    {
        await ApplyRequested.InvokeAsync(RenderClause);
        await RefreshRequested.InvokeAsync(RenderClause);
        await Close();
    }

    private string BuildRenderClause()
    {
        var properties = new List<string>();
        Add(properties, "title", _title);
        if (UsesXColumn) Add(properties, "xcolumn", _xColumn);
        if (UsesYColumns && _yColumns.Count > 0) Add(properties, "ycolumns", string.Join(",", _yColumns));
        if (UsesSeriesColumn) Add(properties, "series", _seriesColumn);
        Add(properties, "legend", _legend);
        if (UsesStacking && _isStacked) Add(properties, "kind", "stacked");
        var kind = _kind.ToString().ToLowerInvariant();
        return properties.Count == 0 ? $"| render {kind}" : $"| render {kind} with ({string.Join(", ", properties)})";
    }


    private bool TryInferTableName(string queryText, out string tableName)
    {
        tableName = string.Empty;
        if (string.IsNullOrWhiteSpace(queryText) || Tables.Count == 0)
        {
            return false;
        }

        var normalizedQuery = queryText.Replace("\r", string.Empty, StringComparison.Ordinal);
        foreach (var table in Tables)
        {
            if (QueryReferencesTable(normalizedQuery, table.Name))
            {
                tableName = table.Name;
                return true;
            }
        }

        return false;
    }

    private static bool QueryReferencesTable(string queryText, string tableName)
    {
        var lines = queryText.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        foreach (var line in lines)
        {
            if (line.StartsWith("//", StringComparison.Ordinal) || line.StartsWith("--", StringComparison.Ordinal))
            {
                continue;
            }

            if (line.StartsWith(tableName, StringComparison.OrdinalIgnoreCase)
                && IsTableBoundary(line, tableName.Length))
            {
                return true;
            }
        }

        return queryText.Contains($"| {tableName}", StringComparison.OrdinalIgnoreCase)
            || queryText.Contains($";{tableName}", StringComparison.OrdinalIgnoreCase)
            || queryText.Contains($"; {tableName}", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsTableBoundary(string text, int index)
        => index >= text.Length || char.IsWhiteSpace(text[index]) || text[index] is '|' or ';';

    private static void Add(List<string> properties, string name, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value)) properties.Add($"{name}='{value.Trim().Replace("'", "\\'", StringComparison.Ordinal)}'");
    }

    private static string GetKindLabel(RenderKind kind) => kind.ToString();

    public void Dispose()
    {
        StopPreviewWatcher();
        CancelPreviewRender();
    }
}
