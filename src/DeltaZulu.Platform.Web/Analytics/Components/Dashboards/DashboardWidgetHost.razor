@namespace DeltaZulu.Platform.Web.Analytics.Components.Dashboards
@using DeltaZulu.Platform.Web.Analytics.Dashboards
@using DeltaZulu.Platform.Web.Analytics.Dashboards.Runtime

<article class="@WidgetClass"
         aria-label="@Widget.Title"
         data-dashboard-widget-id="@Widget.Id"
         data-layout-x="@Widget.Layout.X"
         data-layout-y="@Widget.Layout.Y"
         data-layout-width="@Widget.Layout.Width"
         data-layout-height="@Widget.Layout.Height"
         data-layout-min-width="@Widget.Layout.MinimumWidth"
         data-layout-min-height="@Widget.Layout.MinimumHeight">
    <header class="@HeaderClass">
        <div>
            <h2>@Widget.Title</h2>
        </div>
        <div class="dashboard-widget-actions" data-dashboard-drag-ignore="true">
            <div class="dashboard-widget-split" role="group" aria-label="@WidgetActionLabel">
                <MudButton Class="@RefreshButtonClass"
                           Variant="Variant.Outlined"
                           Size="Size.Small"
                           Disabled="@(!CanRunWidget)"
                           OnClick="RunAsync"
                           title="@RefreshTitle"
                           aria-label="@RefreshTitle">
                    <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" />
                </MudButton>
                @if (IsEditMode)
                {
                    <MudButton Class="dashboard-widget-action-button"
                               Variant="Variant.Outlined"
                               Size="Size.Small"
                               OnClick="EditAsync"
                               title="Edit widget"
                               aria-label="Edit widget">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                    </MudButton>
                    <MudButton Class="dashboard-widget-action-button dashboard-widget-action-button-last"
                               Variant="Variant.Outlined"
                               Size="Size.Small"
                               OnClick="DeleteAsync"
                               title="Delete widget"
                               aria-label="Delete widget">
                        <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                    </MudButton>
                }
            </div>
            @if (IsEditMode)
            {
                <span class="dashboard-widget-drag-handle" title="Drag from the title bar to move widget" aria-hidden="true">⋮⋮</span>
            }
        </div>
    </header>

    <section class="dashboard-widget-body">
        @if (Widget.Kind == DashboardWidgetKind.Markdown)
        {
            <DashboardMarkdownWidget Markdown="@Widget.QueryText" />
        }
        else if (Result is null || Result.Status == DashboardWidgetRunStatus.NotRun)
        {
            <div class="dashboard-widget-loading">
                <p>Waiting for automatic execution…</p>
            </div>
        }
        else if (Result.HasRenderableChart)
        {
            <DashboardChartWidget Result="Result" Height="@ChartHeight" />
        }
        else
        {
            <DashboardTableWidget Result="Result" />
        }
    </section>

    @if (IsEditMode)
    {
        <footer class="dashboard-widget-footer">
            <span>Layout: x=@Widget.Layout.X, y=@Widget.Layout.Y, w=@Widget.Layout.Width, h=@Widget.Layout.Height</span>
        </footer>

        <span class="dashboard-widget-resize-edge dashboard-widget-resize-edge-top"
              data-resize-edge="top"
              title="Resize widget from top"
              aria-hidden="true"></span>
        <span class="dashboard-widget-resize-edge dashboard-widget-resize-edge-right"
              data-resize-edge="right"
              title="Resize widget from right"
              aria-hidden="true"></span>
        <span class="dashboard-widget-resize-edge dashboard-widget-resize-edge-bottom"
              data-resize-edge="bottom"
              title="Resize widget from bottom"
              aria-hidden="true"></span>
        <span class="dashboard-widget-resize-edge dashboard-widget-resize-edge-left"
              data-resize-edge="left"
              title="Resize widget from left"
              aria-hidden="true"></span>
    }
</article>

@code {
    [Parameter, EditorRequired]
    public DashboardWidgetDefinition Widget { get; set; } = new();

    [Parameter]
    public DashboardWidgetRunResult? Result { get; set; }

    [Parameter]
    public bool IsEditMode { get; set; }

    [Parameter]
    public EventCallback<DashboardWidgetDefinition> RunWidget { get; set; }

    [Parameter]
    public EventCallback<DashboardWidgetDefinition> EditWidget { get; set; }

    [Parameter]
    public EventCallback<DashboardWidgetDefinition> DeleteWidget { get; set; }

    private bool CanRunWidget
        => Widget.Kind == DashboardWidgetKind.Query
            && HasExecutableSource
            && Result?.Status != DashboardWidgetRunStatus.Running;

    private bool HasExecutableSource
        => !string.IsNullOrWhiteSpace(Widget.QueryText)
            || !string.IsNullOrWhiteSpace(Widget.VisualizationId);

    private string RefreshTitle
        => CanRunWidget
            ? "Refresh widget"
            : "Widget has no executable query or visualization source.";

    private string WidgetClass
        => IsEditMode
            ? "dashboard-widget-host dashboard-widget-editable"
            : "dashboard-widget-host";

    private string HeaderClass
        => IsEditMode
            ? "dashboard-widget-header dashboard-widget-drag-surface"
            : "dashboard-widget-header";

    private string WidgetActionLabel
        => $"{Widget.Title} actions";

    private string RefreshButtonClass
        => IsEditMode
            ? "dashboard-widget-refresh-button"
            : "dashboard-widget-refresh-button dashboard-widget-action-button-last";

    private string ChartHeight
    {
        get
        {
            var rowHeight = Math.Max(1, Widget.Layout.Height) * 96;
            var fixedChrome = IsEditMode ? 150 : 102;
            return $"{Math.Max(180, rowHeight - fixedChrome)}px";
        }
    }

    private Task RunAsync()
        => RunWidget.HasDelegate && CanRunWidget
            ? RunWidget.InvokeAsync(Widget)
            : Task.CompletedTask;

    private Task EditAsync()
        => EditWidget.HasDelegate
            ? EditWidget.InvokeAsync(Widget)
            : Task.CompletedTask;

    private Task DeleteAsync()
        => DeleteWidget.HasDelegate
            ? DeleteWidget.InvokeAsync(Widget)
            : Task.CompletedTask;
}
