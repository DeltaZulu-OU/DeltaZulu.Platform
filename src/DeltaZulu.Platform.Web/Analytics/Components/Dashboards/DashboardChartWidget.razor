@namespace DeltaZulu.Platform.Web.Analytics.Components.Dashboards
@using DeltaZulu.Platform.Web.Analytics.Dashboards.Runtime
@inject IJSRuntime JS
@inject ILogger<DashboardChartWidget> Logger
@implements IAsyncDisposable

<div id="@_surfaceId" class="dashboard-chart-widget">
    @if (Result is null || Result.Status == DashboardWidgetRunStatus.NotRun)
    {
        <div class="dashboard-chart-state">
            <h3>No chart result</h3>
            <p>The widget is waiting for automatic execution.</p>
        </div>
    }
    else if (Result.Status == DashboardWidgetRunStatus.Running)
    {
        <div class="dashboard-chart-state">
            <h3>Running…</h3>
            <p>The query is executing.</p>
        </div>
    }
    else if (Result.Status == DashboardWidgetRunStatus.Cancelled)
    {
        <div class="dashboard-chart-state">
            <h3>Cancelled</h3>
            <p>The widget run was cancelled.</p>
        </div>
    }
    else if (Result.Status == DashboardWidgetRunStatus.Failed)
    {
        <div class="dashboard-chart-state dashboard-chart-error">
            <h3>Widget failed</h3>
            @foreach (var diagnostic in Result.Diagnostics)
            {
                <p>@diagnostic.Message</p>
            }
        </div>
    }
    else if (Result.RenderDirective is null)
    {
        <div class="dashboard-chart-state">
            <h3>No render directive</h3>
            <p>This widget returned tabular output rather than chart output.</p>
        </div>
    }
    else if (!Result.HasRenderableChart)
    {
        <div class="dashboard-chart-state">
            <h3>Chart not renderable</h3>
            <p>The render directive did not produce chart options.</p>
        </div>
    }
    else
    {
        <div class="dashboard-chart-surface" style="height:@Height">
            <Vizor.ECharts.EChart Options="Result.ChartOptions" Width="@Width" Height="@Height" />
        </div>
        @if (!string.IsNullOrWhiteSpace(Result.Chart?.Warning))
        {
            <p class="dashboard-chart-warning">@Result.Chart.Warning</p>
        }
    }
</div>

@code {
    private readonly string _surfaceId = $"dashboard-chart-{Guid.NewGuid():N}";
    private bool _resizeRegistered;

    [Parameter]
    public DashboardWidgetRunResult? Result { get; set; }

    [Parameter]
    public string Width { get; set; } = "640px";

    [Parameter]
    public string Height { get; set; } = "240px";

    private bool HasRenderableChart
        => Result?.HasRenderableChart == true;

    public async ValueTask DisposeAsync()
    {
        if (_resizeRegistered)
        {
            await JS.TryInvokeVoidAsync("huntingDashboardCharts.dispose", _surfaceId);
        }

        _resizeRegistered = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!HasRenderableChart || _resizeRegistered)
        {
            return;
        }

        _resizeRegistered = await JS.TryInvokeVoidAsync("huntingDashboardCharts.observe", _surfaceId);
    }
}
