@namespace DeltaZulu.Platform.Web.Analytics.Components.Dashboards
@using DeltaZulu.Platform.Web.Analytics.Dashboards

@if (IsOpen && Dashboard is not null)
{
    <div class="dashboard-editor-backdrop" role="presentation">
        <aside class="dashboard-editor-dialog dashboard-settings-dialog" role="dialog" aria-modal="true" aria-labelledby="dashboard-settings-editor-title">
            <header class="dashboard-editor-header">
                <div>
                    <p class="dashboard-eyebrow">Dashboard</p>
                    <h2 id="dashboard-settings-editor-title">Edit dashboard settings</h2>
                </div>
                <button class="hunt-btn" @onclick="CancelAsync">Close</button>
            </header>

            @if (_errors.Count > 0)
            {
                <div class="dashboard-editor-errors">
                    <ul>
                        @foreach (var error in _errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            <div class="dashboard-editor-form">
                <label>
                    <span>Name</span>
                    <input class="dashboard-editor-input" @bind="_name" />
                </label>

                <label>
                    <span>Description</span>
                    <input class="dashboard-editor-input" @bind="_description" />
                </label>

                <fieldset class="dashboard-editor-fieldset dashboard-editor-wide">
                    <legend>Auto-refresh</legend>
                    <label class="dashboard-editor-checkbox">
                        <input type="checkbox" @bind="_refreshEnabled" />
                        <span>Enable dashboard auto-refresh</span>
                    </label>
                    <label>
                        <span>Interval seconds</span>
                        <input class="dashboard-editor-input" type="number" min="1" disabled="@(!_refreshEnabled)" @bind="_refreshIntervalSeconds" />
                    </label>
                </fieldset>
            </div>

            <footer class="dashboard-editor-footer">
                <button class="hunt-btn" @onclick="CancelAsync">Cancel</button>
                <button class="hunt-btn dashboard-primary-action" @onclick="SaveAsync">Save dashboard</button>
            </footer>
        </aside>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public DashboardDefinition? Dashboard { get; set; }

    [Parameter]
    public EventCallback<DashboardDefinition> SaveDashboard { get; set; }

    [Parameter]
    public EventCallback Cancel { get; set; }

    private readonly List<string> _errors = [];
    private string _description = string.Empty;
    private string _loadedDashboardId = string.Empty;
    private string _name = string.Empty;
    private bool _loadedIsOpen;
    private bool _refreshEnabled;
    private int _refreshIntervalSeconds = 60;
    private DateTime _loadedUpdatedAtUtc;

    protected override void OnParametersSet()
    {
        if (!IsOpen || Dashboard is null)
        {
            _loadedDashboardId = string.Empty;
            _loadedUpdatedAtUtc = default;
            _loadedIsOpen = false;
            return;
        }

        if (IsSameLoadedDashboard())
        {
            return;
        }

        LoadDashboard(Dashboard);
    }

    private bool IsSameLoadedDashboard()
        => _loadedIsOpen
            && string.Equals(_loadedDashboardId, Dashboard?.Id, StringComparison.Ordinal)
            && _loadedUpdatedAtUtc == Dashboard?.UpdatedAtUtc;

    private void LoadDashboard(DashboardDefinition dashboard)
    {
        _loadedIsOpen = true;
        _loadedDashboardId = dashboard.Id;
        _loadedUpdatedAtUtc = dashboard.UpdatedAtUtc;
        _errors.Clear();
        _name = dashboard.Name;
        _description = dashboard.Description ?? string.Empty;
        _refreshEnabled = dashboard.Refresh.Enabled;
        _refreshIntervalSeconds = dashboard.Refresh.IntervalSeconds ?? 60;
    }

    private async Task SaveAsync()
    {
        if (Dashboard is null)
        {
            return;
        }

        _errors.Clear();

        DashboardRefreshPolicy refresh;
        try
        {
            refresh = _refreshEnabled
                ? DashboardRefreshPolicy.Every(_refreshIntervalSeconds)
                : DashboardRefreshPolicy.Manual();
        }
        catch (ArgumentOutOfRangeException ex)
        {
            _errors.Add(ex.Message);
            return;
        }

        var updated = Dashboard with
        {
            Name = _name.Trim(),
            Description = string.IsNullOrWhiteSpace(_description) ? null : _description.Trim(),
            Refresh = refresh,
            UpdatedAtUtc = DateTime.UtcNow
        };

        var validationErrors = DashboardModelValidator.Validate(updated);
        if (validationErrors.Count > 0)
        {
            _errors.AddRange(validationErrors);
            return;
        }

        await SaveDashboard.InvokeAsync(updated);
    }

    private async Task CancelAsync()
    {
        await Cancel.InvokeAsync();
    }
}
