@namespace DeltaZulu.Platform.Web.Analytics.Components.Dashboards
@using DeltaZulu.Platform.Domain.Analytics.Visualizations
@using DeltaZulu.Platform.Web.Analytics.Dashboards
@using DeltaZulu.Platform.Web.Analytics.Services
@inject ILogger<DashboardWidgetEditor> Logger
@inject QueryLibraryService QueryLibrary
@inject VisualizationLibraryService VisualizationLibrary
@inject WidgetEditorInterop WidgetEditor
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (IsOpen)
{
    <div class="dashboard-editor-backdrop" role="presentation">
        <section class="dashboard-editor-dialog" role="dialog" aria-modal="true" aria-labelledby="dashboard-widget-editor-title">
            <header class="dashboard-editor-header">
                <div>
                    <p class="dashboard-eyebrow">Widget</p>
                    <h2 id="dashboard-widget-editor-title">@Title</h2>
                </div>
                <button class="hunt-btn" @onclick="CancelAsync">Close</button>
            </header>

            @if (_errors.Count > 0)
            {
                <div class="dashboard-editor-errors">
                    <ul>
                        @foreach (var error in _errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            <div class="dashboard-editor-form">
                <label>
                    <span>Title</span>
                    <input class="dashboard-editor-input" @bind="_title" />
                </label>

                <label>
                    <span>Kind</span>
                    <select class="dashboard-editor-input" value="@KindValue" @onchange="KindChangedAsync">
                        <option value="@DashboardWidgetKind.Query">Query</option>
                        <option value="@DashboardWidgetKind.Markdown">Markdown</option>
                    </select>
                </label>

                @if (_kind == DashboardWidgetKind.Query)
                {
                    <label>
                        <span>Source</span>
                        <select class="dashboard-editor-input" value="@QuerySourceValue" @onchange="QuerySourceChangedAsync">
                            <option value="@WidgetQuerySource.QueryText">Query text</option>
                            <option value="@WidgetQuerySource.Visualization">Saved visualization</option>
                        </select>
                    </label>
                }

                @if (IsVisualizationSource)
                {
                    <div class="dashboard-editor-wide">
                        <label>
                            <span>Saved visualization</span>
                            <select class="dashboard-editor-input" @bind="_selectedVisualizationId" disabled="@_loadingVisualizations">
                                <option value="">Select a saved visualization</option>
                                @foreach (var visualization in _visualizations)
                                {
                                    <option value="@visualization.Id">
                                        @GetVisualizationDisplayName(visualization)
                                    </option>
                                }
                            </select>
                        </label>

                        @if (_loadingVisualizations)
                        {
                            <p class="dashboard-editor-mode">Loading saved visualizations…</p>
                        }
                        else if (_visualizations.Count == 0)
                        {
                            <p class="dashboard-editor-mode">No saved visualizations are available yet.</p>
                        }
                    </div>
                }

                @if (ShouldShowTextEditor)
                {
                    <div class="dashboard-editor-wide">
                        <div class="dashboard-editor-label-row">
                            <span>@EditorTextLabel</span>
                            <span class="hunt-toolbar-actions">
                                @if (CanUseVisualizationWizard)
                                {
                                    <VisualizationHelperDrawer ApplyRequested="ApplyVisualizationRenderAsync" RefreshRequested="RefreshVisualizationRenderAsync" CurrentQueryTextProvider="GetQueryTextAsync" />
                                }
                            </span>
                        </div>

                        <div class="dashboard-editor-text-shell">
                            <div id="@_editorElementId"
                                 class="@EditorHostClass"
                                 aria-hidden="@(!_monacoReady)"></div>

                            @if (!_monacoReady)
                            {
                                <textarea class="dashboard-editor-textarea"
                                          rows="10"
                                          @bind="_queryText"
                                          @bind:event="oninput"></textarea>
                            }
                        </div>
                    </div>
                }
            </div>

            <footer class="dashboard-editor-footer">
                <button class="hunt-btn" @onclick="CancelAsync">Cancel</button>
                <button class="hunt-btn dashboard-primary-action" @onclick="SaveAsync">Save widget</button>
            </footer>
        </section>
    </div>
}

@code {
    private enum WidgetQuerySource
    {
        QueryText,
        Visualization
    }

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public DashboardWidgetDefinition? Widget { get; set; }

    [Parameter]
    public DashboardLayout SuggestedLayout { get; set; } = new();

    [Parameter]
    public EventCallback<DashboardWidgetDefinition> SaveWidget { get; set; }

    [Parameter]
    public EventCallback Cancel { get; set; }

    private readonly List<string> _errors = [];
    private readonly string _editorElementId = $"dashboard-widget-editor-{Guid.NewGuid():N}";
    private string _id = string.Empty;
    private string _queryText = string.Empty;
    private string _markdownText = string.Empty;
    private string _title = string.Empty;
    private DashboardWidgetKind _kind = DashboardWidgetKind.Query;
    private DashboardLayout _layout = new();
    private WidgetQuerySource _querySource = WidgetQuerySource.QueryText;
    private string? _selectedVisualizationId;
    private IReadOnlyList<VisualizationRecord> _visualizations = [];
    private IReadOnlyDictionary<string, string> _savedQueryNames = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
    private bool _editorInitialized;
    private bool _editorNeedsInitialize;
    private bool _loadedIsOpen;
    private bool _loadingVisualizations;
    private bool _monacoReady;
    private bool _visualizationsLoaded;
    private bool _visualizationsNeedLoad;
    private string? _loadedWidgetId;

    private string Title
        => Widget is null ? "Add widget" : "Edit widget";

    private string EditorTextLabel
        => _kind == DashboardWidgetKind.Markdown ? "Markdown content" : "Query text";

    private string EditorLanguage
        => _kind == DashboardWidgetKind.Markdown ? "markdown" : "kql";

    private bool IsVisualizationSource
        => _kind == DashboardWidgetKind.Query && _querySource == WidgetQuerySource.Visualization;

    private bool ShouldShowTextEditor
        => !IsVisualizationSource;

    private bool CanUseVisualizationWizard
        => _kind == DashboardWidgetKind.Query && _querySource == WidgetQuerySource.QueryText;

    private string KindValue
        => _kind.ToString();

    private string QuerySourceValue
        => _querySource.ToString();

    public ValueTask DisposeAsync()
    {
        MarkEditorDisposed();
        return ValueTask.CompletedTask;
    }

    protected override void OnParametersSet()
    {
        if (!IsOpen)
        {
            _loadedIsOpen = false;
            _loadedWidgetId = null;
            _visualizationsNeedLoad = false;
            return;
        }

        var widgetId = Widget?.Id ?? "<new>";
        if (_loadedIsOpen && string.Equals(_loadedWidgetId, widgetId, StringComparison.Ordinal))
        {
            return;
        }

        _loadedIsOpen = true;
        _loadedWidgetId = widgetId;
        _errors.Clear();
        _monacoReady = false;
        _editorNeedsInitialize = true;
        _visualizationsNeedLoad = true;

        if (Widget is not null)
        {
            _id = Widget.Id;
            _title = Widget.Title;
            _kind = Widget.Kind;
            _queryText = Widget.QueryText;
            _layout = Widget.Layout;
            _selectedVisualizationId = NormalizeOptionalText(Widget.VisualizationId);
            _querySource = _kind == DashboardWidgetKind.Query && !string.IsNullOrWhiteSpace(_selectedVisualizationId)
                ? WidgetQuerySource.Visualization
                : WidgetQuerySource.QueryText;
            return;
        }

        _id = Guid.NewGuid().ToString("N");
        _title = "New widget";
        _kind = DashboardWidgetKind.Query;
        _querySource = WidgetQuerySource.QueryText;
        _selectedVisualizationId = null;
        _queryText = """
ProcessEvent
| summarize Count = count() by AccountName
| render barchart xcolumn=AccountName ycolumns=Count title='Events by account'
""";
        _markdownText = """
# This is a headline

Lorem *ipsum* **dolor** sit amet.
""";
        _layout = SuggestedLayout;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsOpen)
        {
            if (_editorInitialized)
            {
                await DisposeEditorWithJsAsync();
            }

            return;
        }

        if (_visualizationsNeedLoad && _kind == DashboardWidgetKind.Query)
        {
            _visualizationsNeedLoad = false;
            await LoadVisualizationsAsync();
            await RequestRenderAsync();
        }
        else if (_visualizationsNeedLoad)
        {
            _visualizationsNeedLoad = false;
        }

        if (!ShouldShowTextEditor)
        {
            if (_editorInitialized)
            {
                await DisposeEditorWithJsAsync();
            }

            return;
        }

        if (!_editorNeedsInitialize)
        {
            return;
        }

        _editorNeedsInitialize = false;

        await RunEditorInteropAsync(async () =>
        {
            _monacoReady = await WidgetEditor.InitializeAsync(
                _editorElementId,
                EditorLanguage == "kql" ? _queryText : _markdownText,
                EditorLanguage);
            _editorInitialized = _monacoReady;
        }, "initialize");

        await RequestRenderAsync();
    }

    private async Task KindChangedAsync(ChangeEventArgs args)
    {
        var nextKind = Enum.TryParse<DashboardWidgetKind>(args.Value?.ToString(), out var parsed)
            ? parsed
            : DashboardWidgetKind.Query;

        if (_kind == nextKind)
        {
            return;
        }

        if (ShouldShowTextEditor)
        {
            _queryText = await GetQueryTextAsync();
        }

        _kind = nextKind;

        if (_kind != DashboardWidgetKind.Query)
        {
            _querySource = WidgetQuerySource.QueryText;
            _selectedVisualizationId = null;
        }

        if (ShouldShowTextEditor)
        {
            if (_editorInitialized)
            {
                await SetEditorLanguageAsync();
            }
            else
            {
                _editorNeedsInitialize = true;
                _monacoReady = false;
            }
        }
        else if (_editorInitialized)
        {
            await DisposeEditorWithJsAsync();
        }

        await RequestRenderAsync();
    }

    private async Task QuerySourceChangedAsync(ChangeEventArgs args)
    {
        var nextSource = Enum.TryParse<WidgetQuerySource>(args.Value?.ToString(), out var parsed)
            ? parsed
            : WidgetQuerySource.QueryText;

        if (_querySource == nextSource)
        {
            return;
        }

        if (ShouldShowTextEditor)
        {
            _queryText = await GetQueryTextAsync();
        }

        _querySource = nextSource;
        _errors.Clear();

        if (IsVisualizationSource)
        {
            if (!_visualizationsLoaded)
            {
                await LoadVisualizationsAsync();
            }

            if (_editorInitialized)
            {
                await DisposeEditorWithJsAsync();
            }
        }
        else
        {
            _selectedVisualizationId = null;
            _editorNeedsInitialize = true;
            _monacoReady = false;
        }

        await RequestRenderAsync();
    }

    private async Task ApplyVisualizationRenderAsync(string renderClause)
    {
        if (!CanUseVisualizationWizard)
        {
            return;
        }

        var currentText = await GetQueryTextAsync();
        if (!RenderClauseQueryValidator.TryAppendOrReplaceTerminalRender(
            currentText,
            renderClause,
            out var nextQuery,
            out var error))
        {
            _errors.Add(error);
            await RequestRenderAsync();
            return;
        }

        _queryText = nextQuery;

        if (_editorInitialized)
        {
            await SetDashboardEditorValueAsync(nextQuery);
        }

        await RequestRenderAsync();
    }

    private async Task SetDashboardEditorValueAsync(string value)
        => await RunEditorInteropAsync(
            () => JS.InvokeVoidAsync("huntingDashboardWidgetEditor.setValue", _editorElementId, value).AsTask(),
            "setValue", disposeOnJsError: false);

    private async Task RefreshVisualizationRenderAsync(string renderClause)
        => await RequestRenderAsync();

    private async Task SaveAsync()
    {
        _errors.Clear();

        var queryText = ShouldShowTextEditor
            ? (await GetQueryTextAsync()).Trim()
            : string.Empty;
        var visualizationId = IsVisualizationSource
            ? NormalizeOptionalText(_selectedVisualizationId)
            : null;

        var widget = new DashboardWidgetDefinition
        {
            Id = _id,
            Title = _title.Trim(),
            Kind = _kind,
            VisualizationId = visualizationId,
            QueryText = queryText,
            Layout = _layout,
            Refresh = DashboardRefreshPolicy.Manual()
        };

        var validationErrors = DashboardModelValidator.Validate(new DashboardDefinition
        {
            Id = "widget-editor-validation",
            Name = "Widget editor validation",
            Refresh = DashboardRefreshPolicy.Manual(),
            Widgets = [widget],
            CreatedAtUtc = DateTime.UtcNow,
            UpdatedAtUtc = DateTime.UtcNow
        });

        if (validationErrors.Count > 0)
        {
            _errors.AddRange(validationErrors);
            return;
        }

        await SaveWidget.InvokeAsync(widget);
    }

    private async Task LoadVisualizationsAsync()
    {
        _loadingVisualizations = true;

        try
        {
            var savedQueries = await QueryLibrary.ListSavedQueriesAsync();
            _savedQueryNames = savedQueries.ToDictionary(
                query => query.Id,
                query => string.IsNullOrWhiteSpace(query.Name) ? query.Id : query.Name,
                StringComparer.OrdinalIgnoreCase);
            _visualizations = await VisualizationLibrary.ListVisualizationsAsync();
            _visualizationsLoaded = true;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load saved visualizations for the dashboard widget editor.");
            _errors.Add("Could not load saved visualizations.");
            _savedQueryNames = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            _visualizations = [];
            _visualizationsLoaded = false;
        }
        finally
        {
            _loadingVisualizations = false;
        }
    }

    private string GetVisualizationDisplayName(VisualizationRecord visualization)
    {
        var queryName = GetSavedQueryDisplayName(visualization.QueryId);
        return $"{visualization.Name} ({visualization.Kind}, Query: {queryName})";
    }

    private string GetSavedQueryDisplayName(string queryId)
    {
        if (string.IsNullOrWhiteSpace(queryId))
        {
            return "(none)";
        }

        return _savedQueryNames.TryGetValue(queryId, out var name)
            ? name
            : ShortId(queryId);
    }

    private async Task SetEditorLanguageAsync()
        => await RunEditorInteropAsync(
            () => WidgetEditor.SetLanguageAsync(_editorElementId, EditorLanguage).AsTask(),
            "setLanguage", disposeOnJsError: false);

    private async Task<string> GetQueryTextAsync()
    {
        if (!_editorInitialized)
        {
            return _queryText;
        }

        await RunEditorInteropAsync(async () =>
        {
            _queryText = await WidgetEditor.GetValueAsync(_editorElementId);
        }, "getValue", disposeOnJsError: false);

        return _queryText;
    }

    private async Task CancelAsync()
    {
        if (_editorInitialized)
        {
            await DisposeEditorWithJsAsync();
        }

        await Cancel.InvokeAsync();
    }

    private async Task DisposeEditorWithJsAsync()
    {
        if (!_editorInitialized)
        {
            return;
        }

        MarkEditorDisposed();
        await WidgetEditor.TryDisposeAsync(_editorElementId);
    }

    private async Task RequestRenderAsync()
    {
        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (ObjectDisposedException ex)
        {
            LogEditorInteropLifecycleDebug(ex, "render");
        }
        catch (InvalidOperationException ex)
        {
            LogEditorInteropLifecycleDebug(ex, "render");
        }
    }

    private void MarkEditorDisposed()
    {
        _editorInitialized = false;
        _monacoReady = false;
    }

    private static string? NormalizeOptionalText(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static string ShortId(string id)
    {
        if (string.IsNullOrWhiteSpace(id))
        {
            return "(none)";
        }

        return id.Length <= 8 ? id : id[..8];
    }

    private async Task RunEditorInteropAsync(Func<Task> action, string operation, bool disposeOnJsError = true)
    {
        try
        {
            await action();
        }
        catch (JSException ex) when (!disposeOnJsError)
        {
            LogEditorInteropLifecycleDebug(ex, operation);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or OperationCanceledException
                                       or JSException or ObjectDisposedException or InvalidOperationException)
        {
            LogEditorInteropLifecycleDebug(ex, operation);
            MarkEditorDisposed();
        }
    }

    private void LogEditorInteropLifecycleDebug(Exception exception, string operation)
        => Logger.LogDebug(
            exception,
            "Dashboard widget editor JS interop {Operation} was skipped or cancelled for {EditorElementId}.",
            operation,
            _editorElementId);

    private string EditorHostClass => _monacoReady
        ? "dashboard-editor-monaco"
        : "dashboard-editor-monaco dashboard-editor-monaco--initializing";
}
