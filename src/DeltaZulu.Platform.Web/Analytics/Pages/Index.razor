    private const int EditorInitializationMaxAttempts = 3;
    private static readonly TimeSpan EditorInitializationRetryDelay = TimeSpan.FromMilliseconds(250);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync(
            "huntingLayout.initVerticalSplitter",
            "hunt-page-content",
            "hunt-editor-panel",
            "hunt-results-panel",
            "hunt-panel-splitter");

        if (!_editorInitialized)
        {
            var schema = Catalog.BuildEditorSchemaMetadata();
            var editorSeed = await GetCachedEditorTextForInitializationAsync();
            var initialized = await TryInitializeEditorAsync(schema, editorSeed);
            if (!initialized)
            {
                return;
            }

            _editorInitialized = true;
        }

        if (_activeTab != ResultTab.Render || !HasRenderOutput || _chartOptions is null)
        {
            return;
        }

        var rect = await _chartHost.GetBoundingClientRectAsync(JS);
        var width = rect.Width;
        var height = rect.Height;
        var widthPx = Math.Max(320, (int)Math.Round(width, MidpointRounding.AwayFromZero));
        var heightPx = Math.Max(320, (int)Math.Round(height, MidpointRounding.AwayFromZero));
        if (widthPx == _lastMeasuredChartWidthPx && heightPx == _lastMeasuredChartHeightPx)
        {
            return;
        }

        _lastMeasuredChartWidthPx = widthPx;
        _lastMeasuredChartHeightPx = heightPx;
        _chartWidth = $"{widthPx}px";
        _chartHeight = $"{heightPx}px";
        _chartRenderKey++;
        StateHasChanged();
    }

    private async Task<string> GetCachedEditorTextForInitializationAsync()
    {
        if (_editorInitialized)
        {
            try
            {
                var currentValue = await LanguageService.GetEditorValueAsync();
                if (!string.IsNullOrEmpty(currentValue))
                {
                    _cachedEditorText = currentValue;
                    _kql = currentValue;
                }
            }
            catch
            {
                // Keep existing cache if interop is unavailable; init retry path handles surfacing failures.
            }
        }

        return string.IsNullOrEmpty(_cachedEditorText) ? _kql : _cachedEditorText;
    }

    private async Task<bool> TryInitializeEditorAsync(
       DeltaZulu.Platform.Domain.Analytics.Schema.EditorSchemaMetadata schema,
       string initialValue)
    {
        Exception? lastException = null;

        for (var attempt = 1; attempt <= EditorInitializationMaxAttempts; attempt++)
        {
            try
            {
                await LanguageService.InitializeKqlEditorAsync(
                    "kql-editor",
                    initialValue,
                    RunQueryFromEditor,
                    schema);

                return true;
            }
            catch (Exception ex)
            {
                lastException = ex;
                if (attempt < EditorInitializationMaxAttempts)
                {
                    await Task.Delay(EditorInitializationRetryDelay);
                }
            }
        }

        Snackbar.Add(
            $"Could not initialize the KQL editor after {EditorInitializationMaxAttempts} attempts. {lastException?.Message}",
            Severity.Error);

        return false;
    }

    public async ValueTask DisposeAsync()
    {
        EditorBus.InsertRequested -= HandleInsertRequested;
        EditorBus.ReplaceRequested -= HandleReplaceRequested;
        _cts.Cancel();
        _cts.Dispose();
        await LanguageService.DisposeAsync();
    }

    private async Task InsertHelperQueryAsync(string queryText)
    {
        if (string.IsNullOrWhiteSpace(queryText))
        {
            return;
        }

        var updated = queryText.Trim();
        _kql = updated;
        _cachedEditorText = updated;
        await LanguageService.SetEditorValueAsync(updated);
    }

    private async Task AppendHelperQueryAsync(string queryText)
    {
        if (string.IsNullOrWhiteSpace(queryText))
        {
            return;
        }

        var current = await GetCurrentEditorTextAsync();
        var updated = string.IsNullOrWhiteSpace(current)
            ? queryText.Trim()
            : $"{current.TrimEnd()}{Environment.NewLine}{Environment.NewLine}{queryText.Trim()}";

        _kql = updated;
        _cachedEditorText = updated;
        await LanguageService.SetEditorValueAsync(updated);
    }
    private async Task LoadQueryIntoEditor(string queryText)
    {
        _kql = queryText;
        _cachedEditorText = queryText;
        await LanguageService.SetEditorValueAsync(queryText);
    }
