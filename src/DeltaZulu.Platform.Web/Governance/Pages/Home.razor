@namespace DeltaZulu.Platform.Web.Governance.Components.Pages
@page "/governance"
@using MudBlazor

<PageTitle>Detection Content</PageTitle>

<DzPageHeader Title="Detection Content"
              TitleTypo="Typo.h4"
              Description="Edit detection content, prove it is safe, accept it into history." />

<MudGrid Spacing="3">
    <MudItem xs="12" md="4">
        <DzPanel Eyebrow="Content" Title="Detections" Class="dz-panel--full-height">
            <MudText Typo="Typo.body2" Class="text-secondary">
                Manage detection content packages and open changes.
            </MudText>
            <MudButton Href="/governance/detections"
                       Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Size="Size.Small"
                       Class="mt-3"
                       StartIcon="@Icons.Material.Outlined.Radar">
                Open detections
            </MudButton>
        </DzPanel>
    </MudItem>

    <MudItem xs="12" md="4">
        <DzPanel Eyebrow="Workflow" Title="Changes" Class="dz-panel--full-height">
            <MudText Typo="Typo.body2" Class="text-secondary">
                Review draft content, validation checks, approvals, and acceptance gates.
            </MudText>
            <MudButton Href="/governance/changes"
                       Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Size="Size.Small"
                       Class="mt-3"
                       StartIcon="@Icons.Material.Outlined.Assignment">
                Open changes
            </MudButton>
        </DzPanel>
    </MudItem>

    <MudItem xs="12" md="4">
        <DzPanel Eyebrow="History" Title="Accepted versions" Class="dz-panel--full-height">
            <MudText Typo="Typo.body2" Class="text-secondary">
                Compare accepted versions and restore previous content safely.
            </MudText>
            <MudButton Href="/governance/history"
                       Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Size="Size.Small"
                       Class="mt-3"
                       StartIcon="@Icons.Material.Outlined.History">
                Open history
            </MudButton>
        </DzPanel>
    </MudItem>
</MudGrid>
