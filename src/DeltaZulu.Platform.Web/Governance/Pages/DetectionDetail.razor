@namespace DeltaZulu.Platform.Web.Governance.Components.Pages
@page "/governance/detections/{Id}"
@using DeltaZulu.Platform.Web.Governance.Components.Shared
@using MudBlazor
@rendermode InteractiveServer
@using DeltaZulu.Platform.Application.Governance.Services
@using DeltaZulu.Platform.Domain.Governance.Detections
@using DeltaZulu.Platform.Domain.Governance.Changes
@using DeltaZulu.Platform.Domain.Governance.Identifiers
@using DeltaZulu.Platform.Domain.Governance.Common
@using DeltaZulu.Platform.Domain.Governance.Enums
@using DeltaZulu.Platform.Web.Governance.Services
@inject DetectionContentService DetectionService
@inject ChangeService ChangeService
@inject VersionService VersionService
@inject AcceptedContentReadService AcceptedContentReadService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject PocUserContext UserContext

<PageTitle>Detection — @(_detection?.Title ?? "Loading")</PageTitle>

@if (_detection is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2" />

    <MudGrid Spacing="3">
        <MudItem xs="12" md="8">
            <DzPageHeader Eyebrow="Detection"
                          Title="@_detection.Title"
                          Description="@_detection.Summary">
                <Metadata>
                    <DzMetaChip Kind="file">@_detection.Slug</DzMetaChip>
                    <StatusChip Lifecycle="_detection.Lifecycle" />
                </Metadata>
                <Actions>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Outlined.Add" OnClick="OpenChangeDialog">
                        Open proposal
                    </MudButton>
                    @if (_detection.Lifecycle == DetectionLifecycle.Accepted)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Outlined.Archive" OnClick="DeprecateDetection">
                            Deprecate
                        </MudButton>
                    }
                </Actions>
            </DzPageHeader>
        </MudItem>
        <MudItem xs="12" md="4">
            <DzPanel Eyebrow="Details" Class="dz-panel--full-height">
                <DzDetailList>
                    <DzDetailItem Label="Status">
                        <StatusChip Lifecycle="_detection.Lifecycle" />
                    </DzDetailItem>

                    <DzDetailItem Label="Latest version">
                        @if (_latestVersion is not null)
                        {
                            <div class="d-flex align-center gap-2 flex-wrap">
                                <DzMetaChip Kind="version">@_latestVersion.DisplayVersion</DzMetaChip>
                                <DzActionLink OnClick="@(() => Nav.NavigateTo($"/governance/history/{_latestVersion.Id}"))">
                                    Compare
                                </DzActionLink>
                            </div>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Class="text-secondary">None</MudText>
                        }
                    </DzDetailItem>

                    <DzDetailItem Label="Active proposals" Value="@_activeChangeCount.ToString()" />

                    <DzDetailItem Label="Updated">
                        <MudText Typo="Typo.body2" Class="dz-config-value dz-config-value--mono">
                            @_detection.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss")
                        </MudText>
                    </DzDetailItem>
                </DzDetailList>
            </DzPanel>
        </MudItem>
    </MudGrid>

    <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" Class="mt-4">
        <MudTabPanel Text="Versions" BadgeData="@_versions.Count" BadgeColor="Color.Secondary">
            <DzTabBody>
                @if (_versions.Count == 0)
                {
                    <DzEmptyState Title="No accepted versions yet."
                                  Description="Accept a proposal to create the first version."
                                  Icon="@Icons.Material.Outlined.History" />
                }
                else
                {
                    <DzTableShell>
                        <MudTable Items="_versions" Dense="true" T="DetectionVersion" Elevation="0">
                            <HeaderContent>
                                <MudTh>Version</MudTh>
                                <MudTh>Summary</MudTh>
                                <MudTh>Profile</MudTh>
                                <MudTh>Accepted</MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Version">
                                    <DzMetaChip Kind="version">@context.DisplayVersion</DzMetaChip>
                                </MudTd>
                                <MudTd DataLabel="Summary">@context.ChangeSummary</MudTd>
                                <MudTd DataLabel="Profile">
                                    <DzMetaChip Kind="workflow">@context.WorkflowProfile</DzMetaChip>
                                </MudTd>
                                <MudTd DataLabel="Accepted"><MudText Typo="Typo.caption">@context.AcceptedAt.ToString("yyyy-MM-dd HH:mm")</MudText></MudTd>
                                <MudTd DataLabel="Actions">
                                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Secondary"
                                               OnClick="@(() => Nav.NavigateTo($"/governance/history/{context.Id}"))">
                                        Compare / restore
                                    </MudButton>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </DzTableShell>
                }
            </DzTabBody>
        </MudTabPanel>

        <MudTabPanel Text="Proposal history" BadgeData="@_changes.Count" BadgeColor="Color.Secondary">
            <DzTabBody>
                @if (_changes.Count == 0)
                {
                    <DzEmptyState Title="No proposals linked to this detection."
                                  Description="Open a proposal to start editing this detection."
                                  Icon="@Icons.Material.Outlined.WorkHistory" />
                }
                else
                {
                    <DzTableShell>
                        <MudTable Items="_changes" Dense="true" Hover="true"
                                  OnRowClick="@(args => Nav.NavigateTo($"/governance/proposals/{args.Item!.Id}"))"
                                  T="ChangeRequest" RowClass="cursor-pointer" Elevation="0">
                            <HeaderContent>
                                <MudTh>Key</MudTh>
                                <MudTh>Title</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Updated</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Key"><code>@context.Key</code></MudTd>
                                <MudTd DataLabel="Title">@context.Title</MudTd>
                                <MudTd DataLabel="Status"><StatusChip ChangeStatus="context.Status" /></MudTd>
                                <MudTd DataLabel="Updated"><MudText Typo="Typo.caption">@context.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</MudText></MudTd>
                            </RowTemplate>
                        </MudTable>
                    </DzTableShell>
                }
            </DzTabBody>
        </MudTabPanel>

        <MudTabPanel Text="Related issues" BadgeColor="Color.Info">
            <DzTabBody>
                <DzEmptyState Title="Issues are linked through proposals."
                              Description="Open a proposal to see its linked issue."
                              Icon="@Icons.Material.Outlined.Link" />
            </DzTabBody>
        </MudTabPanel>

        <MudTabPanel Text="Files">
            <DzTabBody>
                @if (_acceptedFiles.Count == 0)
                {
                    <DzEmptyState Title="No accepted content yet."
                                  Description="Accepted files will appear after the first approved proposal is accepted."
                                  Icon="@Icons.Material.Outlined.FolderOff" />
                }
                else
                {
                    <MudList T="string" Dense="true" Class="dz-card-list">
                        @foreach (var file in _acceptedFiles)
                        {
                            <MudListItem T="string">
                                <MudButton Variant="Variant.Text"
                                           Color="Color.Secondary"
                                           FullWidth="true"
                                           Class="justify-start"
                                           StartIcon="@Icons.Material.Filled.InsertDriveFile"
                                           OnClick="@(() => OpenAcceptedFileAsync(file))">
                                    <code>@file.RepositoryPath</code>
                                </MudButton>
                            </MudListItem>
                        }
                    </MudList>
                }
            </DzTabBody>
        </MudTabPanel>
    </MudTabs>

    
    <DzCodeDrawer Open="_fileDrawerOpen"
                  OpenChanged="OnFileDrawerOpenChanged"
                  Title="Accepted file"
                  Subtitle="@(_selectedAcceptedFile?.LogicalPath ?? _selectedAcceptedFilePath)"
                  Content="@_selectedAcceptedFile?.Content"
                  CopyText="@_selectedAcceptedFile?.Content"
                  ShowCopyButton="@(_selectedAcceptedFile is { IsBinary: false } && !string.IsNullOrEmpty(_selectedAcceptedFile.Content))"
                  IsLoading="_fileLoading"
                  ErrorMessage="@_fileLoadError"
                  IsBinary="@(_selectedAcceptedFile?.IsBinary ?? false)"
                  EmptyTitle="No file selected."
                  EmptyDescription="Select an accepted file to preview its content."
                  AriaLabel="Accepted file drawer" />
}

@code {
    [Parameter] public string Id { get; set; } = null!;

    private Detection? _detection;
    private DetectionVersion? _latestVersion;
    private int _activeChangeCount;
    private List<DetectionVersion> _versions = [];
    private List<ChangeRequest> _changes = [];
    private List<AcceptedContentFileSummary> _acceptedFiles = [];
    private AcceptedContentFileDetails? _selectedAcceptedFile;
    private string? _selectedAcceptedFilePath;
    private string? _fileLoadError;
    private bool _fileDrawerOpen;
    private bool _fileLoading;
    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnParametersSetAsync()
    {
        if (!Guid.TryParse(Id, out var guid)) return;
        var detId = new DetectionId(guid);

        _detection = await DetectionService.GetByIdAsync(detId);
        if (_detection is null) return;

        _breadcrumbs =
        [
            new("Detections", "/governance/detections"),
            new(_detection.Slug, null, disabled: true),
    ];

        _versions = (await VersionService.ListByDetectionAsync(detId)).ToList();
        _latestVersion = _versions.FirstOrDefault();
        _changes = (await ChangeService.ListByDetectionAsync(detId)).ToList();
        _activeChangeCount = _changes.Count(c => c.Status is not DeltaZulu.Platform.Domain.Governance.Enums.ChangeStatus.Merged and not DeltaZulu.Platform.Domain.Governance.Enums.ChangeStatus.Closed);

        _acceptedFiles = (await AcceptedContentReadService.ListAcceptedFilesForDetectionAsync(_detection.Id)).ToList();

    }

    private async Task DeprecateDetection()
    {
        if (_detection is null) return;
        try
        {
            await DetectionService.DeprecateAsync(_detection.Id);
            Snackbar.Add("Detection deprecated.", Severity.Success);
            _detection = await DetectionService.GetByIdAsync(_detection.Id);
        }
        catch (DomainException ex) { Snackbar.Add(ex.Message, Severity.Error); }
    }

    private async Task OpenChangeDialog()
    {
        if (_detection is null) return;
        var parameters = new DialogParameters<OpenChangeDialog>
        {
            { x => x.DetectionId, _detection.Id },
            { x => x.AuthorId, UserContext.CurrentUser.Id },
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<OpenChangeDialog>("Open proposal", parameters, options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is ChangeRequestId changeId)
        {
            Nav.NavigateTo($"/governance/proposals/{changeId}");
        }
    }
    
    private async Task OpenAcceptedFileAsync(AcceptedContentFileSummary file)
    {
        if (_detection is null) return;

        _fileDrawerOpen = true;
        _fileLoading = true;
        _fileLoadError = null;
        _selectedAcceptedFile = null;
        _selectedAcceptedFilePath = file.LogicalPath;

        try
        {
            _selectedAcceptedFile = await AcceptedContentReadService.GetAcceptedFileForDetectionAsync(
                _detection.Id,
                file.LogicalPath);

            if (_selectedAcceptedFile is null)
            {
                _fileLoadError = $"Accepted file '{file.LogicalPath}' was not found.";
            }
        }
        catch (DomainException ex)
        {
            _fileLoadError = ex.Message;
        }
        finally
        {
            _fileLoading = false;
        }
    }

    private Task OnFileDrawerOpenChanged(bool open)
    {
        _fileDrawerOpen = open;
        return Task.CompletedTask;
    }
}
