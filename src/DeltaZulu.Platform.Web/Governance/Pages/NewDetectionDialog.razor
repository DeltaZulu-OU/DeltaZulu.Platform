@namespace DeltaZulu.Platform.Web.Governance.Components.Pages
@using MudBlazor
@using DeltaZulu.Platform.Application.Governance.Services
@using DeltaZulu.Platform.Domain.Governance.Common
@using DeltaZulu.Platform.Domain.Governance.Enums
@using DeltaZulu.Platform.Web.Governance.Components.Shared
@using DeltaZulu.Platform.Web.Governance.Services
@inject DetectionContentService DetectionService
@inject ChangeService ChangeService
@inject PocUserContext UserContext
@inject ISnackbar Snackbar

<MudDialog Class="dz-rule-dialog">
    <TitleContent>
        <div class="dz-rule-dialog__title">
            <MudIcon Icon="@Icons.Material.Outlined.AddModerator" />
            <div>
                <MudText Typo="Typo.overline">Create rule</MudText>
                <MudText Typo="Typo.h6">New detection rule</MudText>
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_slug" Label="Rule slug" HelperText="Lowercase, hyphens, 3–64 characters."
                      Required="true" Immediate="true" Class="mb-3 dz-mono-input" />
        <DetectionAuthorForm @ref="_detectionForm"
                             DetectionSlug="@DetectionIdFromSlug" />
        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   StartIcon="@Icons.Material.Outlined.Check"
                   Disabled="@(_submitting || string.IsNullOrWhiteSpace(_slug))">
            @if (_submitting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Create rule
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private string _slug = "";
    private DetectionAuthorForm? _detectionForm;
    private string? _error;
    private bool _submitting;

    private string DetectionIdFromSlug => string.IsNullOrWhiteSpace(_slug) ? string.Empty : $"dz-{_slug.Trim()}";

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        _error = null;
        _submitting = true;
        try
        {
            if (_detectionForm is null)
            {
                _error = "Detection form is not ready.";
                return;
            }

            var draft = await _detectionForm.GetDraftAsync();
            var slug = _slug.Trim();
            var detection = await DetectionService.CreateAsync(slug, draft.Title.Trim(), draft.Description.Trim());
            var draftKey = $"INIT-{slug}"[..Math.Min($"INIT-{slug}".Length, 32)];
            var change = await ChangeService.OpenChangeAsync(
                draftKey,
                $"Initial detection content for {draft.Title.Trim()}",
                detection.Id,
                UserContext.CurrentUser.Id,
                WorkflowProfileId.QuickLab);
            await ChangeService.UpsertDetectionDraftAsync(change.Id, draft, UserContext.CurrentUser.Id);

            Snackbar.Add($"Detection '{slug}' created with initial content draft.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(change.Id));
        }
        catch (DomainException ex) { _error = ex.Message; }
        finally { _submitting = false; }
    }
}
