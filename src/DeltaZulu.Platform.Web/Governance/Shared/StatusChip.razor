@namespace DeltaZulu.Platform.Web.Governance.Components.Shared
@using DeltaZulu.Platform.Domain.Governance.Enums
@using ChangeStatusEnum = DeltaZulu.Platform.Domain.Governance.Enums.ChangeStatus
@using IssueStatusEnum = DeltaZulu.Platform.Domain.Governance.Enums.IssueStatus
@using CheckStatusEnum = DeltaZulu.Platform.Domain.Governance.Enums.CheckStatus

@if (_text is not null)
{
    <DzStatusChip Label="@_text" Tone="@_tone" />
}

@code {
    [Parameter] public ChangeStatus? ChangeStatus { get; set; }
    [Parameter] public IssueStatus? IssueStatus { get; set; }
    [Parameter] public DetectionLifecycle? Lifecycle { get; set; }
    [Parameter] public CheckStatus? CheckStatus { get; set; }

    private string? _text;
    private string _tone = "neutral";

    protected override void OnParametersSet()
    {
        if (ChangeStatus is not null)
        {
            _text = ChangeStatus.Value.ToString();
            _tone = ChangeStatus.Value switch
            {
                ChangeStatusEnum.Draft => "neutral",
                ChangeStatusEnum.ChecksRunning => "info",
                ChangeStatusEnum.ReviewRequired => "warning",
                ChangeStatusEnum.ChangesRequested => "error",
                ChangeStatusEnum.ReadyToAccept => "success",
                ChangeStatusEnum.Merged => "dark",
                ChangeStatusEnum.Published => "success",
                ChangeStatusEnum.Closed => "muted",
                _ => "neutral",
            };
        }
        else if (IssueStatus is not null)
        {
            _text = IssueStatus.Value.ToString();
            _tone = IssueStatus.Value switch
            {
                IssueStatusEnum.New => "neutral",
                IssueStatusEnum.NeedsInfo => "warning",
                IssueStatusEnum.Triaged => "info",
                IssueStatusEnum.SanitizationRequired => "error",
                IssueStatusEnum.Rejected => "muted",
                IssueStatusEnum.Backlog => "neutral",
                IssueStatusEnum.Ready => "info",
                IssueStatusEnum.Blocked => "error",
                IssueStatusEnum.InProgress => "warning",
                IssueStatusEnum.InReview => "warning",
                IssueStatusEnum.Merged => "success",
                IssueStatusEnum.Published => "dark",
                IssueStatusEnum.Closed => "muted",
                _ => "neutral",
            };
        }
        else if (Lifecycle is not null)
        {
            _text = Lifecycle.Value switch
            {
                DetectionLifecycle.Draft => "Draft",
                DetectionLifecycle.Accepted => "Accepted",
                DetectionLifecycle.Deprecated => "Deprecated",
                _ => Lifecycle.Value.ToString(),
            };
            _tone = Lifecycle.Value switch
            {
                DetectionLifecycle.Draft => "neutral",
                DetectionLifecycle.Accepted => "success",
                DetectionLifecycle.Deprecated => "muted",
                _ => "neutral",
            };
        }
        else if (CheckStatus is not null)
        {
            _text = CheckStatus.Value.ToString();
            _tone = CheckStatus.Value switch
            {
                CheckStatusEnum.Passed => "success",
                CheckStatusEnum.Failed => "error",
                CheckStatusEnum.Running => "info",
                CheckStatusEnum.Queued => "neutral",
                CheckStatusEnum.Skipped => "muted",
                CheckStatusEnum.Cancelled => "muted",
                _ => "neutral",
            };
        }
        else
        {
            _text = null;
            _tone = "neutral";
        }
    }
}
