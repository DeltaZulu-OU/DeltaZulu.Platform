@namespace DeltaZulu.Platform.Web.Workbench.Components.Pages
@using MudBlazor
@using DeltaZulu.Platform.Application.Workbench.Services
@using DeltaZulu.Platform.Domain.Workbench.Common
@inject DetectionContentService DetectionService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Class="dz-dialog-title">New detection</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_slug" Label="Slug" HelperText="Lowercase, hyphens, 3–64 characters."
                      Required="true" Immediate="true" Class="mb-3 dz-mono-input" />
        <MudTextField @bind-Value="_title" Label="Title" Required="true" Immediate="true" Class="mb-3" />
        <MudTextField @bind-Value="_summary" Label="Summary" Lines="3" Class="mb-3"
                      HelperText="One or two sentences describing the detection." />
        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="_submitting">
            @if (_submitting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Create
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private string _slug = "";
    private string _title = "";
    private string _summary = "";
    private string? _error;
    private bool _submitting;

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        _error = null;
        _submitting = true;
        try
        {
            await DetectionService.CreateAsync(_slug.Trim(), _title.Trim(), _summary.Trim());
            Snackbar.Add($"Detection '{_slug}' created.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (DomainException ex) { _error = ex.Message; }
        finally { _submitting = false; }
    }
}
