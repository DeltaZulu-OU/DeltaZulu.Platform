<div class="dz-detail-list__item @Class" @attributes="AdditionalAttributes">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <MudText Typo="Typo.caption" Class="@LabelClass">@Label</MudText>
    }

    @if (ChildContent is not null)
    {
        <div class="@ValueClass">
            @ChildContent
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(Value))
    {
        <MudText Typo="@ValueTypo" Class="@ValueClass">@Value</MudText>
    }
</div>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public bool Mono { get; set; }
    [Parameter] public Typo ValueTypo { get; set; } = Typo.body2;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? LabelClass { get; set; } = "text-muted";
    [Parameter] public string? ValueClassOverride { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ValueClass => ValueClassOverride ?? string.Join(" ", new[]
    {
        "dz-detail-list__value",
        Mono ? "dz-detail-list__value--mono" : null
    }.Where(static value => !string.IsNullOrWhiteSpace(value)));
}
