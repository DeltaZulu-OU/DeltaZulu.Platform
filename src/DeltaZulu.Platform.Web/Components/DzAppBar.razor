@using Microsoft.AspNetCore.Components.Web

<MudAppBar Elevation="@Elevation" Class="@AppBarClass" Style="@AppBarStyle" Color="Color.Inherit" @attributes="AdditionalAttributes">
    @if (ShowMenuButton)
    {
        <MudIconButton Icon="@MenuIcon"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@HandleMenuClick"
                       aria-label="Toggle navigation" />
    }

    @if (!string.IsNullOrWhiteSpace(LogoSrc))
    {
        <img src="@LogoSrc" alt="@LogoAlt" height="@LogoHeight" class="dz-shell-logo ml-2 mr-3" />
    }

    @if (TitleContent is not null)
    {
        @TitleContent
    }
    else if (!string.IsNullOrWhiteSpace(ProductName))
    {
        <MudText Typo="@TitleTypo" Class="dz-shell-title">
            @ProductName
        </MudText>
    }

    <MudSpacer />

    @if (Actions is not null)
    {
        <div class="dz-app-bar__actions">
            @Actions
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(ProductBadge))
    {
        <MudText Typo="Typo.caption" Class="dz-shell-badge">
            @ProductBadge
        </MudText>
    }
</MudAppBar>

@code {
    [Parameter] public string? ProductName { get; set; }
    [Parameter] public string? ProductBadge { get; set; }
    [Parameter] public string? LogoSrc { get; set; }
    [Parameter] public string LogoAlt { get; set; } = "DeltaZulu";
    [Parameter] public int LogoHeight { get; set; } = 28;
    [Parameter] public bool ShowMenuButton { get; set; } = true;
    [Parameter] public string MenuIcon { get; set; } = Icons.Material.Filled.Menu;
    [Parameter] public EventCallback OnMenuClick { get; set; }
    [Parameter] public Typo TitleTypo { get; set; } = Typo.subtitle1;
    [Parameter] public int Elevation { get; set; }
    [Parameter] public RenderFragment? TitleContent { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private const string DefaultBackground = "var(--brand-slate)";
    private const string DefaultTextColor = "#FFFFFF";

    private Task HandleMenuClick(MouseEventArgs _) => OnMenuClick.InvokeAsync();

    private string AppBarStyle => string.IsNullOrWhiteSpace(Style)
        ? $"background:{DefaultBackground};color:{DefaultTextColor}"
        : Style;

    private string AppBarClass => string.Join(" ", new[]
    {
        "dz-app-bar",
        Class
    }.Where(static value => !string.IsNullOrWhiteSpace(value)));
}