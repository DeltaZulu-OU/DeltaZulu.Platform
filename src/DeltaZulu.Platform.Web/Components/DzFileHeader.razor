<div class="dz-file-header @Class" @attributes="AdditionalAttributes">
    <MudIcon Icon="@Icon" Size="Size.Small" Class="dz-file-header__icon" />
    <code>@Path</code>
    @if (!string.IsNullOrWhiteSpace(Kind))
    {
        <DzMetaChip Kind="file">@Kind</DzMetaChip>
    }
    @if (!string.IsNullOrWhiteSpace(Metadata))
    {
        <MudText Typo="Typo.caption" Class="mud-text-secondary">@Metadata</MudText>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Path { get; set; } = string.Empty;
    [Parameter] public string? Kind { get; set; }
    [Parameter] public string? Metadata { get; set; }
    [Parameter] public string Icon { get; set; } = Icons.Material.Outlined.InsertDriveFile;
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }
}
