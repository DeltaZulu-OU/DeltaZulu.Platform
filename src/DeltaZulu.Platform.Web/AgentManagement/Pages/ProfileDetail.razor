@namespace DeltaZulu.Platform.Web.AgentManagement.Pages
@page "/agents/profiles/{Id}"
@rendermode InteractiveServer
@using MudBlazor
@using DeltaZulu.Platform.Application.AgentManagement.Services
@using DeltaZulu.Platform.Domain.AgentManagement.Enums
@using DeltaZulu.Platform.Domain.AgentManagement.Identifiers
@using DeltaZulu.Platform.Domain.AgentManagement.Profiles
@using DeltaZulu.Platform.Domain.Common
@inject ResourceProfileService ProfileService
@inject ISnackbar Snackbar

<PageTitle>Profile — @(_profile?.Name ?? "Loading")</PageTitle>

@if (_profile is null)
{
    <DzLoadingState Text="Loading profile..." />
}
else
{
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-2" />

    <MudGrid Spacing="3">
        <MudItem xs="12" md="8">
            <DzPageHeader Eyebrow="Resource Profile"
                          Title="@_profile.Name"
                          Description="@($"Origin: {_profile.Origin}")">
                <Metadata>
                    <DzStatusChip Label="@(_profile.Enabled ? "Enabled" : "Disabled")"
                                  Tone="@(_profile.Enabled ? "success" : "muted")" />
                </Metadata>
            </DzPageHeader>
        </MudItem>
        <MudItem xs="12" md="4">
            <DzPanel Eyebrow="Details" Class="dz-panel--full-height">
                <DzDetailList>
                    <DzDetailItem Label="Origin">
                        <DzMetaChip Kind="origin">@_profile.Origin</DzMetaChip>
                    </DzDetailItem>
                    <DzDetailItem Label="Enabled">
                        <DzStatusChip Label="@(_profile.Enabled ? "Enabled" : "Disabled")"
                                      Tone="@(_profile.Enabled ? "success" : "muted")" />
                    </DzDetailItem>
                    <DzDetailItem Label="Created">
                        <MudText Typo="Typo.body2" Class="dz-config-value dz-config-value--mono">
                            @_profile.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")
                        </MudText>
                    </DzDetailItem>
                    <DzDetailItem Label="Updated">
                        <MudText Typo="Typo.body2" Class="dz-config-value dz-config-value--mono">
                            @_profile.UpdatedAt.ToString("yyyy-MM-dd HH:mm:ss")
                        </MudText>
                    </DzDetailItem>
                </DzDetailList>
            </DzPanel>
        </MudItem>
    </MudGrid>

    <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" Class="mt-4">
        <MudTabPanel Text="Versions" BadgeData="@_versions.Count" BadgeColor="Color.Secondary">
            <DzTabBody>
                @if (_versions.Count == 0)
                {
                    <DzEmptyState Title="No versions yet"
                                  Description="Create a profile version to define collection behavior."
                                  Icon="@Icons.Material.Outlined.History" />
                }
                else
                {
                    <DzTableShell>
                        <MudTable Items="_versions" Dense="true" T="ResourceProfileVersion" Elevation="0">
                            <HeaderContent>
                                <MudTh>Version</MudTh>
                                <MudTh>State</MudTh>
                                <MudTh>Schema</MudTh>
                                <MudTh>Content Hash</MudTh>
                                <MudTh>Author</MudTh>
                                <MudTh>Updated</MudTh>
                                <MudTh>Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Version">
                                    <DzMetaChip Kind="version">@context.DisplayVersion</DzMetaChip>
                                </MudTd>
                                <MudTd DataLabel="State">
                                    <ProfileStateChip State="context.State" />
                                </MudTd>
                                <MudTd DataLabel="Schema">
                                    <MudText Typo="Typo.body2">@context.SchemaVersion</MudText>
                                </MudTd>
                                <MudTd DataLabel="Content Hash">
                                    <code>@context.ContentHash[..Math.Min(8, context.ContentHash.Length)]</code>
                                </MudTd>
                                <MudTd DataLabel="Author">
                                    <MudText Typo="Typo.body2">@(context.Author ?? "—")</MudText>
                                </MudTd>
                                <MudTd DataLabel="Updated">
                                    <MudText Typo="Typo.caption">@context.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</MudText>
                                </MudTd>
                                <MudTd DataLabel="Actions">
                                    @switch (context.State)
                                    {
                                        case ProfileState.Draft:
                                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Info"
                                                       OnClick="@(() => ValidateVersion(context.Id))">
                                                Validate
                                            </MudButton>
                                            break;
                                        case ProfileState.Validated:
                                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Success"
                                                       OnClick="@(() => PublishVersion(context.Id))">
                                                Publish
                                            </MudButton>
                                            break;
                                        case ProfileState.Published:
                                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Warning"
                                                       OnClick="@(() => DeprecateVersion(context.Id))">
                                                Deprecate
                                            </MudButton>
                                            break;
                                        case ProfileState.Deprecated:
                                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Default"
                                                       OnClick="@(() => ArchiveVersion(context.Id))">
                                                Archive
                                            </MudButton>
                                            break;
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </DzTableShell>
                }
            </DzTabBody>
        </MudTabPanel>
    </MudTabs>
}

@code {
    [Parameter] public string Id { get; set; } = null!;

    private ResourceProfile? _profile;
    private List<ResourceProfileVersion> _versions = [];
    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        if (!Guid.TryParse(Id, out var guid)) return;
        var profileId = new ResourceProfileId(guid);

        _profile = await ProfileService.GetByIdAsync(profileId);
        if (_profile is null) return;

        _breadcrumbs =
        [
            new("Resource Profiles", "/agents/profiles"),
            new(_profile.Name, null, disabled: true),
        ];

        _versions = (await ProfileService.ListVersionsAsync(profileId)).ToList();
    }

    private Task ValidateVersion(ProfileVersionId id) =>
        ApplyTransition(() => ProfileService.MarkValidatedAsync(id), "validated");

    private Task PublishVersion(ProfileVersionId id) =>
        ApplyTransition(() => ProfileService.PublishAsync(id), "published");

    private Task DeprecateVersion(ProfileVersionId id) =>
        ApplyTransition(() => ProfileService.DeprecateAsync(id), "deprecated");

    private Task ArchiveVersion(ProfileVersionId id) =>
        ApplyTransition(() => ProfileService.ArchiveAsync(id), "archived");

    private async Task ApplyTransition(Func<Task> action, string pastTense)
    {
        try
        {
            await action();
            Snackbar.Add($"Version {pastTense}.", Severity.Success);
            await LoadAsync();
        }
        catch (DomainException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
