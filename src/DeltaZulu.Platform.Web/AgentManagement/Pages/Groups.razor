@namespace DeltaZulu.Platform.Web.AgentManagement.Pages
@page "/agents/groups"
@rendermode InteractiveServer
@using MudBlazor
@using DeltaZulu.Platform.Application.AgentManagement.Services
@using DeltaZulu.Platform.Domain.AgentManagement.Agents
@using DeltaZulu.Platform.Domain.AgentManagement.Identifiers
@using DeltaZulu.Platform.Domain.Common
@inject AgentGroupService GroupService
@inject AgentService AgentService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Agent Groups</PageTitle>

<DzPageHeader Eyebrow="Management"
              Title="Agent Groups"
              Description="Organize agents into logical groups for scoped policy assignment.">
    <Actions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@Icons.Material.Outlined.Add" OnClick="OpenCreateDialog">
            Create Group
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                   StartIcon="@Icons.Material.Outlined.Refresh" OnClick="LoadAsync">
            Refresh
        </MudButton>
    </Actions>
</DzPageHeader>

@if (_loading)
{
    <DzLoadingState Text="Loading agent groups..." />
}
else if (_groups.Count == 0)
{
    <DzEmptyState Title="No agent groups"
                  Description="Create a group to organize agents and assign policies by scope."
                  Icon="@Icons.Material.Outlined.Workspaces" />
}
else
{
    <DzTableShell>
        <MudTable Items="_groups" Dense="true" Hover="true" T="AgentGroup" Elevation="0">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Created</MudTh>
                <MudTh>Updated</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">
                    @if (_editingGroupId == context.Id)
                    {
                        <MudTextField @bind-Value="_editName" Immediate="true" Variant="Variant.Outlined"
                                      Margin="Margin.Dense" T="string"
                                      OnKeyDown="@(async (e) => { if (e.Key == "Enter") await SaveRename(context.Id); })" />
                    }
                    else
                    {
                        <strong>@context.Name</strong>
                    }
                </MudTd>
                <MudTd DataLabel="Created">
                    <MudText Typo="Typo.caption">@context.CreatedAt.ToString("yyyy-MM-dd HH:mm")</MudText>
                </MudTd>
                <MudTd DataLabel="Updated">
                    <MudText Typo="Typo.caption">@context.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</MudText>
                </MudTd>
                <MudTd DataLabel="Actions">
                    @if (_editingGroupId == context.Id)
                    {
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                                   OnClick="@(() => SaveRename(context.Id))">Save</MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="CancelRename">Cancel</MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Outlined.Edit"
                                   OnClick="@(() => StartRename(context))">Rename</MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Outlined.Group"
                                   OnClick="@(() => ToggleMembersAsync(context.Id))">
                            @(_expandedGroupId == context.Id ? "Hide Members" : "Members")
                        </MudButton>
                    }
                </MudTd>
            </RowTemplate>
            <ChildRowContent>
                @if (_expandedGroupId == context.Id)
                {
                    <MudTr>
                        <td colspan="4" class="pa-4">
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Members (@_memberIds.Count)</MudText>
                            @if (_memberIds.Count == 0)
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-2">
                                    No agents in this group yet.
                                </MudText>
                            }
                            else
                            {
                                <div class="d-flex gap-1 flex-wrap mb-3">
                                    @foreach (var memberId in _memberIds)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                 OnClose="@(() => RemoveMemberAsync(context.Id, memberId))">
                                            @AgentName(memberId)
                                        </MudChip>
                                    }
                                </div>
                            }
                            <div class="d-flex gap-2 align-center">
                                <MudSelect @bind-Value="_agentToAdd" Label="Add agent" T="string"
                                           Margin="Margin.Dense" Variant="Variant.Outlined" Style="max-width: 320px">
                                    @foreach (var agent in NonMembers())
                                    {
                                        <MudSelectItem Value="@agent.Id.Value.ToString("D")">@agent.Hostname</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                                           Disabled="@string.IsNullOrEmpty(_agentToAdd)"
                                           OnClick="@(() => AddMemberAsync(context.Id))">Add</MudButton>
                            </div>
                        </td>
                    </MudTr>
                }
            </ChildRowContent>
        </MudTable>
    </DzTableShell>
}

@code {
    private bool _loading = true;
    private IReadOnlyList<AgentGroup> _groups = [];
    private AgentGroupId? _editingGroupId;
    private string _editName = "";
    private AgentGroupId? _expandedGroupId;
    private IReadOnlyList<AgentId> _memberIds = [];
    private IReadOnlyList<Agent> _agents = [];
    private string? _agentToAdd;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _groups = await GroupService.ListByTenantAsync(TenantId.Default);
            _agents = await AgentService.ListByTenantAsync(TenantId.Default);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ToggleMembersAsync(AgentGroupId groupId)
    {
        if (_expandedGroupId == groupId)
        {
            _expandedGroupId = null;
            _memberIds = [];
            return;
        }

        _expandedGroupId = groupId;
        _agentToAdd = null;
        _memberIds = await GroupService.ListMemberAgentIdsAsync(groupId);
    }

    private async Task AddMemberAsync(AgentGroupId groupId)
    {
        if (string.IsNullOrEmpty(_agentToAdd)) return;

        try
        {
            await GroupService.AddMemberAsync(groupId, new AgentId(Guid.Parse(_agentToAdd)));
            _agentToAdd = null;
            _memberIds = await GroupService.ListMemberAgentIdsAsync(groupId);
            Snackbar.Add("Agent added to group. Group policy applies at the agent's next check-in.", Severity.Success);
        }
        catch (DomainException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task RemoveMemberAsync(AgentGroupId groupId, AgentId agentId)
    {
        await GroupService.RemoveMemberAsync(groupId, agentId);
        _memberIds = await GroupService.ListMemberAgentIdsAsync(groupId);
        Snackbar.Add("Agent removed from group.", Severity.Success);
    }

    private string AgentName(AgentId agentId) =>
        _agents.FirstOrDefault(a => a.Id == agentId)?.Hostname
        ?? agentId.Value.ToString("D")[..8];

    private IEnumerable<Agent> NonMembers() =>
        _agents.Where(a => !_memberIds.Contains(a.Id));

    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<CreateGroupDialog>("Create agent group",
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false })
            await LoadAsync();
    }

    private void StartRename(AgentGroup group)
    {
        _editingGroupId = group.Id;
        _editName = group.Name;
    }

    private void CancelRename()
    {
        _editingGroupId = null;
        _editName = "";
    }

    private async Task SaveRename(AgentGroupId groupId)
    {
        if (string.IsNullOrWhiteSpace(_editName)) return;

        try
        {
            await GroupService.RenameAsync(groupId, _editName.Trim());
            Snackbar.Add("Group renamed.", Severity.Success);
            _editingGroupId = null;
            await LoadAsync();
        }
        catch (DomainException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
