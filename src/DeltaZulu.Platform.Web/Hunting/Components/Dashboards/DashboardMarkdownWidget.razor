@namespace DeltaZulu.Platform.Web.Hunting.Components.Dashboards
@using DeltaZulu.Platform.Web.Hunting.Dashboards.Markdown

@if (string.IsNullOrWhiteSpace(Markdown))
{
    <div class="dashboard-markdown-empty">
        <p>No markdown content yet.</p>
    </div>
}
else
{
    <div class="dashboard-markdown-viewer">
        @((MarkupString)DashboardMarkdownRenderer.ToHtml(Markdown))
    </div>
}

@code {
    [Parameter]
    public string Markdown { get; set; } = string.Empty;
}
