@inherits LayoutComponentBase
@namespace DeltaZulu.Hunting.Web.Shared

<div class="@($"hunt-app {(_globalNavDocked ? "hunt-global-nav-docked" : "hunt-global-nav-undocked")}")">
    <MudAppBar Dense="true" Fixed="false" Elevation="1" Class="hunt-topbar">
        <NavLink href="/hunting" Match="NavLinkMatch.All" class="hunt-brand" aria-label="Open overview">
            <span class="hunt-brand-text">Hunting Workbench</span>
        </NavLink>

        <MudSpacer />
    </MudAppBar>

    <div class="hunt-shell">
        <aside class="hunt-global-sidebar" aria-label="Global navigation">
            <nav class="hunt-global-nav">
                <NavLink href="/hunting" Match="NavLinkMatch.All" class="hunt-global-nav-link">
                    <span class="hunt-global-nav-icon" aria-hidden="true">⌂</span>
                    <span class="hunt-global-nav-text">Overview</span>
                </NavLink>
                <NavLink href="/hunting/threat-hunting" class="hunt-global-nav-link">
                    <span class="hunt-global-nav-icon" aria-hidden="true">⌕</span>
                    <span class="hunt-global-nav-text">Threat Hunting</span>
                </NavLink>
                <NavLink href="/hunting/library" class="hunt-global-nav-link">
                    <span class="hunt-global-nav-icon" aria-hidden="true">▤</span>
                    <span class="hunt-global-nav-text">Library</span>
                </NavLink>
                <NavLink href="/hunting/dashboards" class="hunt-global-nav-link">
                    <span class="hunt-global-nav-icon" aria-hidden="true">▦</span>
                    <span class="hunt-global-nav-text">Dashboards</span>
                </NavLink>
                <NavLink href="/hunting/settings" class="hunt-global-nav-link">
                    <span class="hunt-global-nav-icon" aria-hidden="true">⚙</span>
                    <span class="hunt-global-nav-text">Settings</span>
                </NavLink>
            </nav>

            <div class="hunt-global-nav-footer">
                <button type="button"
                        class="hunt-global-nav-toggle"
                        @onclick="ToggleGlobalNavigation"
                        aria-label="@GlobalNavToggleLabel"
                        title="@GlobalNavToggleLabel">
                    <span class="hunt-global-nav-icon" aria-hidden="true">@(_globalNavDocked ? "⇤" : "⇥")</span>
                    <span class="hunt-global-nav-text">@(_globalNavDocked ? "Collapse" : "Expand")</span>
                </button>
            </div>
        </aside>

        <main class="hunt-main">
            @Body
        </main>
    </div>
</div>

@code {
    private bool _globalNavDocked = true;

    private string GlobalNavToggleLabel => _globalNavDocked
        ? "Undock global navigation"
        : "Dock global navigation";

    private void ToggleGlobalNavigation()
        => _globalNavDocked = !_globalNavDocked;
}
