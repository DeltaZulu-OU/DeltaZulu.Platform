@namespace Hunting.Web.Components
@using DeltaZulu.Hunting.Core.Schema
@inject Hunting.Core.Catalog.ApprovedViewCatalog Catalog
@inject IJSRuntime JS

<button class="hunt-btn hunt-btn-helper"
        @onclick="Open"
        aria-haspopup="dialog"
        aria-expanded="@_open">
    Helper
</button>

@if (_open)
{
    <button class="hunt-drawer-backdrop"
            @onclick="Close"
            aria-label="Close query helper drawer"></button>

    <aside class="hunt-drawer hunt-helper-drawer"
           role="dialog"
           aria-modal="true"
           aria-label="KQL query helper">
        <div class="hunt-drawer-header">
            <div>
                <div class="hunt-drawer-title">Query helper</div>
                <div class="hunt-drawer-subtitle">Build a simple KQL snippet and send it to the editor.</div>
            </div>
            <button class="hunt-drawer-close"
                    @onclick="Close"
                    aria-label="Close query helper drawer">
                ×
            </button>
        </div>

        <div class="hunt-drawer-body hunt-drawer-body-padded hunt-helper-body">
            <section class="hunt-helper-section" aria-labelledby="hunt-helper-target-heading">
                <h3 id="hunt-helper-target-heading" class="hunt-helper-section-title">Target</h3>
                <div class="hunt-helper-grid">
                    <label class="hunt-helper-field">
                        <span>Table</span>
                        <select class="hunt-helper-input" value="@_table" @onchange="OnTableChanged">
                            @foreach (var table in Tables)
                            {
                                <option value="@table.Name">@table.Name</option>
                            }
                        </select>
                    </label>

                    <label class="hunt-helper-field">
                        <span>Time limit</span>
                        <select class="hunt-helper-input" @bind="_timeRange" disabled="@(!HasTimeColumns)">
                            <option value="">None</option>
                            @foreach (var range in TimeRanges)
                            {
                                <option value="@range.Value">@range.Label</option>
                            }
                        </select>
                    </label>

                    @if (HasTimeColumns && HasTimeLimit)
                    {
                        <label class="hunt-helper-field">
                            <span>Time column</span>
                            <select class="hunt-helper-input" @bind="_timeColumn">
                                @foreach (var column in TimeColumns)
                                {
                                    <option value="@column.Name">@column.Name</option>
                                }
                            </select>
                        </label>
                    }
                    else if (!HasTimeColumns)
                    {
                        <div class="hunt-helper-note hunt-helper-field-wide">No datetime column is available for this table.</div>
                    }
                </div>
            </section>

            <section class="hunt-helper-section" aria-labelledby="hunt-helper-conditions-heading">
                <div class="hunt-helper-section-header">
                    <h3 id="hunt-helper-conditions-heading" class="hunt-helper-section-title">Conditions</h3>
                    <button class="hunt-btn hunt-btn-helper-secondary" @onclick="AddFilter" disabled="@(CurrentColumns.Count == 0)">+ Add condition</button>
                </div>

                @if (_filters.Count == 0)
                {
                    <div class="hunt-helper-empty">No conditions yet.</div>
                }
                else
                {
                    <div class="hunt-helper-filters">
                        @foreach (var filter in _filters)
                        {
                            <div class="hunt-helper-filter-row">
                                <select class="hunt-helper-input" aria-label="Filter column" value="@filter.Column" @onchange="args => OnFilterColumnChanged(filter, args)">
                                    @foreach (var column in CurrentColumns)
                                    {
                                        <option value="@column.Name">@column.Name</option>
                                    }
                                </select>

                                <select class="hunt-helper-input" aria-label="Filter operator" value="@filter.Operator" @onchange="args => OnFilterOperatorChanged(filter, args)">
                                    @foreach (var op in GetOperatorsForColumn(filter.Column))
                                    {
                                        <option value="@op">@op</option>
                                    }
                                </select>

                                <input class="hunt-helper-input hunt-helper-filter-value"
                                       aria-label="Filter value"
                                       placeholder="@GetValuePlaceholder(filter.Column)"
                                       @bind="filter.Value"
                                       @bind:event="oninput" />

                                <button class="hunt-btn hunt-helper-remove"
                                        @onclick="() => RemoveFilter(filter)"
                                        aria-label="Remove condition">
                                    Remove
                                </button>
                            </div>
                        }
                    </div>
                }
            </section>

            <section class="hunt-helper-section" aria-labelledby="hunt-helper-output-heading">
                <h3 id="hunt-helper-output-heading" class="hunt-helper-section-title">Result shape</h3>
                <div class="hunt-helper-grid">
                    <label class="hunt-helper-field hunt-helper-field-wide">
                        <span>Project columns</span>
                        <input class="hunt-helper-input"
                               placeholder="@ProjectPlaceholder"
                               @bind="_projectColumns"
                               @bind:event="oninput" />
                    </label>

                    <label class="hunt-helper-field">
                        <span>Sort by</span>
                        <select class="hunt-helper-input" @bind="_sortColumn">
                            <option value="">None</option>
                            @foreach (var column in CurrentColumns)
                            {
                                <option value="@column.Name">@column.Name</option>
                            }
                        </select>
                    </label>

                    <label class="hunt-helper-field">
                        <span>Direction</span>
                        <select class="hunt-helper-input" @bind="_sortDirection">
                            <option value="desc">desc</option>
                            <option value="asc">asc</option>
                        </select>
                    </label>

                    <label class="hunt-helper-field">
                        <span>Row limit</span>
                        <select class="hunt-helper-input" value="@_limitMode" @onchange="OnLimitModeChanged">
                            <option value="">None</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                            <option value="500">500</option>
                            <option value="1000">1000</option>
                            <option value="custom">Custom</option>
                        </select>
                    </label>

                    @if (_limitMode == CustomLimitMode)
                    {
                        <label class="hunt-helper-field">
                            <span>Custom limit</span>
                            <input class="hunt-helper-input"
                                   type="number"
                                   min="1"
                                   max="10000"
                                   @bind="_customLimit" />
                        </label>
                    }
                </div>
            </section>

            <section class="hunt-helper-section" aria-labelledby="hunt-helper-preview-heading">
                <div class="hunt-helper-section-header">
                    <h3 id="hunt-helper-preview-heading" class="hunt-helper-section-title">Preview</h3>
                    <button class="hunt-btn hunt-btn-helper-secondary" @onclick="CopyPreviewAsync" disabled="@(!CanGenerate)">Copy</button>
                </div>
                <pre class="hunt-helper-preview">@GeneratedQuery</pre>
            </section>
        </div>

        <div class="hunt-helper-actions">
            <button class="hunt-btn hunt-btn-run" @onclick="InsertAsync" disabled="@(!CanGenerate)">Insert</button>
            <button class="hunt-btn" @onclick="AppendAsync" disabled="@(!CanGenerate)">Append</button>
            <button class="hunt-btn hunt-btn-clear" @onclick="ClearBuilder">Clear</button>
        </div>
    </aside>
}

@code {
    [Parameter]
    public EventCallback<string> InsertRequested { get; set; }

    [Parameter]
    public EventCallback<string> AppendRequested { get; set; }

    private readonly List<HelperFilter> _filters = [];
    private IReadOnlyList<EditorTableMetadata> _tables = [];
    private bool _open;
    private string _table = string.Empty;
    private const string CustomLimitMode = "custom";

    private string _timeColumn = string.Empty;
    private string _timeRange = string.Empty;
    private string _projectColumns = string.Empty;
    private string _sortColumn = string.Empty;
    private string _sortDirection = "desc";
    private string _limitMode = string.Empty;
    private int? _customLimit;

    private IReadOnlyList<EditorTableMetadata> Tables => _tables;

    private EditorTableMetadata? SelectedTable => Tables.FirstOrDefault(table => string.Equals(table.Name, _table, StringComparison.OrdinalIgnoreCase));

    private IReadOnlyList<EditorColumnMetadata> CurrentColumns => SelectedTable?.Columns ?? [];

    private IReadOnlyList<EditorColumnMetadata> TimeColumns => CurrentColumns.Where(IsDateTimeColumn).ToArray();

    private bool HasTimeColumns => TimeColumns.Count > 0;

    private bool HasTimeLimit => !string.IsNullOrWhiteSpace(_timeRange);

    private int? EffectiveLimit => _limitMode switch
    {
        CustomLimitMode => _customLimit is > 0 ? _customLimit : null,
        { Length: > 0 } value when int.TryParse(value, out var parsed) && parsed > 0 => parsed,
        _ => null
    };

    private bool CanGenerate => !string.IsNullOrWhiteSpace(_table) && SelectedTable is not null;

    private string GeneratedQuery => CanGenerate ? BuildQuery() : string.Empty;

    private string ProjectPlaceholder => BuildDefaultProjection();

    private static readonly (string Value, string Label)[] TimeRanges =
    [
        ("1h", "Last hour"),
        ("24h", "Last 24 hours"),
        ("7d", "Last 7 days"),
        ("30d", "Last 30 days")
    ];

    protected override void OnInitialized()
    {
        _tables = Catalog.BuildEditorSchemaMetadata().Tables
            .OrderBy(static table => table.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        _table = Tables.FirstOrDefault()?.Name ?? string.Empty;
        EnsureSelectionsForCurrentTable(resetProjectColumns: true);
    }

    private void Open() => _open = true;

    private void Close() => _open = false;

    private void OnTableChanged(ChangeEventArgs args)
    {
        _table = args.Value?.ToString() ?? string.Empty;
        EnsureSelectionsForCurrentTable(resetProjectColumns: true);
    }

    private void OnFilterColumnChanged(HelperFilter filter, ChangeEventArgs args)
    {
        filter.Column = args.Value?.ToString() ?? string.Empty;
        filter.Operator = GetDefaultOperatorForColumn(filter.Column);
    }

    private static void OnFilterOperatorChanged(HelperFilter filter, ChangeEventArgs args)
    {
        filter.Operator = args.Value?.ToString() ?? string.Empty;
    }

    private void OnLimitModeChanged(ChangeEventArgs args)
    {
        _limitMode = args.Value?.ToString() ?? string.Empty;
        if (_limitMode != CustomLimitMode)
        {
            _customLimit = null;
        }
        else
        {
            _customLimit ??= 100;
        }
    }

    private void AddFilter()
    {
        var column = GetDefaultFilterColumn();
        if (string.IsNullOrWhiteSpace(column))
        {
            return;
        }

        _filters.Add(new HelperFilter
        {
            Column = column,
            Operator = GetDefaultOperatorForColumn(column),
            Value = string.Empty
        });
    }

    private void RemoveFilter(HelperFilter filter) => _filters.Remove(filter);

    private async Task InsertAsync()
    {
        var query = GeneratedQuery;
        if (string.IsNullOrWhiteSpace(query))
        {
            return;
        }

        await InsertRequested.InvokeAsync(query);
        Close();
    }

    private async Task AppendAsync()
    {
        var query = GeneratedQuery;
        if (string.IsNullOrWhiteSpace(query))
        {
            return;
        }

        await AppendRequested.InvokeAsync(query);
        Close();
    }

    private async Task CopyPreviewAsync()
    {
        if (!CanGenerate)
        {
            return;
        }

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", GeneratedQuery);
    }

    private void ClearBuilder()
    {
        _timeRange = string.Empty;
        _filters.Clear();
        _sortDirection = "desc";
        _limitMode = string.Empty;
        _customLimit = null;
        EnsureSelectionsForCurrentTable(resetProjectColumns: true);
    }

    private void EnsureSelectionsForCurrentTable(bool resetProjectColumns)
    {
        if (SelectedTable is null)
        {
            _timeColumn = string.Empty;
            _sortColumn = string.Empty;
            _projectColumns = string.Empty;
            _filters.Clear();
            return;
        }

        if (!HasTimeColumns)
        {
            _timeRange = string.Empty;
            _timeColumn = string.Empty;
        }
        else if (!ColumnExists(_timeColumn) || !IsDateTimeColumn(GetColumn(_timeColumn)))
        {
            _timeColumn = GetPreferredColumn(TimeColumns, ["Timestamp", "TimeGenerated", "EventTime", "CreatedAt"]);
        }

        if (!string.IsNullOrWhiteSpace(_sortColumn) && !ColumnExists(_sortColumn))
        {
            _sortColumn = string.Empty;
        }

        if (string.IsNullOrWhiteSpace(_sortColumn) && HasTimeColumns)
        {
            _sortColumn = _timeColumn;
        }

        for (var i = _filters.Count - 1; i >= 0; i--)
        {
            var filter = _filters[i];
            if (!ColumnExists(filter.Column))
            {
                var replacement = GetDefaultFilterColumn();
                if (string.IsNullOrWhiteSpace(replacement))
                {
                    _filters.RemoveAt(i);
                    continue;
                }

                filter.Column = replacement;
                filter.Operator = GetDefaultOperatorForColumn(replacement);
            }
            else if (!GetOperatorsForColumn(filter.Column).Contains(filter.Operator, StringComparer.Ordinal))
            {
                filter.Operator = GetDefaultOperatorForColumn(filter.Column);
            }
        }

        if (resetProjectColumns)
        {
            _projectColumns = BuildDefaultProjection();
        }
        else
        {
            _projectColumns = NormalizeColumnList(_projectColumns);
        }
    }

    private string BuildQuery()
    {
        var lines = new List<string> { _table.Trim() };

        if (HasTimeLimit && !string.IsNullOrWhiteSpace(_timeColumn))
        {
            lines.Add($"| where {_timeColumn.Trim()} > ago({_timeRange.Trim()})");
        }

        foreach (var filter in _filters.Where(filter => filter.IsComplete && ColumnExists(filter.Column)))
        {
            lines.Add($"| where {filter.Column.Trim()} {filter.Operator.Trim()} {FormatValue(filter)}");
        }

        var projectColumns = NormalizeColumnList(_projectColumns);
        if (!string.IsNullOrWhiteSpace(projectColumns))
        {
            lines.Add($"| project {projectColumns}");
        }

        if (!string.IsNullOrWhiteSpace(_sortColumn) && ColumnExists(_sortColumn))
        {
            lines.Add($"| sort by {_sortColumn.Trim()} {_sortDirection}");
        }

        if (EffectiveLimit is int limit)
        {
            lines.Add($"| take {limit}");
        }

        return string.Join(Environment.NewLine, lines);
    }

    private string NormalizeColumnList(string value)
    {
        var knownColumns = CurrentColumns
            .Select(static column => column.Name)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        return string.Join(", ", value
            .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .Where(knownColumns.Contains)
            .Distinct(StringComparer.OrdinalIgnoreCase));
    }

    private string FormatValue(HelperFilter filter)
    {
        var value = filter.Value.Trim();
        var column = GetColumn(filter.Column);
        return RequiresStringLiteral(filter.Operator, column)
            ? $"\"{EscapeKqlString(value)}\""
            : value;
    }

    private string[] GetOperatorsForColumn(string columnName)
    {
        var column = GetColumn(columnName);
        if (column is null)
        {
            return ["==", "!="];
        }

        var type = column.Type.Trim().ToLowerInvariant();
        return type switch
        {
            "string" => ["==", "!=", "contains", "has", "startswith", "endswith"],
            "dynamic" => ["==", "!=", "contains", "has"],
            "bool" => ["==", "!="],
            "datetime" => ["==", "!=", ">", "<", ">=", "<="],
            "timespan" => ["==", "!=", ">", "<", ">=", "<="],
            "int" or "long" or "real" or "decimal" or "double" => ["==", "!=", ">", "<", ">=", "<="],
            _ => ["==", "!=", "contains", "has"]
        };
    }

    private string GetDefaultOperatorForColumn(string columnName)
    {
        var column = GetColumn(columnName);
        return column is not null && IsStringLikeColumn(column) ? "contains" : "==";
    }

    private string GetValuePlaceholder(string columnName)
    {
        var column = GetColumn(columnName);
        if (column is null)
        {
            return "value";
        }

        return column.Type.Trim().ToLowerInvariant() switch
        {
            "datetime" => "ago(24h) or 2026-06-01T00:00:00Z",
            "bool" => "true",
            "int" or "long" or "real" or "decimal" or "double" => "100",
            _ => "value"
        };
    }

    private string GetDefaultFilterColumn()
    {
        var stringColumns = CurrentColumns.Where(IsStringLikeColumn).ToArray();
        if (stringColumns.Length > 0)
        {
            return GetPreferredColumn(stringColumns, ["FileName", "ProcessCommandLine", "DnsQuery", "Query", "RemoteIp", "RemoteIP", "AccountName", "DeviceName"]);
        }

        return CurrentColumns.FirstOrDefault()?.Name ?? string.Empty;
    }

    private string BuildDefaultProjection()
    {
        if (CurrentColumns.Count == 0)
        {
            return string.Empty;
        }

        var preferred = new[]
        {
            "Timestamp",
            "DeviceName",
            "AccountName",
            "FileName",
            "ProcessCommandLine",
            "DnsQuery",
            "Query",
            "RemoteIp",
            "RemoteIP",
            "RemotePort",
            "ActionType"
        };

        var selected = new List<string>();
        foreach (var name in preferred)
        {
            var column = CurrentColumns.FirstOrDefault(column => string.Equals(column.Name, name, StringComparison.OrdinalIgnoreCase));
            if (column is not null && !selected.Contains(column.Name, StringComparer.OrdinalIgnoreCase))
            {
                selected.Add(column.Name);
            }
        }

        foreach (var column in CurrentColumns)
        {
            if (selected.Count >= 5)
            {
                break;
            }

            if (!selected.Contains(column.Name, StringComparer.OrdinalIgnoreCase))
            {
                selected.Add(column.Name);
            }
        }

        return string.Join(", ", selected);
    }

    private bool ColumnExists(string columnName) => GetColumn(columnName) is not null;

    private EditorColumnMetadata? GetColumn(string columnName)
        => CurrentColumns.FirstOrDefault(column => string.Equals(column.Name, columnName, StringComparison.OrdinalIgnoreCase));

    private static bool IsDateTimeColumn(EditorColumnMetadata? column)
        => string.Equals(column?.Type, "datetime", StringComparison.OrdinalIgnoreCase);

    private static bool IsStringLikeColumn(EditorColumnMetadata column)
        => column.Type is "string" or "dynamic";

    private static string GetPreferredColumn(IEnumerable<EditorColumnMetadata> columns, IReadOnlyList<string> preferredNames)
    {
        var columnList = columns.ToArray();
        foreach (var preferred in preferredNames)
        {
            var match = columnList.FirstOrDefault(column => string.Equals(column.Name, preferred, StringComparison.OrdinalIgnoreCase));
            if (match is not null)
            {
                return match.Name;
            }
        }

        return columnList.FirstOrDefault()?.Name ?? string.Empty;
    }

    private static bool RequiresStringLiteral(string op, EditorColumnMetadata? column)
    {
        if (op is "contains" or "has" or "startswith" or "endswith")
        {
            return true;
        }

        return op is "==" or "!=" && column is not null && IsStringLikeColumn(column);
    }

    private static string EscapeKqlString(string value)
        => value.Replace("\\", "\\\\", StringComparison.Ordinal).Replace("\"", "\\\"", StringComparison.Ordinal);

    private sealed class HelperFilter
    {
        public string Column { get; set; } = string.Empty;
        public string Operator { get; set; } = "==";
        public string Value { get; set; } = string.Empty;

        public bool IsComplete =>
            !string.IsNullOrWhiteSpace(Column)
            && !string.IsNullOrWhiteSpace(Operator)
            && !string.IsNullOrWhiteSpace(Value);
    }
}
