@namespace Hunting.Web.Components.Dz
@using Hunting.Data
@using System.Globalization

<div class="dz-query-result-table">
    @if (Result is null)
    {
        <div class="dashboard-widget-state dashboard-widget-state-muted">
            No query result is available.
        </div>
    }
    else if (Result.RowCount == 0 || Result.ColumnCount == 0)
    {
        <div class="dashboard-widget-state dashboard-widget-state-muted">
            Query returned no rows.
        </div>
    }
    else
    {
        <div class="dz-query-result-table__toolbar">
            <div class="dz-query-result-table__meta">
                <span>@Result.RowCount rows</span>
                <span>@Result.ColumnCount columns</span>
                @if (Duration > TimeSpan.Zero)
                {
                    <span>@Duration.TotalMilliseconds.ToString("F0", CultureInfo.InvariantCulture) ms</span>
                }
            </div>

            @if (ShowQuickFilter)
            {
                <MudTextField T="string"
                              Value="_quickFilter"
                              ValueChanged="OnQuickFilterChangedAsync"
                              Placeholder="Filter results"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Immediate="true"
                              Clearable="true"
                              Class="dz-query-result-table__filter" />
            }
        </div>

        <MudTable T="int"
                  Items="FilteredRows"
                  Dense="true"
                  Hover="true"
                  Striped="true"
                  Bordered="false"
                  Elevation="0"
                  FixedHeader="true"
                  Height="@Height"
                  RowsPerPage="@RowsPerPage"
                  Class="dz-query-result-table__mud">
            <HeaderContent>
                @foreach (var columnIndex in VisibleColumns)
                {
                    <MudTh>
                        <MudTableSortLabel T="int" SortBy="@CreateSortSelector(columnIndex)">
                            <span title="@Result.Columns[columnIndex].TypeName">
                                @Result.Columns[columnIndex].Name
                            </span>
                        </MudTableSortLabel>
                    </MudTh>
                }
            </HeaderContent>
            <RowTemplate>
                @foreach (var columnIndex in VisibleColumns)
                {
                    var value = Result.GetValue(context, columnIndex);
                    var formatted = FormatCell(value);

                    <MudTd DataLabel="@Result.Columns[columnIndex].Name">
                        <span title="@formatted">@formatted</span>
                    </MudTd>
                }
            </RowTemplate>
            <NoRecordsContent>
                <div class="dashboard-widget-state dashboard-widget-state-muted">
                    No rows match the current filter.
                </div>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager PageSizeOptions="@PageSizeOptions" />
            </PagerContent>
        </MudTable>
    }
</div>

@code {
    private string? _quickFilter;

    [Parameter]
    public QueryResult? Result { get; set; }

    [Parameter]
    public TimeSpan Duration { get; set; }

    [Parameter]
    public int MaxColumns { get; set; } = 30;

    [Parameter]
    public int RowsPerPage { get; set; } = 25;

    [Parameter]
    public int[] PageSizeOptions { get; set; } = [10, 25, 50, 100];

    [Parameter]
    public string Height { get; set; } = "100%";

    [Parameter]
    public bool ShowQuickFilter { get; set; } = true;

    private IEnumerable<int> VisibleColumns
    {
        get
        {
            if (Result is null)
            {
                return [];
            }

            var count = Math.Clamp(MaxColumns, 1, Result.ColumnCount);
            return Enumerable.Range(0, count);
        }
    }

    private IEnumerable<int> FilteredRows
    {
        get
        {
            if (Result is null)
            {
                return [];
            }

            var rows = Enumerable.Range(0, Result.RowCount);
            if (string.IsNullOrWhiteSpace(_quickFilter))
            {
                return rows;
            }

            var filter = _quickFilter.Trim();
            var columns = VisibleColumns.ToArray();

            return rows.Where(rowIndex => columns.Any(columnIndex =>
                FormatCell(Result.GetValue(rowIndex, columnIndex))
                    .Contains(filter, StringComparison.OrdinalIgnoreCase)));
        }
    }

    private Task OnQuickFilterChangedAsync(string? value)
    {
        _quickFilter = value;
        return Task.CompletedTask;
    }

    private Func<int, object> CreateSortSelector(int columnIndex)
        => rowIndex => Result is null
            ? string.Empty
            : GetSortableValue(Result.GetValue(rowIndex, columnIndex));

    private static object GetSortableValue(object? value)
    {
        return value switch
        {
            null => string.Empty,
            IComparable comparable => comparable,
            _ => FormatCell(value)
        };
    }

    private static string FormatCell(object? value)
    {
        return value switch
        {
            null => string.Empty,
            DateTime dateTime => dateTime.ToString("O", CultureInfo.InvariantCulture),
            DateTimeOffset dateTimeOffset => dateTimeOffset.ToString("O", CultureInfo.InvariantCulture),
            bool boolean => boolean ? "true" : "false",
            _ => Convert.ToString(value, CultureInfo.InvariantCulture) ?? string.Empty
        };
    }
}
