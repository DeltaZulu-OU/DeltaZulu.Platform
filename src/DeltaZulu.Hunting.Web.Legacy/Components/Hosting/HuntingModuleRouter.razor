@namespace DeltaZulu.Hunting.Web.Components.Hosting
@using Microsoft.AspNetCore.Components.Routing

<Router AppAssembly="@typeof(HuntingModuleRouter).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@DefaultLayout" />
    </Found>
    <NotFound>
        <LayoutView Layout="@DefaultLayout">
            @NotFound
        </LayoutView>
    </NotFound>
</Router>

@code {
    [Parameter]
    public Type DefaultLayout { get; set; } = typeof(DeltaZulu.Hunting.Web.Components.Hosting.HuntingModuleRouter);

    [Parameter]
    public RenderFragment NotFound { get; set; } = builder => builder.AddContent(0, "Hunting page not found.");
}
