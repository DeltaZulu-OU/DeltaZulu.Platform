@page "/dashboards"
@namespace Hunting.Web.Pages
@using DeltaZulu.Hunting.Web.Dashboards.PageState
@inject DashboardListPageController Controller

<div class="dashboard-list-page">
    <header class="dashboard-page-header dashboard-list-header">
        <div>
            <p class="dashboard-eyebrow">Dashboards</p>
            <h1>Dashboards</h1>
            <p class="dashboard-page-subtitle">Create, import, open, and manage local dashboard definitions.</p>
        </div>
        <div class="dashboard-list-toolbar">
            <label class="dashboard-search" aria-label="Search dashboards">
                <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
                <input placeholder="Search dashboards"
                       value="@State.SearchText"
                       @oninput="OnSearchChanged" />
            </label>

            <div class="dashboard-list-actions-primary">
                <button class="hunt-btn dashboard-primary-action" @onclick="() => Controller.CreateDashboardAsync()">New dashboard</button>
                <button class="hunt-btn" @onclick="() => Controller.ImportDashboardAsync()">Import JSON</button>
            </div>
        </div>
    </header>

    @if (State.HasError)
    {
        <div class="dashboard-error">@State.Error</div>
    }

    @if (State.Loading)
    {
        <section class="dashboard-empty-state">
            <h2>Loading dashboards…</h2>
            <p>Reading dashboard summaries from local application persistence.</p>
        </section>
    }
    else if (State.HasNoDashboards)
    {
        <section class="dashboard-empty-state dashboard-list-empty">
            <h2>No dashboards</h2>
            <p>Create a dashboard or import one from JSON.</p>
            <div class="dashboard-empty-actions">
                <button class="hunt-btn dashboard-primary-action" @onclick="() => Controller.CreateDashboardAsync()">Create dashboard</button>
                <button class="hunt-btn" @onclick="() => Controller.ImportDashboardAsync()">Import JSON</button>
            </div>
        </section>
    }
    else
    {
        <section class="dashboard-list-panel" aria-label="Dashboard list panel">
            <div class="dashboard-list-panel-header">
                <div>
                    <h2>Local dashboards</h2>
                    <p>@State.DashboardRangeText</p>
                </div>

                @if (State.HasPagination)
                {
                    <nav class="dashboard-pagination" aria-label="Dashboard pages">
                        <button class="hunt-btn dashboard-page-button"
                                disabled="@(State.Page <= 1)"
                                @onclick="Controller.PreviousPage">
                            Previous
                        </button>
                        <span>Page @State.Page of @State.TotalPages</span>
                        <button class="hunt-btn dashboard-page-button"
                                disabled="@(State.Page >= State.TotalPages)"
                                @onclick="Controller.NextPage">
                            Next
                        </button>
                    </nav>
                }
            </div>

            @if (State.HasNoMatches)
            {
                <section class="dashboard-empty-state dashboard-list-empty">
                    <h2>No matching dashboards</h2>
                    <p>Clear the search text or use a different term.</p>
                    <div class="dashboard-empty-actions">
                        <button class="hunt-btn" @onclick="Controller.ClearSearch">Clear search</button>
                    </div>
                </section>
            }
            else
            {
                <div class="dashboard-list" aria-label="Dashboard cards">
                    @foreach (var dashboard in State.PagedDashboards)
                    {
                        <article class="dashboard-list-card">
                            <div class="dashboard-card-main">
                                <div class="dashboard-card-title-row">
                                    <h2>@dashboard.Name</h2>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(dashboard.Description))
                                {
                                    <p>@dashboard.Description</p>
                                }
                                else
                                {
                                    <p class="dashboard-muted">No description.</p>
                                }
                            </div>

                            <dl class="dashboard-list-meta">
                                <div>
                                    <dt>Widgets</dt>
                                    <dd>@dashboard.WidgetCount</dd>
                                </div>
                                <div>
                                    <dt>Updated</dt>
                                    <dd>@dashboard.UpdatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                                </div>
                            </dl>

                            <div class="dashboard-card-actions">
                                <button class="hunt-btn dashboard-primary-action" @onclick="() => Controller.OpenDashboard(dashboard.Id)">Open</button>
                                <MudMenu Class="dashboard-card-menu"
                                         Dense="true"
                                         AnchorOrigin="Origin.BottomRight"
                                         TransformOrigin="Origin.TopRight"
                                         Icon="@Icons.Material.Filled.MoreVert"
                                         Size="Size.Small"
                                         Variant="Variant.Outlined">
                                    <MudMenuItem OnClick="() => Controller.DeleteDashboardAsync(dashboard.Id)">Delete</MudMenuItem>
                                </MudMenu>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }
</div>

@code {
    private DashboardListPageState State => Controller.State;

    protected override async Task OnInitializedAsync()
    {
        await Controller.LoadDashboardsAsync();
    }

    private void OnSearchChanged(ChangeEventArgs args)
    {
        Controller.SetSearchText(args.Value?.ToString());
    }
}
