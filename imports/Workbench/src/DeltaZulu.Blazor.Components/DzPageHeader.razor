<div class="dz-page-header @Class" @attributes="AdditionalAttributes">
    <div class="dz-page-header__content">
        @if (!string.IsNullOrWhiteSpace(Eyebrow))
        {
            <span class="eyebrow dz-page-header__eyebrow">@Eyebrow</span>
        }

        <MudText Typo="@TitleTypo" Class="dz-page-header__title">@Title</MudText>

        @if (!string.IsNullOrWhiteSpace(Description))
        {
            <MudText Typo="Typo.body2" Class="dz-page-header__description">@Description</MudText>
        }

        @if (Metadata is not null)
        {
            <div class="dz-page-header__metadata">
                @Metadata
            </div>
        }
    </div>

    @if (Actions is not null)
    {
        <div class="dz-page-header__actions">
            @Actions
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? Eyebrow { get; set; }
    [Parameter] public Typo TitleTypo { get; set; } = Typo.h5;
    [Parameter] public RenderFragment? Metadata { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }
}
